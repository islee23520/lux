{
  "name": "@linalab/lux-app",
  "version": "0.1.0",
  "private": true,
  "description": "Standalone LUX app workspace.",
  "type": "module",
  "workspaces": [
    "mcp-helper"
  ],
  "scripts": {
    "mcp-helper:build": "npm --workspace mcp-helper run build",
    "mcp-helper:test": "npm --workspace mcp-helper run test",
    "gateway:build": "cargo build --workspace",
    "gateway:test": "cargo test --workspace",
    "policy-check": "node scripts/policy-scan.mjs"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
