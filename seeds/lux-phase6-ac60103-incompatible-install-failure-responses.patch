+async fn preflight_adapted_skill_install(
+    State(state): State<GatewayState>,
+    headers: HeaderMap,
+    Json(request): Json<AdaptedSkillInstallRequest>,
+) -> Result<(StatusCode, Json<serde_json::Value>), Response> {
+    require_token(&state, &headers)?;
+    let Some(project_root) = state.config.project_root.as_ref() else {
+        return Err((
+            StatusCode::SERVICE_UNAVAILABLE,
+            Json(skill_install_error_response_json(
+                "project_scope_required",
+                "project path is not configured",
+                None,
+            )),
+        )
+            .into_response());
+    };
+
+    let adaptation = match build_skill_adaptation_metadata_for_project(
+        &request.name,
+        &request.source,
+        project_root,
+    ) {
+        Ok(adaptation) => adaptation,
+        Err(error) => {
+            return Err((
+                StatusCode::BAD_REQUEST,
+                Json(skill_install_error_response_json(
+                    "adapted_skill_preflight_failed",
+                    &error.to_string(),
+                    None,
+                )),
+            )
+                .into_response());
+        }
+    };
+
+    if let Some(failure) = adapted_skill_install_failure_payload(&request.name, &adaptation) {
+        let message = adapted_skill_install_failure_message(&request.name, &failure);
+        return Err((
+            StatusCode::CONFLICT,
+            Json(skill_install_error_response_json(
+                "adapted_skill_incompatible",
+                &message,
+                Some(failure),
+            )),
+        )
+            .into_response());
+    }
+
+    Ok((
+        StatusCode::OK,
+        Json(serde_json::json!({
+            "installable": true,
+            "installed": false,
+            "name": request.name,
+            "adapted": true,
+            "adaptation_metadata": adaptation,
+        })),
+    ))
+}
