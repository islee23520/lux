+fn parse_entries_with_diagnostics(reader: impl BufRead) -> AiLogReadResult {
+    let mut entries = Vec::new();
+    let mut skipped_lines = Vec::new();
+
+    for (index, line_result) in reader.lines().enumerate() {
+        let line_number = index + 1;
+        let line = match line_result {
+            Ok(line) => line,
+            Err(error) => {
+                skipped_lines.push(AiLogSkippedLine {
+                    line_number,
+                    reason: "read-error".to_string(),
+                    message: error.to_string(),
+                });
+                continue;
+            }
+        };
+        let trimmed = line.trim();
+        if trimmed.is_empty() {
+            continue;
+        }
+        let value = match serde_json::from_str::<Value>(trimmed) {
+            Ok(value) => value,
+            Err(error) => {
+                skipped_lines.push(AiLogSkippedLine {
+                    line_number,
+                    reason: "invalid-json".to_string(),
+                    message: error.to_string(),
+                });
+                continue;
+            }
+        };
+        entries.push(AiLogEntry {
+            line_number,
+            timestamp: timestamp(&value).unwrap_or_default(),
+            value,
+        });
+    }
+
+    AiLogReadResult {
+        entries,
+        diagnostics: AiLogReadDiagnostics {
+            skipped_line_count: skipped_lines.len(),
+            skipped_lines,
+        },
+    }
+}
