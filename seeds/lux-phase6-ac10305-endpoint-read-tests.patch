+    #[tokio::test]
+    async fn ai_log_read_endpoints_reject_invalid_project_paths() {
+        let nanos = SystemTime::now()
+            .duration_since(UNIX_EPOCH)
+            .unwrap()
+            .as_nanos();
+        let missing_project =
+            std::env::temp_dir().join(format!("lux-gateway-missing-project-{nanos}"));
+        let invalid_project =
+            std::env::temp_dir().join(format!("lux-gateway-invalid-project-{nanos}"));
+        fs::create_dir_all(&invalid_project).unwrap();
+
+        for endpoint in [
+            "/api/ai-log",
+            "/api/ai-log/context",
+            "/api/ai-log/files",
+            "/api/ai-log/tail",
+            "/api/ai-log/recent",
+        ] {
+            let missing_response = authenticated_get(
+                test_app(),
+                &format!("{endpoint}?project_path={}", missing_project.display()),
+            )
+            .await;
+            assert_eq!(
+                missing_response.status(),
+                StatusCode::BAD_REQUEST,
+                "{endpoint} should reject inaccessible project paths"
+            );
+
+            let invalid_response = authenticated_get(
+                test_app(),
+                &format!("{endpoint}?project_path={}", invalid_project.display()),
+            )
+            .await;
+            assert_eq!(
+                invalid_response.status(),
+                StatusCode::BAD_REQUEST,
+                "{endpoint} should reject directories without Unity project markers"
+            );
+        }
+
+        let _ = fs::remove_dir_all(invalid_project);
+    }
