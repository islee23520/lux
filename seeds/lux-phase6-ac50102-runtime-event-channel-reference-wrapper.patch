+using System;
+using System.Collections.Generic;
+using UnityEngine;
+
+namespace Linalab.Lux.Runtime
+{
+    [DisallowMultipleComponent]
+    [AddComponentMenu("LUX/Runtime Event Channel Emitter")]
+    public sealed class LuxRuntimeEventChannelEmitter : MonoBehaviour
+    {
+        [SerializeField] LuxRuntimeEventChannel eventChannel;
+        [SerializeField] string eventTypeOverride = string.Empty;
+        [SerializeField] string targetOverride = string.Empty;
+        [SerializeField] string summaryOverride = string.Empty;
+        [SerializeField] bool includeGameObjectName = true;
+        [SerializeField] List<LuxRuntimeEventChannelAttribute> attributes = new List<LuxRuntimeEventChannelAttribute>();
+
+        public LuxRuntimeEventChannel EventChannel => eventChannel;
+
+        public LuxRuntimeEventRecord Emit()
+        {
+            return Emit(null, null, null, null);
+        }
+
+        public LuxRuntimeEventRecord Emit(string runtimeEventType)
+        {
+            return Emit(runtimeEventType, null, null, null);
+        }
+
+        public LuxRuntimeEventRecord Emit(IReadOnlyDictionary<string, object> runtimeAttributes)
+        {
+            return Emit(null, runtimeAttributes, null, null);
+        }
+
+        public LuxRuntimeEventRecord Emit(
+            string runtimeEventType,
+            IReadOnlyDictionary<string, object> runtimeAttributes = null,
+            string runtimeTarget = null,
+            string runtimeSummary = null)
+        {
+            if (!TryEmit(runtimeEventType, runtimeAttributes, runtimeTarget, runtimeSummary, out var record))
+            {
+                throw new InvalidOperationException("LuxRuntimeEventChannelEmitter requires a LuxRuntimeEventChannel asset reference before emitting runtime events.");
+            }
+
+            return record;
+        }
+
+        public LuxRuntimeEventRecord Log()
+        {
+            return Emit();
+        }
+
+        public LuxRuntimeEventRecord Log(string runtimeEventType)
+        {
+            return Emit(runtimeEventType);
+        }
+
+        public void EmitFromUnityEvent()
+        {
+            TryEmit(out _);
+        }
+
+        public void EmitFromUnityEvent(string runtimeEventType)
+        {
+            TryEmit(runtimeEventType, out _);
+        }
+
+        public void LogFromUnityEvent()
+        {
+            EmitFromUnityEvent();
+        }
+
+        public void LogFromUnityEvent(string runtimeEventType)
+        {
+            EmitFromUnityEvent(runtimeEventType);
+        }
+
+        public bool TryEmit(out LuxRuntimeEventRecord record)
+        {
+            return TryEmit(null, null, null, null, out record);
+        }
+
+        public bool TryEmit(string runtimeEventType, out LuxRuntimeEventRecord record)
+        {
+            return TryEmit(runtimeEventType, null, null, null, out record);
+        }
+
+        public bool TryEmit(
+            string runtimeEventType,
+            IReadOnlyDictionary<string, object> runtimeAttributes,
+            string runtimeTarget,
+            string runtimeSummary,
+            out LuxRuntimeEventRecord record)
+        {
+            record = null;
+            if (eventChannel == null)
+            {
+                return false;
+            }
+
+            string selectedEventType = FirstNonEmpty(runtimeEventType, eventTypeOverride);
+            string selectedTarget = FirstNonEmpty(runtimeTarget, targetOverride);
+            string selectedSummary = FirstNonEmpty(runtimeSummary, summaryOverride);
+            record = eventChannel.Emit(
+                selectedEventType,
+                BuildAttributes(runtimeAttributes),
+                selectedTarget,
+                selectedSummary);
+            return true;
+        }
+
+        public void SetChannel(LuxRuntimeEventChannel channel)
+        {
+            eventChannel = channel;
+        }
+
+        public void SetEventTypeOverride(string eventType)
+        {
+            eventTypeOverride = eventType ?? string.Empty;
+        }
+
+        public void SetTargetOverride(string target)
+        {
+            targetOverride = target ?? string.Empty;
+        }
+
+        public void SetSummaryOverride(string summary)
+        {
+            summaryOverride = summary ?? string.Empty;
+        }
+
+        public void SetIncludeGameObjectName(bool include)
+        {
+            includeGameObjectName = include;
+        }
+
+        public void Configure(
+            LuxRuntimeEventChannel channel,
+            string eventType,
+            string target,
+            string summary,
+            IEnumerable<LuxRuntimeEventChannelAttribute> attributes,
+            bool includeGameObjectName = true)
+        {
+            eventChannel = channel;
+            eventTypeOverride = eventType ?? string.Empty;
+            targetOverride = target ?? string.Empty;
+            summaryOverride = summary ?? string.Empty;
+            this.attributes = attributes == null
+                ? new List<LuxRuntimeEventChannelAttribute>()
+                : new List<LuxRuntimeEventChannelAttribute>(attributes);
+            this.includeGameObjectName = includeGameObjectName;
+        }
+
+        Dictionary<string, object> BuildAttributes(IReadOnlyDictionary<string, object> runtimeAttributes)
+        {
+            var result = new Dictionary<string, object>(StringComparer.Ordinal);
+            foreach (var attribute in attributes)
+            {
+                attribute?.TryAddTo(result);
+            }
+
+            if (includeGameObjectName && gameObject != null && !result.ContainsKey("gameObject"))
+            {
+                result["gameObject"] = gameObject.name;
+            }
+
+            if (runtimeAttributes == null)
+            {
+                return result;
+            }
+
+            foreach (var pair in runtimeAttributes)
+            {
+                if (!string.IsNullOrWhiteSpace(pair.Key))
+                {
+                    result[pair.Key] = pair.Value;
+                }
+            }
+
+            return result;
+        }
+
+        static string FirstNonEmpty(string first, string second)
+        {
+            return !string.IsNullOrWhiteSpace(first) ? first : second;
+        }
+    }
+}
