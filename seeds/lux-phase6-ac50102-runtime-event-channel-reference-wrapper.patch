+using System;
+using System.Collections.Generic;
+using System.IO;
+using Linalab.Lux.Runtime;
+using NUnit.Framework;
+using UnityEditor;
+using UnityEngine;
+
+namespace Linalab.LuxEditor.Tests
+{
+    public sealed class LuxRuntimeEventChannelComponentTests
+    {
+        string tempDirectory;
+
+        [SetUp]
+        public void SetUp()
+        {
+            tempDirectory = Path.Combine(Path.GetTempPath(), "LuxRuntimeEventChannelComponentTests", Guid.NewGuid().ToString("N"));
+            Directory.CreateDirectory(tempDirectory);
+            LuxRuntimeEvent.ConfigureForTests(null, tempDirectory, () => new DateTime(2026, 5, 5, 0, 0, 0, DateTimeKind.Utc));
+        }
+
+        [TearDown]
+        public void TearDown()
+        {
+            LuxRuntimeEvent.ResetForTests();
+            if (!string.IsNullOrWhiteSpace(tempDirectory) && Directory.Exists(tempDirectory))
+            {
+                Directory.Delete(tempDirectory, true);
+            }
+        }
+
+        [Test]
+        public void Emit_ForwardsSerializedChannelReferenceToRuntimeLog()
+        {
+            string projectRoot = Path.Combine(tempDirectory, "Project");
+            var channel = ScriptableObject.CreateInstance<LuxRuntimeEventChannel>();
+            channel.Configure(
+                "checkpoint_reached",
+                "Checkpoints/Default",
+                "Checkpoint reached through channel asset.",
+                projectRoot,
+                null,
+                new[] { new LuxRuntimeEventChannelMetadata("scenePath", "Assets/Scenes/Arena.unity") },
+                new[] { LuxRuntimeEventChannelAttribute.String("channelAttribute", "asset-value") });
+            var gameObject = new GameObject("Checkpoint Trigger");
+            var component = gameObject.AddComponent<LuxRuntimeEventChannelEmitter>();
+            component.Configure(
+                channel,
+                "checkpoint_entered",
+                "Checkpoints/Entrance",
+                "Checkpoint entered through serialized component.",
+                new[]
+                {
+                    LuxRuntimeEventChannelAttribute.String("checkpointId", "entrance"),
+                    LuxRuntimeEventChannelAttribute.Integer("scoreValue", 250)
+                });
+
+            var record = component.Emit();
+
+            string logPath = Path.Combine(projectRoot, "UserSettings", "LuxAiActionLog.jsonl");
+            string line = File.ReadAllText(logPath);
+            Assert.That(record.source, Is.EqualTo("unity-runtime"));
+            Assert.That(record.actor, Is.EqualTo("gameplay"));
+            Assert.That(record.category, Is.EqualTo("runtime"));
+            Assert.That(record.payload.kind, Is.EqualTo("runtime-gameplay-event"));
+            Assert.That(record.payload.eventType, Is.EqualTo("checkpoint_entered"));
+            Assert.That(line, Does.Contain("\"eventType\":\"checkpoint_entered\""));
+            Assert.That(line, Does.Contain("\"target\":\"Checkpoints/Entrance\""));
+            Assert.That(line, Does.Contain("\"summary\":\"Checkpoint entered through serialized component.\""));
+            Assert.That(line, Does.Contain("\"channelAttribute\":\"asset-value\""));
+            Assert.That(line, Does.Contain("\"checkpointId\":\"entrance\""));
+            Assert.That(line, Does.Contain("\"scoreValue\":250"));
+            Assert.That(line, Does.Contain("\"gameObject\":\"Checkpoint Trigger\""));
+            Assert.That(line, Does.Contain("\"scenePath\":\"Assets/Scenes/Arena.unity\""));
+
+            UnityEngine.Object.DestroyImmediate(gameObject);
+            UnityEngine.Object.DestroyImmediate(channel);
+        }
+
+        [Test]
+        public void Emit_AcceptsRuntimeOverridesAndUsesUnderlyingRedaction()
+        {
+            string logPath = Path.Combine(tempDirectory, "runtime-events.jsonl");
+            var channel = ScriptableObject.CreateInstance<LuxRuntimeEventChannel>();
+            channel.Configure(
+                "default_event",
+                "Runtime",
+                "Default runtime channel summary.",
+                null,
+                logPath,
+                new[] { new LuxRuntimeEventChannelMetadata("apiKey", "raw-secret") },
+                new[] { LuxRuntimeEventChannelAttribute.String("authorization", "Bearer raw-secret") });
+            var gameObject = new GameObject("Secret Runtime Source");
+            var component = gameObject.AddComponent<LuxRuntimeEventChannelEmitter>();
+            component.Configure(channel, null, null, null, null);
+
+            component.Emit(
+                "runtime_secret",
+                new Dictionary<string, object> { ["token"] = "raw-secret", ["safeValue"] = "visible" },
+                "Runtime/Secret",
+                "Bearer raw-secret should be redacted.");
+
+            string line = File.ReadAllText(logPath);
+            Assert.That(line, Does.Contain("\"eventType\":\"runtime_secret\""));
+            Assert.That(line, Does.Contain("\"safeValue\":\"visible\""));
+            Assert.That(line, Does.Not.Contain("raw-secret"));
+            Assert.That(line, Does.Contain("[REDACTED]"));
+
+            UnityEngine.Object.DestroyImmediate(gameObject);
+            UnityEngine.Object.DestroyImmediate(channel);
+        }
+
+        [Test]
+        public void EmitFromUnityEvent_ForwardsNoArgumentUnityEventCall()
+        {
+            string logPath = Path.Combine(tempDirectory, "unity-event-runtime-events.jsonl");
+            var channel = ScriptableObject.CreateInstance<LuxRuntimeEventChannel>();
+            channel.Configure(
+                "unity_event_triggered",
+                "UnityEvent",
+                "UnityEvent forwarded through runtime event component.",
+                null,
+                logPath,
+                null,
+                null);
+            var gameObject = new GameObject("UnityEvent Runtime Source");
+            var component = gameObject.AddComponent<LuxRuntimeEventChannelEmitter>();
+            component.Configure(channel, null, null, null, new[] { LuxRuntimeEventChannelAttribute.String("source", "unity-event") }, includeGameObjectName: false);
+
+            component.EmitFromUnityEvent();
+
+            string line = File.ReadAllText(logPath);
+            Assert.That(line, Does.Contain("\"eventType\":\"unity_event_triggered\""));
+            Assert.That(line, Does.Contain("\"source\":\"unity-event\""));
+            UnityEngine.Object.DestroyImmediate(gameObject);
+            UnityEngine.Object.DestroyImmediate(channel);
+        }
+
+        [Test]
+        public void TryEmit_ReturnsFalseWhenChannelReferenceIsMissing()
+        {
+            var gameObject = new GameObject("Unconfigured Runtime Source");
+            var component = gameObject.AddComponent<LuxRuntimeEventChannelEmitter>();
+
+            bool emitted = component.TryEmit(out var record);
+
+            Assert.That(emitted, Is.False);
+            Assert.That(record, Is.Null);
+            Assert.That(File.Exists(Path.Combine(tempDirectory, "UserSettings", "LuxAiActionLog.jsonl")), Is.False);
+            UnityEngine.Object.DestroyImmediate(gameObject);
+        }
+
+        [Test]
+        public void ComponentConfiguration_IsUnitySerialized()
+        {
+            var channel = ScriptableObject.CreateInstance<LuxRuntimeEventChannel>();
+            var gameObject = new GameObject("Serialized Runtime Source");
+            var component = gameObject.AddComponent<LuxRuntimeEventChannelEmitter>();
+            component.Configure(channel, "serialized_event", "Serialized/Target", "Serialized component summary.", new[] { LuxRuntimeEventChannelAttribute.Float("elapsedSeconds", 42.5f) });
+
+            string json = EditorJsonUtility.ToJson(component);
+
+            Assert.That(json, Does.Contain("serialized_event"));
+            Assert.That(json, Does.Contain("Serialized/Target"));
+            Assert.That(json, Does.Contain("elapsedSeconds"));
+            UnityEngine.Object.DestroyImmediate(gameObject);
+            UnityEngine.Object.DestroyImmediate(channel);
+        }
+    }
+}
