+        path: path.clone(),
+        relative_path: LOG_RELATIVE_PATH.join("/"),
+        parent_directory: parent_directory.clone(),
+        previous_path: previous_path.clone(),
+        record_kind: AI_WORK_STEP_RECORD_KIND.to_string(),
+        lifecycle_state: ai_work_step_log_lifecycle_state(&path, &parent_directory, &previous_path).to_string(),
+        creates_parent_on_ensure: true,
+        creates_file_on_first_append: true,
+    }
+}
