+using System;
+using System.Collections.Generic;
+using System.IO;
+using Linalab.Lux.Runtime;
+using NUnit.Framework;
+using UnityEditor;
+using UnityEngine;
+
+namespace Linalab.LuxEditor.Tests
+{
+    public sealed class LuxRuntimeEventEmissionPathSchemaCompatibilityTests
+    {
+        string tempDirectory;
+
+        [SetUp]
+        public void SetUp()
+        {
+            tempDirectory = Path.Combine(Path.GetTempPath(), "LuxRuntimeEventEmissionPathSchemaCompatibilityTests", Guid.NewGuid().ToString("N"));
+            Directory.CreateDirectory(tempDirectory);
+            LuxRuntimeEvent.ConfigureForTests(
+                null,
+                tempDirectory,
+                () => new DateTime(2026, 5, 5, 13, 15, 0, DateTimeKind.Utc));
+        }
+
+        [TearDown]
+        public void TearDown()
+        {
+            LuxRuntimeEvent.ResetForTests();
+            if (!string.IsNullOrWhiteSpace(tempDirectory) && Directory.Exists(tempDirectory))
+            {
+                Directory.Delete(tempDirectory, true);
+            }
+        }
+
+        [Test]
+        public void StaticApiAndSerializedChannel_EmitCompatibleRuntimeEventPayloadSchemas()
+        {
+            string projectRoot = Path.Combine(tempDirectory, "Project");
+            string directLogPath = Path.Combine(tempDirectory, "direct-runtime-events.jsonl");
+            string channelLogPath = Path.Combine(tempDirectory, "channel-runtime-events.jsonl");
+            var configuredChannel = ScriptableObject.CreateInstance<LuxRuntimeEventChannel>();
+            var serializedChannel = ScriptableObject.CreateInstance<LuxRuntimeEventChannel>();
+
+            try
+            {
+                var directRecord = LuxRuntimeEvent.Emit(
+                    "checkpoint_reached",
+                    new Dictionary<string, object>
+                    {
+                        ["checkpointId"] = "finish",
+                        ["elapsedSeconds"] = 42.5f,
+                        ["scoreValue"] = 500,
+                        ["isFinal"] = true,
+                        ["position"] = new Vector3(4.5f, 1f, -2.25f)
+                    },
+                    "Checkpoints/Finish",
+                    "Runtime schema compatibility checkpoint.",
+                    metadata: new Dictionary<string, string>
+                    {
+                        ["sample"] = "emission-schema-compatibility",
+                        ["scenePath"] = "Assets/Scenes/Checkpoint.unity"
+                    },
+                    options: new LuxRuntimeEventOptions
+                    {
+                        ProjectRoot = projectRoot,
+                        LogPath = directLogPath
+                    });
+
+                configuredChannel.Configure(
+                    "checkpoint_reached",
+                    "Checkpoints/Finish",
+                    "Runtime schema compatibility checkpoint.",
+                    projectRoot,
+                    channelLogPath,
+                    new[]
+                    {
+                        new LuxRuntimeEventChannelMetadata("sample", "emission-schema-compatibility"),
+                        new LuxRuntimeEventChannelMetadata("scenePath", "Assets/Scenes/Checkpoint.unity")
+                    },
+                    new[]
+                    {
+                        LuxRuntimeEventChannelAttribute.String("checkpointId", "finish"),
+                        LuxRuntimeEventChannelAttribute.Float("elapsedSeconds", 42.5f),
+                        LuxRuntimeEventChannelAttribute.Integer("scoreValue", 500),
+                        LuxRuntimeEventChannelAttribute.Boolean("isFinal", true),
+                        LuxRuntimeEventChannelAttribute.Vector3("position", new Vector3(4.5f, 1f, -2.25f))
+                    });
+                EditorJsonUtility.FromJsonOverwrite(EditorJsonUtility.ToJson(configuredChannel), serializedChannel);
+
+                var channelRecord = serializedChannel.Emit();
+                string directJson = SingleJsonLine(directLogPath);
+                string channelJson = SingleJsonLine(channelLogPath);
+
+                LuxRuntimeEventSchemaAssert.AssertCompatibleRuntimePayloads(directRecord, channelRecord);
+                LuxRuntimeEventSchemaAssert.AssertRuntimePayloadSchemaJson(directJson);
+                LuxRuntimeEventSchemaAssert.AssertRuntimePayloadSchemaJson(channelJson);
+            }
+            finally
+            {
+                UnityEngine.Object.DestroyImmediate(configuredChannel);
+                UnityEngine.Object.DestroyImmediate(serializedChannel);
+            }
+        }
+
+        static string SingleJsonLine(string logPath)
+        {
+            string[] lines = File.ReadAllLines(logPath);
+            Assert.That(lines, Has.Length.EqualTo(1), logPath);
+            return lines[0];
+        }
+    }
+}
