diff --git a/LuxEditorTests/Editor/LuxRuntimeEventSchemaAssert.cs b/LuxEditorTests/Editor/LuxRuntimeEventSchemaAssert.cs
new file mode 100644
index 0000000..a4f7011
--- /dev/null
+++ b/LuxEditorTests/Editor/LuxRuntimeEventSchemaAssert.cs
@@ -0,0 +1,159 @@
+using System.Collections;
+using System.Collections.Generic;
+using Linalab.Lux.Runtime;
+using NUnit.Framework;
+
+namespace Linalab.LuxEditor.Tests
+{
+    static class LuxRuntimeEventSchemaAssert
+    {
+        public static void AssertCompatibleRuntimePayloads(
+            LuxRuntimeEventRecord expected,
+            LuxRuntimeEventRecord actual)
+        {
+            Assert.That(expected, Is.Not.Null);
+            Assert.That(actual, Is.Not.Null);
+            Assert.That(expected.id, Is.Not.Empty);
+            Assert.That(actual.id, Is.Not.Empty);
+            Assert.That(actual.id, Is.Not.EqualTo(expected.id), "Each emission path must still produce a distinct event id.");
+            Assert.That(actual.schemaVersion, Is.EqualTo(expected.schemaVersion));
+            Assert.That(actual.protocol, Is.EqualTo(expected.protocol));
+            Assert.That(actual.timestampUtc, Is.EqualTo(expected.timestampUtc));
+            Assert.That(actual.projectPath, Is.EqualTo(expected.projectPath));
+            Assert.That(actual.source, Is.EqualTo(expected.source));
+            Assert.That(actual.actor, Is.EqualTo(expected.actor));
+            Assert.That(actual.category, Is.EqualTo(expected.category));
+            Assert.That(actual.type, Is.EqualTo(expected.type));
+            Assert.That(actual.action, Is.EqualTo(expected.action));
+            Assert.That(actual.target, Is.EqualTo(expected.target));
+            Assert.That(actual.summary, Is.EqualTo(expected.summary));
+            Assert.That(actual.message, Is.EqualTo(expected.message));
+            Assert.That(actual.severity, Is.EqualTo(expected.severity));
+            Assert.That(actual.success, Is.EqualTo(expected.success));
+            AssertStringDictionaryMatches(expected.metadata, actual.metadata, "metadata");
+            AssertCompatiblePayload(expected.payload, actual.payload);
+        }
+
+        public static void AssertRuntimePayloadSchemaJson(string json)
+        {
+            Assert.That(json, Does.Contain("\"schemaVersion\":1"));
+            Assert.That(json, Does.Contain("\"protocol\":\"lux.ai.action_log.v1\""));
+            Assert.That(json, Does.Contain("\"id\":\""));
+            Assert.That(json, Does.Contain("\"timestampUtc\":\""));
+            Assert.That(json, Does.Contain("\"projectPath\":\""));
+            Assert.That(json, Does.Contain("\"source\":\"unity-runtime\""));
+            Assert.That(json, Does.Contain("\"actor\":\"gameplay\""));
+            Assert.That(json, Does.Contain("\"category\":\"runtime\""));
+            Assert.That(json, Does.Contain("\"type\":\"checkpoint_reached\""));
+            Assert.That(json, Does.Contain("\"action\":\"checkpoint_reached\""));
+            Assert.That(json, Does.Contain("\"target\":\"Checkpoints/Finish\""));
+            Assert.That(json, Does.Contain("\"summary\":\"Runtime schema compatibility checkpoint.\""));
+            Assert.That(json, Does.Contain("\"message\":\"Runtime schema compatibility checkpoint.\""));
+            Assert.That(json, Does.Contain("\"severity\":\"info\""));
+            Assert.That(json, Does.Contain("\"success\":true"));
+            Assert.That(json, Does.Contain("\"metadata\":{"));
+            Assert.That(json, Does.Contain("\"sample\":\"emission-schema-compatibility\""));
+            Assert.That(json, Does.Contain("\"scenePath\":\"Assets/Scenes/Checkpoint.unity\""));
+            Assert.That(json, Does.Contain("\"redactionMetadata\""));
+            Assert.That(json, Does.Contain("\"retentionMetadata\""));
+            Assert.That(json, Does.Contain("\"payload\":{\"kind\":\"runtime-gameplay-event\""));
+            Assert.That(json, Does.Contain("\"eventType\":\"checkpoint_reached\""));
+            Assert.That(json, Does.Contain("\"status\":\"completed\""));
+            Assert.That(json, Does.Contain("\"attributes\":{"));
+            Assert.That(json, Does.Contain("\"checkpointId\":\"finish\""));
+            Assert.That(json, Does.Contain("\"elapsedSeconds\":42.5"));
+            Assert.That(json, Does.Contain("\"scoreValue\":500"));
+            Assert.That(json, Does.Contain("\"isFinal\":true"));
+            Assert.That(json, Does.Contain("\"position\":{\"x\":4.5,\"y\":1,\"z\":-2.25}"));
+        }
+
+        static void AssertCompatiblePayload(
+            LuxRuntimeEventPayload expected,
+            LuxRuntimeEventPayload actual)
+        {
+            Assert.That(expected, Is.Not.Null);
+            Assert.That(actual, Is.Not.Null);
+            Assert.That(actual.kind, Is.EqualTo(expected.kind));
+            Assert.That(actual.eventType, Is.EqualTo(expected.eventType));
+            Assert.That(actual.summary, Is.EqualTo(expected.summary));
+            Assert.That(actual.status, Is.EqualTo(expected.status));
+            Assert.That(actual.target, Is.EqualTo(expected.target));
+            AssertObjectDictionaryMatches(expected.attributes, actual.attributes, "payload.attributes");
+        }
+
+        static void AssertStringDictionaryMatches(
+            IReadOnlyDictionary<string, string> expected,
+            IReadOnlyDictionary<string, string> actual,
+            string path)
+        {
+            Assert.That(expected, Is.Not.Null, path);
+            Assert.That(actual, Is.Not.Null, path);
+            Assert.That(actual.Count, Is.EqualTo(expected.Count), path);
+            foreach (var pair in expected)
+            {
+                Assert.That(actual.ContainsKey(pair.Key), Is.True, path + "." + pair.Key);
+                Assert.That(actual[pair.Key], Is.EqualTo(pair.Value), path + "." + pair.Key);
+            }
+        }
+
+        static void AssertObjectDictionaryMatches(
+            IReadOnlyDictionary<string, object> expected,
+            IReadOnlyDictionary<string, object> actual,
+            string path)
+        {
+            Assert.That(expected, Is.Not.Null, path);
+            Assert.That(actual, Is.Not.Null, path);
+            Assert.That(actual.Count, Is.EqualTo(expected.Count), path);
+            foreach (var pair in expected)
+            {
+                Assert.That(actual.ContainsKey(pair.Key), Is.True, path + "." + pair.Key);
+                AssertObjectValuesMatch(path + "." + pair.Key, pair.Value, actual[pair.Key]);
+            }
+        }
+
+        static void AssertObjectValuesMatch(string path, object expected, object actual)
+        {
+            if (expected is IDictionary expectedDictionary)
+            {
+                var actualDictionary = actual as IDictionary;
+                Assert.That(actualDictionary, Is.Not.Null, path);
+                Assert.That(actualDictionary.Count, Is.EqualTo(expectedDictionary.Count), path);
+                foreach (DictionaryEntry entry in expectedDictionary)
+                {
+                    Assert.That(actualDictionary.Contains(entry.Key), Is.True, path + "." + entry.Key);
+                    AssertObjectValuesMatch(path + "." + entry.Key, entry.Value, actualDictionary[entry.Key]);
+                }
+
+                return;
+            }
+
+            if (!(expected is string) && expected is IEnumerable expectedEnumerable)
+            {
+                var actualEnumerable = actual as IEnumerable;
+                Assert.That(actualEnumerable, Is.Not.Null, path);
+                var expectedValues = ToList(expectedEnumerable);
+                var actualValues = ToList(actualEnumerable);
+                Assert.That(actualValues.Count, Is.EqualTo(expectedValues.Count), path);
+                for (int index = 0; index < expectedValues.Count; index++)
+                {
+                    AssertObjectValuesMatch(path + "[" + index + "]", expectedValues[index], actualValues[index]);
+                }
+
+                return;
+            }
+
+            Assert.That(actual, Is.EqualTo(expected), path);
+        }
+
+        static List<object> ToList(IEnumerable values)
+        {
+            var result = new List<object>();
+            foreach (var value in values)
+            {
+                result.Add(value);
+            }
+
+            return result;
+        }
+    }
+}
