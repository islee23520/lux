+                raw_asset_path.display(),
+                raw_asset_path.display()
+            ),
+        )
+        .unwrap();
+
+        let entries = read_log_entries(&log_path, &AiLogFilter::default()).unwrap();
+        let serialized_entries = serde_json::to_string(&entries).unwrap();
+        let context = build_continuation_context(&entries, None);
+        let serialized_context = serde_json::to_string(&context).unwrap();
+        let redaction_metadata =
+            serde_json::to_string(&entries[0].value["redactionMetadata"]).unwrap();
+        let normalized_project_root = project_root.to_string_lossy().replace('\\', "/");
