+        [Test]
+        public void Broadcaster_RedactsSecretAndProjectPathBeforeQueuedBroadcast()
+        {
+            var broadcasts = new List<Tuple<string, UnityEditor.LuxAiActionLogEntry>>();
+            ConfigureBroadcasterForTest(0.0, (eventType, payload) => broadcasts.Add(Tuple.Create(eventType, (UnityEditor.LuxAiActionLogEntry)payload)));
+            string projectRoot = Path.GetFullPath(UnityEditor.LuxBridgeSettings.GetProjectRoot()).TrimEnd(Path.DirectorySeparatorChar, Path.AltDirectorySeparatorChar);
+            string rawAssetPath = Path.Combine(projectRoot, "Assets", "Scripts", "BroadcastProbe.cs");
+
+            UnityEditor.LuxAiActionLogBroadcaster.Record("remote", "call", rawAssetPath, "Authorization: Bearer broadcast-secret token=broadcast-token " + rawAssetPath);
+            UnityEditor.LuxAiActionLogBroadcaster.PumpForTests();
+            foreach (var configuredLog in _configuredLogs)
+            {
+                configuredLog.Flush();
+            }
+
+            var broadcastParts = new List<string>();
+            foreach (var broadcast in broadcasts)
+            {
+                broadcastParts.Add(broadcast.Item2.target + " " + broadcast.Item2.message);
+            }
+
+            string broadcastText = string.Join(" ", broadcastParts).Replace('\\', '/');
+            string jsonl = File.ReadAllText(GetTempLogPath()).Replace('\\', '/');
+            string normalizedProjectRoot = projectRoot.Replace('\\', '/');
+
+            Assert.That(broadcasts, Has.Count.EqualTo(1));
+            Assert.That(broadcastText + " " + jsonl, Does.Not.Contain("broadcast-secret"));
+            Assert.That(broadcastText + " " + jsonl, Does.Not.Contain("broadcast-token"));
+            Assert.That(broadcastText + " " + jsonl, Does.Not.Contain(normalizedProjectRoot));
+        }
