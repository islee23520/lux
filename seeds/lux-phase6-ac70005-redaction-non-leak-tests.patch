+            "[REDACTED]"
+        );
+        assert!(serialized_entries.contains("[REDACTED]"));
+        assert!(!serialized_entries.contains("raw-secret"));
+        assert!(!serialized_entries.contains("raw-query"));
+        assert!(!serialized_entries.contains("metadata-token"));
+        assert!(!serialized_entries.contains(&normalized_project_root));
+        assert!(!serialized_context.contains("player-secret-42"));
+        assert!(!serialized_context.contains("slot-raw"));
+        assert!(!serialized_context.contains("gold-key"));
+        assert!(!serialized_context.contains("raw-secret"));
+        assert!(!serialized_context.contains("metadata-token"));
+        assert!(!serialized_context.contains(&normalized_project_root));
+        assert!(redaction_metadata.contains("credential"));
+        assert!(redaction_metadata.contains("gameplay-sensitive"));
