+        [Test]
+        public void Record_RedactionRegressionDoesNotLeakSecretPathOrMetadataValues()
+        {
+            string path = GetTempLogPath();
+            using var log = new UnityEditor.LuxAiActionLog(logPath: path);
+            string projectRoot = Path.GetFullPath(UnityEditor.LuxBridgeSettings.GetProjectRoot()).TrimEnd(Path.DirectorySeparatorChar, Path.AltDirectorySeparatorChar);
+            string rawAssetPath = Path.Combine(projectRoot, "Assets", "Scripts", "RedactionProbe.cs");
+
+            var entry = log.Record(
+                "test",
+                "agent",
+                "remote",
+                "call",
+                rawAssetPath,
+                "Authorization: Bearer raw-secret OPENAI_API_KEY=sk-live opened " + rawAssetPath,
+                metadata: new Dictionary<string, string>
+                {
+                    ["apiKey"] = "metadata-secret",
+                    ["note"] = "token=metadata-token",
+                    ["assetPath"] = rawAssetPath,
+                    ["safe"] = "visible"
+                });
+            log.Flush();
+
+            string jsonl = File.ReadAllText(path).Replace('\\', '/');
+            string normalizedProjectRoot = projectRoot.Replace('\\', '/');
+            string metadataSummary = string.Join(" ", entry.redactionMetadata.redactedFields ?? new List<string>())
+                + " "
+                + string.Join(" ", entry.redactionMetadata.redactionClasses ?? new List<string>());
+
+            Assert.That(entry.metadata["safe"], Is.EqualTo("visible"));
+            Assert.That(jsonl, Does.Contain("[REDACTED]"));
+            Assert.That(jsonl, Does.Not.Contain("raw-secret"));
+            Assert.That(jsonl, Does.Not.Contain("sk-live"));
+            Assert.That(jsonl, Does.Not.Contain("metadata-secret"));
+            Assert.That(jsonl, Does.Not.Contain("metadata-token"));
+            Assert.That(jsonl, Does.Not.Contain(normalizedProjectRoot));
+            Assert.That(metadataSummary, Does.Contain("<sensitive-key>"));
+            Assert.That(metadataSummary, Does.Not.Contain("apiKey"));
+            Assert.That(metadataSummary, Does.Not.Contain("metadata-secret"));
+            Assert.That(metadataSummary, Does.Not.Contain("metadata-token"));
+            Assert.That(metadataSummary.Replace('\\', '/'), Does.Not.Contain(normalizedProjectRoot));
+        }
