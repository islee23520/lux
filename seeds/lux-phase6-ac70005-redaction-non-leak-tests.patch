+            format!(
+                "{{\"timestampUtc\":\"2026-05-04T00:00:00Z\",\"actor\":\"gameplay\",\"category\":\"runtime\",\"source\":\"unity-runtime\",\"summary\":\"Authorization: Bearer raw-secret token=raw-query opened {}\",\"target\":\"{}\",\"metadata\":{{\"apiKey\":\"token=metadata-token\",\"assetPath\":\"{}\",\"safe\":\"visible\"}},\"payload\":{{\"kind\":\"runtime-gameplay-event\",\"eventType\":\"quest_step_completed\",\"attributes\":{{\"questId\":\"quest-7\",\"playerId\":\"player-secret-42\",\"saveData\":{{\"slot\":\"slot-raw\"}},\"inventory\":[\"gold-key\"],\"publicResult\":\"completed\"}}}},\"redactionMetadata\":{{\"policyVersion\":\"lux.redaction.v1\",\"applied\":true,\"redactedCount\":4,\"redactedFields\":[\"metadata.<sensitive-key>\",\"payload.attributes.playerId\",\"payload.attributes.saveData\",\"target\"],\"redactionClasses\":[\"credential\",\"gameplay-sensitive\",\"project-path\"],\"locationHints\":[{{\"location\":\"metadata.<sensitive-key>\",\"category\":\"credential\"}}]}}}}\n",
