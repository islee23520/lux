+    #[test]
+    fn runtime_gameplay_payload_roundtrips_state_snapshot_through_serde() {
+        let payload = EventPayloadConvention::new(
+            EventPayloadKind::RuntimeGameplayEvent,
+            "enemy_death",
+            "Gameplay runtime enemy death logged.",
+        )
+        .with_status("completed")
+        .with_attribute("entityId", json!("enemy-7"))
+        .with_attribute("scenePath", json!("Assets/Scenes/Arena.unity"))
+        .with_attribute(
+            "position",
+            json!({
+                "x": 12.5,
+                "y": 0,
+                "z": -3.25
+            }),
+        )
+        .with_attribute("scoreValue", json!(150))
+        .with_attribute("isBoss", json!(false))
+        .with_attribute("tags", json!(["runtime", "combat"]));
+        let value = serde_json::to_value(payload).unwrap();
+
+        assert_eq!(value["kind"], "runtime-gameplay-event");
+        assert_eq!(value["eventType"], "enemy_death");
+        assert_eq!(
+            value["summary"],
+            "Gameplay runtime enemy death logged."
+        );
+        assert_eq!(value["status"], "completed");
+        assert_eq!(value["attributes"]["entityId"], json!("enemy-7"));
+        assert_eq!(
+            value["attributes"]["scenePath"],
+            json!("Assets/Scenes/Arena.unity")
+        );
+        assert_eq!(value["attributes"]["position"]["x"], json!(12.5));
+        assert_eq!(value["attributes"]["position"]["y"], json!(0));
+        assert_eq!(value["attributes"]["position"]["z"], json!(-3.25));
+        assert_eq!(value["attributes"]["scoreValue"], json!(150));
+        assert_eq!(value["attributes"]["isBoss"], json!(false));
+        assert_eq!(value["attributes"]["tags"][1], json!("combat"));
+
+        let roundtrip = EventPayloadConvention::from_json_value(value).unwrap();
+
+        assert_eq!(roundtrip.kind, EventPayloadKind::RuntimeGameplayEvent);
+        assert_eq!(roundtrip.event_type, "enemy_death");
+        assert_eq!(roundtrip.summary, "Gameplay runtime enemy death logged.");
+        assert_eq!(roundtrip.status.as_deref(), Some("completed"));
+        assert_eq!(roundtrip.attributes["entityId"], json!("enemy-7"));
+        assert_eq!(roundtrip.attributes["position"]["z"], json!(-3.25));
+        assert_eq!(roundtrip.attributes["tags"][0], json!("runtime"));
+    }
