+    #[test]
+    fn ai_work_step_malformed_write_and_read_cases_are_isolated() {
+        let project_root = temp_project_root("ai-work-step-malformed-isolation");
+        let path = project_root.join("UserSettings").join("LuxAiActionLog.jsonl");
+        fs::create_dir_all(path.parent().unwrap()).unwrap();
+        let first = test_ai_work_step_record("ai-step-valid-before-corrupt", 1);
+        let second = test_ai_work_step_record("ai-step-valid-after-corrupt", 2);
+        let first_line = serialize_ai_work_step_record(&first).unwrap();
+        let second_line = serialize_ai_work_step_record(&second).unwrap();
+        fs::write(
+            &path,
+            format!(
+                "{first_line}\n{{\"payload\":{{\"kind\":\"ai-work-step\"}}\n{{\"payload\":{{\"kind\":\"editor-action\"}}}}\n\n{second_line}\n"
+            ),
+        )
+        .unwrap();
+        let before_rejected_write = fs::read_to_string(&path).unwrap();
+        let invalid_write = json!({
+            "id": "ai-step-invalid-write",
+            "payload": {
+                "kind": "editor-action"
+            }
+        });
+
+        assert!(append_ai_work_step_record(&path, &invalid_write).is_err());
+        assert_eq!(fs::read_to_string(&path).unwrap(), before_rejected_write);
+
+        append_ai_work_step_record(
+            &path,
+            &test_ai_work_step_record("ai-step-valid-after-rejected-write", 3),
+        )
+        .unwrap();
+
+        let records = parse_ai_work_step_records(Cursor::new(fs::read_to_string(&path).unwrap()));
+        let ids: Vec<_> = records
+            .iter()
+            .map(|record| record.value["id"].as_str().unwrap())
+            .collect();
+        let lines: Vec<_> = records.iter().map(|record| record.line_number).collect();
+
+        assert_eq!(
+            ids,
+            vec![
+                "ai-step-valid-before-corrupt",
+                "ai-step-valid-after-corrupt",
+                "ai-step-valid-after-rejected-write"
+            ]
+        );
+        assert_eq!(lines, vec![1, 5, 6]);
+
+        fs::remove_dir_all(project_root).unwrap();
+    }
