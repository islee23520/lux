+    #[test]
+    fn ai_work_step_concurrent_appends_remain_parseable_under_shared_project_scope() {
+        const WRITER_COUNT: usize = 4;
+        const EVENTS_PER_WRITER: usize = 24;
+        let project_root = temp_project_root("ai-work-step-shared-project-concurrent");
+        let path = Arc::new(ensure_log_path(&project_root).unwrap());
+
+        let handles: Vec<_> = (0..WRITER_COUNT)
+            .map(|writer| {
+                let path = Arc::clone(&path);
+                thread::spawn(move || {
+                    for index in 0..EVENTS_PER_WRITER {
+                        let sequence = (writer * EVENTS_PER_WRITER + index) as u64;
+                        let record = test_ai_work_step_record(
+                            &format!("ai-step-shared-project-{sequence}"),
+                            sequence,
+                        );
+                        append_ai_work_step_record(&*path, &record).unwrap();
+                    }
+                })
+            })
+            .collect();
+
+        for handle in handles {
+            handle.join().unwrap();
+        }
+
+        let contents = fs::read_to_string(&*path).unwrap();
+        let raw_lines: Vec<_> = contents.lines().collect();
+        let records = parse_ai_work_step_records(Cursor::new(contents.as_bytes()));
+        let mut sequences = BTreeSet::new();
+
+        assert_eq!(raw_lines.len(), WRITER_COUNT * EVENTS_PER_WRITER);
+        assert_eq!(records.len(), raw_lines.len());
+        for line in raw_lines {
+            assert!(deserialize_ai_work_step_record(line).is_ok());
+        }
+        for record in records {
+            assert!(sequences.insert(
+                record.value["payload"]["ordering"]["sequence"]
+                    .as_u64()
+                    .unwrap()
+            ));
+        }
+        assert_eq!(sequences.len(), WRITER_COUNT * EVENTS_PER_WRITER);
+        assert_eq!(sequences.first().copied(), Some(0));
+        assert_eq!(
+            sequences.last().copied(),
+            Some((WRITER_COUNT * EVENTS_PER_WRITER - 1) as u64)
+        );
+
+        fs::remove_dir_all(project_root).unwrap();
+    }
 
