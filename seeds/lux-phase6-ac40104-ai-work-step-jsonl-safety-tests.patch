+            .unwrap();
+        }
+
+        let records = parse_ai_work_step_records(Cursor::new(fs::read_to_string(&path).unwrap()));
+        assert_eq!(records.len(), 6);
+        for (index, record) in records.iter().enumerate() {
+            assert_eq!(record.line_number, index + 1);
+            let expected_id = format!("ai-step-ordered-{index}");
+            assert_eq!(record.value["id"].as_str(), Some(expected_id.as_str()));
+            assert_eq!(
+                record.value["payload"]["ordering"]["sequence"],
+                index as u64
+            );
+        }
+
+        fs::remove_dir_all(project_root).unwrap();
+    }
