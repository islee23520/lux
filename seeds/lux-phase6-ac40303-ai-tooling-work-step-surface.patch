@@ -0,0 +1,356 @@
+import fs from 'node:fs/promises';
+import path from 'node:path';
+
+export const LUX_AI_WORK_STEPS_TOOL_NAME = 'lux_ai_work_steps';
+
+const PRIMARY_LOG_RELATIVE_PATH = path.join('.lux', 'ai-action-log.jsonl');
+const LEGACY_LOG_RELATIVE_PATH = path.join('UserSettings', 'LuxAiActionLog.jsonl');
+const LOG_PATH_ENV = 'LUX_AI_ACTION_LOG_PATH';
+const DEFAULT_LIMIT = 100;
+const MAX_LIMIT = 500;
+const REDACTED = '[REDACTED]';
+
+interface AiWorkStepsArguments {
+  limit?: number;
+}
+
+interface AiWorkStepSortKey {
+  timestampUtc: string;
+  sequence: number;
+  lineNumber: number;
+  id: string;
+}
+
+interface AiWorkStepEntry {
+  lineNumber: number;
+  timestampUtc: string;
+  sequence: number;
+  id: string;
+  actor: string;
+  source: string;
+  category: string;
+  type: string;
+  stepName: string;
+  status: string;
+  summary: string;
+  sortKey: AiWorkStepSortKey;
+  value: unknown;
+}
+
+interface AiWorkStepWarning {
+  lineNumber: number;
+  reason: string;
+}
+
+interface ResolvedLogPath {
+  path: string;
+  source: 'environment' | 'project' | 'legacy';
+}
+
+export interface AiWorkStepsReadResult {
+  schemaVersion: 1;
+  protocol: 'lux.ai_work_steps.read.v1';
+  surface: 'mcp';
+  projectPath: string;
+  path: string;
+  pathSource: ResolvedLogPath['source'];
+  limit: number;
+  count: number;
+  warningCount: number;
+  entries: AiWorkStepEntry[];
+  warnings: AiWorkStepWarning[];
+}
+
+export async function readProjectAiWorkSteps(projectRoot: string, argumentsValue: unknown): Promise<AiWorkStepsReadResult> {
+  const args = parseArguments(argumentsValue);
+  const resolvedPath = await resolveLogPath(projectRoot);
+  const { entries, warnings } = await readEntries(resolvedPath.path);
+  const limitedEntries = entries.length > args.limit ? entries.slice(entries.length - args.limit) : entries;
+  const redactedEntries = limitedEntries.map(redactEntry);
+  const redactedWarnings = warnings.map((warning) => ({
+    lineNumber: warning.lineNumber,
+    reason: redactText(warning.reason),
+  }));
+
+  return {
+    schemaVersion: 1,
+    protocol: 'lux.ai_work_steps.read.v1',
+    surface: 'mcp',
+    projectPath: projectRoot,
+    path: resolvedPath.path,
+    pathSource: resolvedPath.source,
+    limit: args.limit,
+    count: redactedEntries.length,
+    warningCount: redactedWarnings.length,
+    entries: redactedEntries,
+    warnings: redactedWarnings,
+  };
+}
+
+function parseArguments(argumentsValue: unknown): Required<AiWorkStepsArguments> {
+  if (argumentsValue === undefined || argumentsValue === null) {
+    return { limit: DEFAULT_LIMIT };
+  }
+
+  if (!isPlainObject(argumentsValue)) {
+    throw new Error('Lux AI work step arguments must be an object.');
+  }
+
+  const limit = argumentsValue.limit;
+  if (limit === undefined) {
+    return { limit: DEFAULT_LIMIT };
+  }
+
+  if (typeof limit !== 'number' || !Number.isInteger(limit) || limit < 1) {
+    throw new Error('limit must be a positive integer.');
+  }
+
+  return { limit: Math.min(limit, MAX_LIMIT) };
+}
+
+async function resolveLogPath(projectRoot: string): Promise<ResolvedLogPath> {
+  const override = process.env[LOG_PATH_ENV];
+  if (override && override.trim().length > 0) {
+    return {
+      path: path.isAbsolute(override) ? override : path.join(projectRoot, override),
+      source: 'environment',
+    };
+  }
+
+  const primaryPath = path.join(projectRoot, PRIMARY_LOG_RELATIVE_PATH);
+  if (await fileExists(primaryPath)) {
+    return { path: primaryPath, source: 'project' };
+  }
+
+  const legacyPath = path.join(projectRoot, LEGACY_LOG_RELATIVE_PATH);
+  if (await fileExists(legacyPath)) {
+    return { path: legacyPath, source: 'legacy' };
+  }
+
+  return { path: primaryPath, source: 'project' };
+}
+
+async function fileExists(candidate: string): Promise<boolean> {
+  try {
+    const stat = await fs.stat(candidate);
+    return stat.isFile();
+  } catch (error) {
+    if (isNodeError(error) && error.code === 'ENOENT') {
+      return false;
+    }
+
+    throw error;
+  }
+}
+
+async function readEntries(logPath: string): Promise<{ entries: AiWorkStepEntry[]; warnings: AiWorkStepWarning[] }> {
+  let rawLog: string;
+  try {
+    rawLog = await fs.readFile(logPath, 'utf8');
+  } catch (error) {
+    if (isNodeError(error) && error.code === 'ENOENT') {
+      return { entries: [], warnings: [] };
+    }
+
+    throw error;
+  }
+
+  const entries: AiWorkStepEntry[] = [];
+  const warnings: AiWorkStepWarning[] = [];
+
+  rawLog.split(/\r?\n/).forEach((line, index) => {
+    const lineNumber = index + 1;
+    const trimmed = line.trim();
+    if (trimmed.length === 0) {
+      return;
+    }
+
+    let parsed: unknown;
+    try {
+      parsed = JSON.parse(trimmed);
+    } catch (error) {
+      warnings.push({
+        lineNumber,
+        reason: `line is not valid JSON: ${error instanceof Error ? error.message : String(error)}`,
+      });
+      return;
+    }
+
+    const entry = toWorkStepEntry(parsed, lineNumber);
+    if (entry) {
+      entries.push(entry);
+      return;
+    }
+
+    warnings.push({
+      lineNumber,
+      reason: 'line is not an AI work step record',
+    });
+  });
+
+  entries.sort(compareEntries);
+  return { entries, warnings };
+}
+
+function toWorkStepEntry(value: unknown, lineNumber: number): AiWorkStepEntry | undefined {
+  if (!isPlainObject(value) || !isAiWorkStepRecord(value)) {
+    return undefined;
+  }
+
+  const payload = isPlainObject(value.payload) ? value.payload : {};
+  const timestampUtc = stringValue(value.timestampUtc) ?? stringValue(value.captured_at_utc);
+  const id = stringValue(value.id) ?? stringValue(value.eventId) ?? `line-${lineNumber}`;
+  const stepName = stringValue(payload.stepName)
+    ?? stringValue(value.stepName)
+    ?? stringValue(value.action)
+    ?? stringValue(value.type)
+    ?? stringValue(value.eventType);
+
+  if (!timestampUtc || !stepName) {
+    return undefined;
+  }
+
+  const sequence = numberValue(isPlainObject(payload.ordering) ? payload.ordering.sequence : undefined)
+    ?? numberValue(value.sequence)
+    ?? lineNumber;
+  const status = stringValue(payload.status) ?? stringValue(value.status) ?? statusFromSuccess(value.success);
+  const summary = stringValue(payload.summary)
+    ?? stringValue(value.summary)
+    ?? stringValue(value.message)
+    ?? stringValue(value.description)
+    ?? '';
+  const source = stringValue(value.source) ?? '';
+  const actor = stringValue(value.actor) ?? '';
+  const category = stringValue(value.category) ?? '';
+  const type = stringValue(value.type) ?? stringValue(value.eventType) ?? stringValue(value.action) ?? stepName;
+  const sortKey = { timestampUtc, sequence, lineNumber, id };
+
+  return {
+    lineNumber,
+    timestampUtc,
+    sequence,
+    id,
+    actor,
+    source,
+    category,
+    type,
+    stepName,
+    status,
+    summary,
+    sortKey,
+    value,
+  };
+}
+
+function isAiWorkStepRecord(value: Record<string, unknown>): boolean {
+  const payload = isPlainObject(value.payload) ? value.payload : undefined;
+  if (payload?.kind === 'ai-work-step') {
+    return true;
+  }
+
+  const category = stringValue(value.category)?.toLowerCase() ?? '';
+  const source = stringValue(value.source)?.toLowerCase() ?? '';
+  const actor = stringValue(value.actor)?.toLowerCase() ?? '';
+
+  return category === 'ai-action-log'
+    || category === 'ai-tool'
+    || source.includes('ai-tool')
+    || source === 'codex'
+    || source === 'opencode'
+    || actor === 'codex'
+    || actor === 'opencode';
+}
+
+function compareEntries(left: AiWorkStepEntry, right: AiWorkStepEntry): number {
+  return compareString(left.sortKey.timestampUtc, right.sortKey.timestampUtc)
+    || left.sortKey.sequence - right.sortKey.sequence
+    || left.sortKey.lineNumber - right.sortKey.lineNumber
+    || compareString(left.sortKey.id, right.sortKey.id);
+}
+
+function redactEntry(entry: AiWorkStepEntry): AiWorkStepEntry {
+  return {
+    ...entry,
+    timestampUtc: redactText(entry.timestampUtc),
+    id: redactText(entry.id),
+    actor: redactText(entry.actor),
+    source: redactText(entry.source),
+    category: redactText(entry.category),
+    type: redactText(entry.type),
+    stepName: redactText(entry.stepName),
+    status: redactText(entry.status),
+    summary: redactText(entry.summary),
+    sortKey: {
+      ...entry.sortKey,
+      timestampUtc: redactText(entry.sortKey.timestampUtc),
+      id: redactText(entry.sortKey.id),
+    },
+    value: redactJsonValue(entry.value),
+  };
+}
+
+function redactJsonValue(value: unknown, key = ''): unknown {
+  if (typeof value === 'string') {
+    return isSensitiveKey(key) ? REDACTED : redactText(value);
+  }
+
+  if (Array.isArray(value)) {
+    return value.map((item) => redactJsonValue(item));
+  }
+
+  if (isPlainObject(value)) {
+    return Object.fromEntries(
+      Object.entries(value).map(([entryKey, entryValue]) => [
+        entryKey,
+        isSensitiveKey(entryKey) ? REDACTED : redactJsonValue(entryValue, entryKey),
+      ]),
+    );
+  }
+
+  return value;
+}
+
+function redactText(text: string): string {
+  return text
+    .replace(/-----BEGIN [A-Z ]*PRIVATE KEY-----[\s\S]*?-----END [A-Z ]*PRIVATE KEY-----/g, REDACTED)
+    .replace(/(authorization\s*[:=]\s*)(bearer\s+)?[^\s,;"'}]+/gi, `$1${REDACTED}`)
+    .replace(/\bbearer\s+[^\s,;"'}]+/gi, REDACTED)
+    .replace(/\btoken=[^\s,;"'}]+/gi, `token=${REDACTED}`)
+    .replace(/\b(secret-token|api[_-]?key=[^\s,;"'}]+|password=[^\s,;"'}]+)/gi, REDACTED);
+}
+
+function isSensitiveKey(key: string): boolean {
+  return /authorization|credential|password|secret|token|api[_-]?key/i.test(key);
+}
+
+function statusFromSuccess(value: unknown): string {
+  if (value === true) {
+    return 'completed';
+  }
+
+  if (value === false) {
+    return 'failed';
+  }
+
+  return 'unknown';
+}
+
+function compareString(left: string, right: string): number {
+  return left < right ? -1 : left > right ? 1 : 0;
+}
+
+function stringValue(value: unknown): string | undefined {
+  return typeof value === 'string' ? value : undefined;
+}
+
+function numberValue(value: unknown): number | undefined {
+  return typeof value === 'number' && Number.isFinite(value) ? value : undefined;
+}
+
+function isPlainObject(value: unknown): value is Record<string, unknown> {
+  return typeof value === 'object' && value !== null && !Array.isArray(value);
+}
+
+function isNodeError(error: unknown): error is NodeJS.ErrnoException {
+  return error instanceof Error && 'code' in error;
+}
