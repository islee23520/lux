+test('tools/call reads ordered AI work steps from project log without Unity TCP discovery', async () => {
+  await withTempProject(async (projectRoot) => {
+    const logDirectory = path.join(projectRoot, '.lux');
+    fs.mkdirSync(logDirectory, { recursive: true });
+    fs.writeFileSync(
+      path.join(logDirectory, 'ai-action-log.jsonl'),
+      [
+        JSON.stringify({
+          timestampUtc: '2026-05-04T00:00:03Z',
+          id: 'ai-step-third',
+          source: 'codex',
+          actor: 'codex',
+          category: 'ai-action-log',
+          type: 'tool.test.completed',
+          summary: 'third token=raw-secret',
+          payload: {
+            kind: 'ai-work-step',
+            eventType: 'tool.test.completed',
+            stepName: 'test',
+            status: 'completed',
+            summary: 'third token=raw-secret',
+            ordering: { sequence: 3 },
+            credentials: { token: 'raw-secret' },
+          },
+        }),
+        'not-json',
+        JSON.stringify({
+          timestampUtc: '2026-05-04T00:00:01Z',
+          id: 'ai-step-first',
+          source: 'codex',
+          actor: 'codex',
+          category: 'ai-action-log',
+          type: 'tool.read.completed',
+          payload: { kind: 'ai-work-step', stepName: 'read', status: 'completed', summary: 'first', ordering: { sequence: 1 } },
+        }),
+        JSON.stringify({
+          timestampUtc: '2026-05-04T00:00:02Z',
+          id: 'ai-step-second',
+          source: 'codex',
+          actor: 'codex',
+          category: 'ai-action-log',
+          type: 'tool.patch.completed',
+          payload: { kind: 'ai-work-step', stepName: 'apply_patch', status: 'completed', summary: 'second', ordering: { sequence: 2 } },
+        }),
+        JSON.stringify({
+          timestampUtc: '2026-05-04T00:00:04Z',
+          id: 'editor-only',
+          source: 'unity-editor',
+          actor: 'user',
+          category: 'editor',
+          action: 'selection.changed',
+          message: 'editor-only',
+        }),
+      ].join('\n'),
+      'utf8',
+    );
+    const pair = await connectMcpServer(projectRoot);
+
+    try {
+      const result = await pair.client.callTool({ name: LUX_AI_WORK_STEPS_TOOL_NAME, arguments: { limit: 2 } });
+      const content = (result as { content: Array<{ type: string; text?: string }> }).content;
+      const parsed = JSON.parse(content[0]?.text ?? '{}');
+      const serialized = content[0]?.text ?? '';
+
+      assert.equal(parsed.protocol, 'lux.ai_work_steps.read.v1');
+      assert.equal(parsed.surface, 'mcp');
+      assert.equal(parsed.projectPath, projectRoot);
+      assert.equal(parsed.pathSource, 'project');
+      assert.equal(parsed.limit, 2);
+      assert.equal(parsed.count, 2);
+      assert.equal(parsed.warningCount, 2);
+      assert.deepEqual(parsed.entries.map((entry: { id: string }) => entry.id), ['ai-step-second', 'ai-step-third']);
+      assert.equal(parsed.entries[0].stepName, 'apply_patch');
+      assert.equal(parsed.entries[1].summary, 'third token=[REDACTED]');
+      assert.equal(parsed.entries[1].value.payload.credentials, '[REDACTED]');
+      assert.equal(parsed.warnings[0].lineNumber, 2);
+      assert.equal(parsed.warnings[1].lineNumber, 5);
+      assert.ok(!serialized.includes('raw-secret'));
+      assert.ok(!serialized.includes('editor-only'));
+    } finally {
+      await pair.close();
+    }
+  });
+});
