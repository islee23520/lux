+    if line.contains('\n') {
+        anyhow::bail!("AI work step JSONL record encoded with an embedded newline");
+    }
+
+    Ok(line)
+}
+
+fn parse_ai_work_step_record_bytes(line: &[u8]) -> Result<Option<Value>> {
+    let line = std::str::from_utf8(line).context("AI work step JSONL line is not valid UTF-8")?;
+    if line.trim().is_empty() {
+        return Ok(None);
+    }
+
+    deserialize_ai_work_step_record(line).map(Some)
 }
 
