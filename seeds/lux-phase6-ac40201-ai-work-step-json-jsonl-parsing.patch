+pub fn parse_ai_work_step_records(reader: impl BufRead) -> Vec<AiLogEntry> {
+    parse_ai_work_step_records_with_warnings(reader).entries
+}
+
+pub fn parse_ai_work_step_records_with_warnings(reader: impl BufRead) -> AiWorkStepParseResult {
+    let mut entries = Vec::new();
+    let mut warnings = Vec::new();
+
+    for (index, line) in reader.split(b'\n').enumerate() {
+        let line_number = index + 1;
+        let line = match line {
+            Ok(line) => line,
+            Err(error) => {
+                warnings.push(AiWorkStepParseWarning {
+                    line_number,
+                    reason: format!("failed to read line: {error}"),
+                });
+                continue;
+            }
+        };
+
+        match parse_ai_work_step_record_bytes(&line) {
+            Ok(Some(value)) => entries.push(AiLogEntry {
+                line_number,
+                timestamp: timestamp(&value).unwrap_or_default(),
+                value,
+            }),
+            Ok(None) => {}
+            Err(error) => warnings.push(AiWorkStepParseWarning {
+                line_number,
+                reason: error.to_string(),
+            }),
+        }
+    }
+
+    AiWorkStepParseResult { entries, warnings }
+}
+
+pub fn serialize_ai_work_step_record(record: &Value) -> Result<String> {
+    validate_ai_work_step_record(record)?;
+    let line =
