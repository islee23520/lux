+fn validate_ai_work_step_record(value: &Value) -> Result<()> {
+    let object = value
+        .as_object()
+        .context("AI work step JSONL record must be a JSON object")?;
+    required_string(object.get("id"), "id")?;
+    required_string(object.get("actor"), "actor")?;
+    required_string(object.get("source"), "source")?;
+    required_string(object.get("category"), "category")?;
+    required_string(
+        object
+            .get("timestampUtc")
+            .or_else(|| object.get("captured_at_utc")),
+        "timestampUtc",
+    )?;
+    required_string(
+        object
+            .get("type")
+            .or_else(|| object.get("eventType"))
+            .or_else(|| object.get("event_type")),
+        "type",
+    )?;
+    required_string(object.get("summary"), "summary")?;
+
+    let payload = object
+        .get("payload")
+        .and_then(Value::as_object)
+        .context("AI work step JSONL record must include an object payload")?;
+    let kind = required_string(payload.get("kind"), "payload.kind")?;
+    if kind != AI_WORK_STEP_RECORD_KIND {
+        anyhow::bail!("AI work step JSONL record payload.kind must be {AI_WORK_STEP_RECORD_KIND}");
+    }
+
+    required_string(payload.get("stepName"), "payload.stepName")?;
+    required_string(payload.get("status"), "payload.status")?;
+    required_string(payload.get("summary"), "payload.summary")?;
+    required_string(
+        payload
+            .get("eventType")
+            .or_else(|| payload.get("event_type")),
+        "payload.eventType",
+    )?;
+    let ordering = payload
+        .get("ordering")
+        .and_then(Value::as_object)
+        .context("AI work step JSONL record must include payload.ordering")?;
+    let sequence = ordering
+        .get("sequence")
+        .context("AI work step JSONL record must include payload.ordering.sequence")?;
+    let valid_sequence = sequence
+        .as_u64()
+        .is_some()
+        || sequence
+            .as_i64()
+            .map(|sequence| sequence >= 0)
+            .unwrap_or(false);
+    if !valid_sequence {
+        anyhow::bail!("AI work step JSONL record payload.ordering.sequence must be a non-negative integer");
+    }
+
+    Ok(())
+}
+
+fn required_string<'a>(value: Option<&'a Value>, field: &str) -> Result<&'a str> {
+    let text = value
+        .and_then(Value::as_str)
+        .with_context(|| format!("AI work step JSONL record must include string {field}"))?;
+    if text.trim().is_empty() {
+        anyhow::bail!("AI work step JSONL record field {field} must not be empty");
+    }
+
+    Ok(text)
+}
