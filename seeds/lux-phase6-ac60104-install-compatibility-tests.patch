+fn assert_compatibility_check_ok(compatibility: &Value, name: &str) {
+    let check = compatibility["checks"]
+        .as_array()
+        .expect("compatibility checks array")
+        .iter()
+        .find(|check| check["name"] == name)
+        .unwrap_or_else(|| panic!("missing compatibility check {name}"));
+    assert_eq!(check["ok"], true, "compatibility check {name} should pass");
+}
+
+fn assert_compatibility_failed_checks(failure: &Value, expected: &[&str]) {
+    let failed_checks = failure["failed_checks"]
+        .as_array()
+        .expect("failed checks array")
+        .iter()
+        .filter_map(Value::as_str)
+        .collect::<Vec<_>>();
+    for expected_check in expected {
+        assert!(
+            failed_checks.contains(expected_check),
+            "expected failed compatibility check {expected_check}; got {failed_checks:?}"
+        );
+    }
+    assert_eq!(
+        failed_checks.len(),
+        expected.len(),
+        "failure message should name only failed checks"
+    );
+}
