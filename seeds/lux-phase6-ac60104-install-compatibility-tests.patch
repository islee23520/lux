+#[test]
+fn skill_install_adapt_compatible_compatibility_metadata_installs() {
+    let home = create_temp_dir("lux-skill-adapt-compatible-home");
+    let project = create_test_unity_project("lux-skill-adapt-compatible-project", true);
+    let source = create_test_skill_source_with_compatibility(
+        "smoke-adapt-compatible-skill",
+        Some(
+            r#"{
+    "requiresLuxPackage": true,
+    "requiredPackages": ["com.linalab.lux"],
+    "renderPipelines": ["urp"],
+    "platformTargets": ["android", "standalone"],
+    "unityVersion": { "min": "6000.0", "max": "6000.99" },
+    "requiredFeatures": ["package_dependency"]
+  }"#,
+        ),
+    );
+
+    let output = Command::new(env!("CARGO_BIN_EXE_lux"))
+        .args([
+            "skill",
+            "install",
+            "smoke-adapt-compatible-skill",
+            "--source",
+            source.to_str().expect("source path UTF-8"),
+            "--project",
+            "--adapt",
+            "--json",
+        ])
+        .current_dir(&project)
+        .env("HOME", &home)
+        .output()
+        .expect("run compatible lux skill install --adapt");
+
+    assert_command_success(&output, "compatible lux skill install --adapt");
+    assert!(
+        output.stderr.is_empty(),
+        "compatible install should not emit stderr: {}",
+        String::from_utf8_lossy(&output.stderr)
+    );
+    let parsed: Value = serde_json::from_slice(&output.stdout).expect("install JSON");
+    assert_eq!(parsed["installed"], true);
+    assert_eq!(parsed["adapted"], true);
+    assert!(parsed.get("failure").is_none());
+    let compatibility = &parsed["adaptation_metadata"]["compatibility"];
+    assert_eq!(compatibility["schema"], "lux.skill.compatibility.v1");
+    assert_eq!(compatibility["status"], "compatible");
+    assert_compatibility_check_ok(compatibility, "requires_lux_package");
+    assert_compatibility_check_ok(compatibility, "required_packages");
+    assert_compatibility_check_ok(compatibility, "render_pipeline");
+    assert_compatibility_check_ok(compatibility, "platform_targets");
+    assert_compatibility_check_ok(compatibility, "unity_version_min");
+    assert_compatibility_check_ok(compatibility, "unity_version_max");
+    assert_compatibility_check_ok(compatibility, "required_features");
+
+    let installed_dir = project.join(".lux/skills/smoke-adapt-compatible-skill");
+    assert!(
+        installed_dir.join("manifest.json").is_file(),
+        "compatible adapted skill manifest should be installed"
+    );
+    let stored_adaptation: Value = serde_json::from_str(
+        &fs::read_to_string(installed_dir.join("lux-adaptation.json"))
+            .expect("read installed compatibility adaptation metadata"),
+    )
+    .expect("installed compatibility adaptation JSON");
+    assert_eq!(
+        stored_adaptation["compatibility"]["status"],
+        "compatible"
+    );
+    assert_eq!(
+        stored_adaptation["compatibility"]["declared"]["renderPipelines"][0],
+        "urp"
+    );
+}
