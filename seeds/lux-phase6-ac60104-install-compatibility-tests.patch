+#[test]
+fn skill_install_adapt_incompatible_json_names_all_failed_checks() {
+    let home = create_temp_dir("lux-skill-adapt-json-multi-incompatible-home");
+    let project = create_test_unity_project("lux-skill-adapt-json-multi-incompatible-project", true);
+    let source = create_test_skill_source_with_compatibility(
+        "smoke-adapt-multi-incompatible-skill",
+        Some(
+            r#"{
+    "requiresLuxPackage": true,
+    "requiredPackages": ["com.linalab.lux", "com.example.missing"],
+    "renderPipelines": ["hdrp"],
+    "platformTargets": ["visionos"],
+    "unityVersion": { "min": "7000.0" },
+    "requiredFeatures": ["package_dependency", "unity_ai_bridge_discovery"]
+  }"#,
+        ),
+    );
+
+    let output = Command::new(env!("CARGO_BIN_EXE_lux"))
+        .args([
+            "skill",
+            "install",
+            "smoke-adapt-multi-incompatible-skill",
+            "--source",
+            source.to_str().expect("source path UTF-8"),
+            "--project",
+            "--adapt",
+            "--json",
+        ])
+        .current_dir(&project)
+        .env("HOME", &home)
+        .output()
+        .expect("run multi-check incompatible lux skill install --adapt");
+
+    assert!(!output.status.success());
+    assert_eq!(output.status.code(), Some(1));
+    assert!(
+        output.stderr.is_empty(),
+        "JSON failure contract should be written to stdout only: {}",
+        String::from_utf8_lossy(&output.stderr)
+    );
+    let parsed: Value = serde_json::from_slice(&output.stdout).expect("error JSON");
+    assert_eq!(parsed["installed"], false);
+    assert_eq!(parsed["error_code"], "adapted_skill_incompatible");
+    let error = parsed["error"].as_str().expect("error string");
+    assert!(error.contains("required_packages"));
+    assert!(error.contains("render_pipeline"));
+    assert!(error.contains("platform_targets"));
+    assert!(error.contains("unity_version_min"));
+    assert!(error.contains("required_features"));
+    assert_eq!(parsed["failure"]["schema"], "lux.skill.install_failure.v1");
+    assert_eq!(parsed["failure"]["compatibility_status"], "incompatible");
+    assert_eq!(parsed["failure"]["skill_name"], "smoke-adapt-multi-incompatible-skill");
+    assert!(parsed["failure"]["recovery"]
+        .as_str()
+        .expect("recovery text")
+        .contains("lux skill install --project --adapt"));
+    assert_compatibility_failed_checks(
+        &parsed["failure"],
+        &[
+            "required_packages",
+            "render_pipeline",
+            "platform_targets",
+            "unity_version_min",
+            "required_features",
+        ],
+    );
+    assert!(
+        !project
+            .join(".lux/skills/smoke-adapt-multi-incompatible-skill")
+            .exists(),
+        "incompatible adapted skill must not be installed"
+    );
+}
