     let adaptation_path = installed_dir.join("lux-adaptation.json");
     assert!(adaptation_path.is_file());
 
+    let stored_adaptation: Value = serde_json::from_str(
+        &fs::read_to_string(&adaptation_path).expect("read installed adaptation metadata"),
+    )
+    .expect("installed adaptation metadata JSON");
+    assert_eq!(
+        stored_adaptation["adaptation_decisions"]["schema"],
+        "lux.skill.adaptation.decisions.v1"
+    );
+    assert_eq!(
+        stored_adaptation["adaptation_decisions"]["artifact"],
+        "lux-adaptation.json"
+    );
+    let decisions = stored_adaptation["adaptation_decisions"]["decisions"]
+        .as_array()
+        .expect("adaptation decisions array");
+    assert!(decisions.iter().any(|decision| {
+        decision["id"] == "adaptation_artifact"
+            && decision["decision"] == "persist_adaptation_metadata"
+            && decision["status"] == "accepted"
+    }));
+    assert_eq!(
+        install_json["adaptation_metadata"]["adaptation_decisions"],
+        stored_adaptation["adaptation_decisions"]
+    );
+
     let info = Command::new(env!("CARGO_BIN_EXE_lux"))
         .args(["skill", "info", "smoke-adapt-skill", "--json"])
