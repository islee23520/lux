+fn retention_metadata(value: &Value) -> Option<Value> {
+    let metadata = value
+        .get("retentionMetadata")
+        .or_else(|| value.get("retention_metadata"))?;
+    Some(json!({
+        "policyVersion": redacted_string_field(metadata, "policyVersion")
+            .or_else(|| redacted_string_field(metadata, "policy_version"))
+            .unwrap_or_else(|| "unknown".to_string()),
+        "policyName": redacted_string_field(metadata, "policyName")
+            .or_else(|| redacted_string_field(metadata, "policy_name"))
+            .unwrap_or_else(|| "unknown".to_string()),
+        "lifecycleState": redacted_string_field(metadata, "lifecycleState")
+            .or_else(|| redacted_string_field(metadata, "lifecycle_state"))
+            .unwrap_or_else(|| "active".to_string()),
+        "retentionDays": metadata
+            .get("retentionDays")
+            .or_else(|| metadata.get("retention_days"))
+            .and_then(Value::as_u64)
+            .unwrap_or(0),
+        "maxEntries": metadata
+            .get("maxEntries")
+            .or_else(|| metadata.get("max_entries"))
+            .and_then(Value::as_u64)
+            .unwrap_or(0),
+        "expiresAtUtc": redacted_string_field(metadata, "expiresAtUtc")
+            .or_else(|| redacted_string_field(metadata, "expires_at_utc"))
+            .unwrap_or_default(),
+        "cleanupEligible": metadata
+            .get("cleanupEligible")
+            .or_else(|| metadata.get("cleanup_eligible"))
+            .and_then(Value::as_bool)
+            .unwrap_or(false),
+        "cleanupReason": redacted_string_field(metadata, "cleanupReason")
+            .or_else(|| redacted_string_field(metadata, "cleanup_reason"))
+            .unwrap_or_default(),
+    }))
+}
+
+fn redacted_string_field(value: &Value, field: &str) -> Option<String> {
+    value.get(field)?.as_str().map(redact_secrets)
