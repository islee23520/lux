+        assert_eq!(entries[0]["id"], "evt-1");
+        assert_eq!(entries[0]["actor"], "codex");
+        assert_eq!(entries[0]["category"], "ai-action-log");
+        assert_eq!(entries[0]["source"], "gateway");
+        assert_eq!(entries[0]["action"], "edit");
+        assert_eq!(entries[0]["type"], "append");
+        assert_eq!(entries[0]["eventType"], "append");
+        assert_eq!(entries[0]["summary"], "first matching edit");
+        assert_eq!(entries[1]["lineNumber"], 4);
