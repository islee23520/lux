+    #[tokio::test]
+    async fn ai_log_read_endpoint_filters_only_configured_project_events() {
+        let requested_project = temp_project_root("read-contract-requested");
+        let other_project = temp_project_root("read-contract-other");
+        write_ai_log(
+            &requested_project,
+            "{\"timestampUtc\":\"2026-05-04T00:00:01Z\",\"id\":\"requested-event\",\"actor\":\"codex\",\"category\":\"ai-action-log\",\"source\":\"gateway\",\"action\":\"edit\",\"eventType\":\"append\",\"summary\":\"requested project edit\"}\n",
+        );
+        write_ai_log(
+            &other_project,
+            "{\"timestampUtc\":\"2026-05-04T00:00:01Z\",\"id\":\"other-event\",\"actor\":\"codex\",\"category\":\"ai-action-log\",\"source\":\"gateway\",\"action\":\"edit\",\"eventType\":\"append\",\"summary\":\"other project edit\"}\n",
+        );
+        let app = test_app_with_project(requested_project.clone());
+
+        let response = authenticated_get(app, "/api/ai-log/read?limit=10&actor=codex&category=ai-action-log&source=gateway&action=edit&event_type=append").await;
+        assert_eq!(response.status(), StatusCode::OK);
+        let json = response_json(response).await;
+        assert_eq!(json["projectPath"], requested_project.display().to_string());
+        assert_eq!(
+            json["path"],
+            ai_log::resolve_log_path(&requested_project).display().to_string()
+        );
+        assert_eq!(json["count"], 1);
+        assert_eq!(json["entries"][0]["id"], "requested-event");
+        assert_eq!(json["entries"][0]["summary"], "requested project edit");
+        let serialized = serde_json::to_string(&json).unwrap();
+        assert!(!serialized.contains("other-event"));
+        assert!(!serialized.contains("other project edit"));
+        assert!(ai_log::resolve_log_path(&other_project).is_file());
+
+        let _ = fs::remove_dir_all(requested_project);
+        let _ = fs::remove_dir_all(other_project);
+    }
 
