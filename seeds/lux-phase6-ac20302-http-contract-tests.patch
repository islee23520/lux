+                "\n",
+                "not-json\n",
+                r#"{"timestampUtc":"2026-05-04T00:00:02Z","id":"evt-2","actor":"codex","category":"ai-action-log","source":"gateway","action":"edit","eventType":"append","target":"Assets/Scene.unity","status":"completed","tool":"codex","message":"second matching edit","redactionMetadata":{"applied":true},"retentionMetadata":{"policy":"keep-last-500"}}"#,
+                "\n",
+                r#"{"timestampUtc":"2026-05-04T00:00:03Z","id":"ignored-2","actor":"opencode","category":"review","source":"gateway","action":"qa","eventType":"complete","summary":"nonmatching review"}"#,
