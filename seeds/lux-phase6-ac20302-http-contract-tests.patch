+        )
+        .await;
+        assert_eq!(response.status(), StatusCode::OK);
+        let content_type = response
+            .headers()
+            .get(header::CONTENT_TYPE)
+            .and_then(|value| value.to_str().ok())
+            .expect("JSON content type");
+        assert!(
+            content_type.starts_with("application/json"),
+            "unexpected content type {content_type}"
+        );
+        let json = response_json(response).await;
+
+        assert_eq!(json["schemaVersion"], 1);
+        assert_eq!(json["protocol"], "lux.ai_log.read.v1");
+        assert_eq!(json["projectPath"], project_root.display().to_string());
+        assert_eq!(
+            json["path"],
+            ai_log::resolve_log_path(&project_root).display().to_string()
+        );
+        assert_eq!(json["limit"], 2);
+        assert_eq!(json["filters"]["actor"], "codex");
+        assert_eq!(json["filters"]["category"], "ai-action-log");
+        assert_eq!(json["filters"]["source"], "gateway");
+        assert_eq!(json["filters"]["action"], "edit");
