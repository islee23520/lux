+            for (int index = 1; index < lines.Length; index++)
+            {
+                Assert.That(lines[index], Does.StartWith("{"));
+                Assert.That(lines[index], Does.EndWith("}"));
+                Assert.That(lines[index], Does.Contain("\"protocol\":\"lux.ai.action_log.v1\""));
+                int actionStart = lines[index].IndexOf("\"action\":\"", StringComparison.Ordinal);
+                Assert.That(actionStart, Is.GreaterThanOrEqualTo(0));
+                actionStart += "\"action\":\"".Length;
+                int actionEnd = lines[index].IndexOf("\"", actionStart, StringComparison.Ordinal);
+                Assert.That(actionEnd, Is.GreaterThan(actionStart));
+                actions.Add(lines[index].Substring(actionStart, actionEnd - actionStart));
+            }
+
+            Assert.That(actions, Has.Count.EqualTo(EventCount));
+            for (int index = 0; index < EventCount; index++)
+            {
+                Assert.That(actions.Contains("append-" + index), Is.True);
+            }
         }
 
