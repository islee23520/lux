+fn append_lock_for(path: &Path) -> Arc<Mutex<()>> {
+    let locks = APPEND_LOCKS.get_or_init(|| Mutex::new(HashMap::new()));
+    let mut locks = locks
+        .lock()
+        .unwrap_or_else(|poisoned| poisoned.into_inner());
+    locks
+        .entry(path.to_path_buf())
+        .or_insert_with(|| Arc::new(Mutex::new(())))
+        .clone()
+}
+
 pub fn parse_jsonl_values(reader: impl BufRead) -> Vec<Value> {
     reader
         .lines()
         .map_while(Result::ok)
         .filter_map(|line| parse_jsonl_line(&line))
         .collect()
+}
+
+pub fn serialize_event_record(event: &EventEnvelope) -> Result<String> {
+    let value = serde_json::to_value(event.clone().normalize())
+        .context("failed to serialize AI log event record")?;
+    if !value.is_object() {
+        anyhow::bail!("AI log event records must serialize as JSON objects");
+    }
+
+    serde_json::to_string(&value).context("failed to encode AI log event record")
+}
+
+pub fn append_event_record(path: impl AsRef<Path>, event: &EventEnvelope) -> Result<()> {
+    let path = path.as_ref();
+    if let Some(parent) = path.parent() {
+        fs::create_dir_all(parent)
+            .with_context(|| format!("failed to create AI log directory {}", parent.display()))?;
+    }
+
+    let line = serialize_event_record(event)? + "\n";
+    let append_lock = append_lock_for(path);
+    let _guard = append_lock
+        .lock()
+        .unwrap_or_else(|poisoned| poisoned.into_inner());
+    let mut file = OpenOptions::new()
+        .create(true)
+        .append(true)
+        .open(path)
+        .with_context(|| format!("failed to open AI log {}", path.display()))?;
+    file.write_all(line.as_bytes())
+        .with_context(|| format!("failed to append AI log {}", path.display()))?;
+    file.sync_data()
+        .with_context(|| format!("failed to sync AI log {}", path.display()))
 }
 
