+pub(crate) fn skill_info_for_project(
+    name: &str,
+    project_root: Option<&Path>,
+    project_only: bool,
+) -> anyhow::Result<Option<SkillInfoOutput>> {
+    let entries = discover_skills_for_project(project_root)?;
+    let entry = if project_only {
+        entries
+            .iter()
+            .find(|entry| entry.manifest.name == name && entry.scope == "project")
+    } else {
+        entries
+            .iter()
+            .find(|entry| entry.manifest.name == name && entry.scope == "project")
+            .or_else(|| {
+                entries
+                    .iter()
+                    .find(|entry| entry.manifest.name == name && entry.scope == "global")
+            })
+            .or_else(|| entries.iter().find(|entry| entry.manifest.name == name))
+    };
+    let Some(entry) = entry else {
+        return Ok(None);
+    };
+
+    let adaptation_metadata = read_skill_adaptation_metadata(&entry.directory_path);
+    let adapted = adaptation_metadata.is_some();
+    let adaptation_status = skill_adaptation_status(adaptation_metadata.as_ref()).to_string();
+    let compatibility_status = skill_compatibility_status(adaptation_metadata.as_ref());
+    let project_metadata = adaptation_metadata
+        .as_ref()
+        .and_then(|metadata| metadata.get("project_metadata").cloned());
+
+    Ok(Some(SkillInfoOutput {
+        manifest: entry.manifest.clone(),
+        directory_path: entry.directory_path.clone(),
+        scope: entry.scope.clone(),
+        adapted,
+        adaptation_status,
+        compatibility_status,
+        project_metadata,
+        references: read_skill_references(&entry.directory_path),
+        skill_md_preview: read_skill_md_preview(&entry.directory_path),
+        adaptation_metadata,
+    }))
+}
+
+fn skill_adaptation_status(adaptation_metadata: Option<&Value>) -> &'static str {
+    let Some(metadata) = adaptation_metadata else {
+        return "not_adapted";
+    };
+
+    if metadata
+        .get("protocol")
+        .and_then(Value::as_str)
+        .is_some_and(|protocol| protocol == "lux.skill.adaptation.v1")
+    {
+        "adapted"
+    } else {
+        "metadata_unrecognized"
+    }
+}
+
+fn skill_compatibility_status(adaptation_metadata: Option<&Value>) -> Option<String> {
+    adaptation_metadata?
+        .get("compatibility")?
+        .get("status")?
+        .as_str()
+        .map(str::to_string)
+}
