+#[test]
+fn ai_log_recent_json_returns_ordered_project_event_list() {
+    let requested_project = create_ai_log_project_with_log(
+        "lux-ai-log-ordered-read",
+        concat!(
+            "{\"timestampUtc\":\"2026-05-04T00:00:03Z\",\"actor\":\"codex\",\"category\":\"ai-tool\",\"source\":\"ai-tool-dispatcher\",\"action\":\"finish\",\"eventType\":\"tool.finish\",\"summary\":\"third ai step\"}\n",
+            "not-json\n",
+            "{\"timestampUtc\":\"2026-05-04T00:00:01Z\",\"actor\":\"codex\",\"category\":\"ai-tool\",\"source\":\"ai-tool-dispatcher\",\"action\":\"start\",\"eventType\":\"tool.start\",\"summary\":\"first ai step\"}\n",
+            "{\"captured_at_utc\":\"2026-05-04T00:00:02Z\",\"actor\":\"codex\",\"category\":\"ai-tool\",\"source\":\"ai-tool-dispatcher\",\"action\":\"apply_patch\",\"event_type\":\"tool.apply_patch\",\"summary\":\"second ai step\"}\n",
+            "{\"actor\":\"codex\",\"category\":\"ai-tool\",\"source\":\"ai-tool-dispatcher\",\"action\":\"note\",\"eventType\":\"tool.note\",\"summary\":\"untimed ai step\"}\n",
+        ),
+    );
+    let other_project = create_ai_log_project_with_log(
+        "lux-ai-log-ordered-read-other-project",
+        "{\"timestampUtc\":\"2026-05-04T00:00:00Z\",\"actor\":\"codex\",\"category\":\"ai-tool\",\"source\":\"ai-tool-dispatcher\",\"action\":\"start\",\"eventType\":\"tool.start\",\"summary\":\"other project step\"}\n",
+    );
+
+    let output = Command::new(env!("CARGO_BIN_EXE_lux"))
+        .args([
+            "ai-log",
+            "recent",
+            "--project-path",
+            requested_project.to_str().expect("project path UTF-8"),
+            "--limit",
+            "10",
+            "--json",
+            "--actor",
+            "codex",
+            "--category",
+            "ai-tool",
+            "--source",
+            "ai-tool-dispatcher",
+        ])
+        .output()
+        .expect("run lux ai-log recent ordered read");
+
+    assert_command_success(&output, "lux ai-log recent ordered read");
+    let parsed: Value = serde_json::from_slice(&output.stdout).expect("ordered read JSON");
+    assert_eq!(
+        parsed["projectPath"],
+        requested_project.display().to_string()
+    );
+    assert_eq!(parsed["path"], requested_project.join(".lux/ai-action-log.jsonl").display().to_string());
+    assert_eq!(parsed["count"], 4);
+    let entries = parsed["entries"].as_array().expect("entries array");
