+pub fn filter_ordered_entries(entries: Vec<AiLogEntry>, filter: &AiLogFilter) -> Vec<AiLogEntry> {
+    let mut ordered = filter_entries(
+        entries,
+        &AiLogFilter {
+            limit: None,
+            actor: filter.actor.clone(),
+            category: filter.category.clone(),
+            source: filter.source.clone(),
+            action: filter.action.clone(),
+            event_type: filter.event_type.clone(),
+        },
+    );
+
+    ordered.sort_by(compare_entries_chronologically);
+
+    if let Some(limit) = filter.limit {
+        if ordered.len() > limit {
+            ordered = ordered.split_off(ordered.len() - limit);
+        }
+    }
+
+    ordered
+}
+
+fn compare_entries_chronologically(left: &AiLogEntry, right: &AiLogEntry) -> Ordering {
+    match (!left.timestamp.is_empty(), !right.timestamp.is_empty()) {
+        (true, true) => left.timestamp.cmp(&right.timestamp),
+        (true, false) => Ordering::Less,
+        (false, true) => Ordering::Greater,
+        (false, false) => Ordering::Equal,
+    }
+    .then(left.line_number.cmp(&right.line_number))
+}
