+    assert_eq!(entries[1]["line_number"], 4);
+    assert_eq!(entries[1]["value"]["summary"], "second ai step");
+    assert_eq!(entries[2]["line_number"], 1);
+    assert_eq!(entries[2]["value"]["summary"], "third ai step");
+    assert_eq!(entries[3]["line_number"], 5);
+    assert_eq!(entries[3]["value"]["summary"], "untimed ai step");
+    assert_ne!(entries[0]["value"]["summary"], "other project step");
+    assert!(other_project.join(".lux/ai-action-log.jsonl").is_file());
+}
