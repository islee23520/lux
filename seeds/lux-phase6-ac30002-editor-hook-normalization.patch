+                ["eventCategory"] = EditorCategory,
+                ["status"] = string.IsNullOrWhiteSpace(status) ? "completed" : status.Trim(),
+                ["projectPath"] = projectPath,
+                ["projectName"] = ProjectName(projectPath)
