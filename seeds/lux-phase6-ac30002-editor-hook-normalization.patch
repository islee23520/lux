+        [Test]
+        public void Broadcaster_NormalizesEditorLifecycleEventsWithProjectScope()
+        {
+            string path = GetTempLogPath();
+            using var log = new UnityEditor.LuxAiActionLog(logPath: path);
+            UnityEditor.LuxAiActionLogBroadcaster.ConfigureForTests(log, null, () => 0.0);
+            string projectRoot = Linalab.Lux.Editor.LuxBridgeSettings.GetProjectRoot();
+
+            var entry = UnityEditor.LuxAiActionLogBroadcaster.RecordEditorLifecycleEvent(
+                " PlayMode.State_Changed ",
+                "EnteredPlayMode",
+                "Unity playmode state changed.",
+                new Dictionary<string, string> { ["state"] = "EnteredPlayMode" });
+            log.Flush();
+
+            string jsonl = File.ReadAllText(path);
+            Assert.That(entry.projectPath, Is.EqualTo(projectRoot));
+            Assert.That(entry.source, Is.EqualTo("unity-editor"));
+            Assert.That(entry.actor, Is.EqualTo("user"));
+            Assert.That(entry.category, Is.EqualTo("editor"));
+            Assert.That(entry.action, Is.EqualTo("playmode.state_changed"));
+            Assert.That(entry.target, Is.EqualTo("EnteredPlayMode"));
+            Assert.That(entry.metadata["hookName"], Is.EqualTo("manual.editor_lifecycle"));
+            Assert.That(entry.metadata["eventType"], Is.EqualTo("playmode.state_changed"));
+            Assert.That(entry.metadata["eventSource"], Is.EqualTo("unity-editor"));
+            Assert.That(entry.metadata["eventCategory"], Is.EqualTo("editor"));
+            Assert.That(entry.metadata["status"], Is.EqualTo("completed"));
+            Assert.That(entry.metadata["projectPath"], Is.EqualTo(projectRoot));
+            Assert.That(entry.metadata["projectName"], Is.Not.Empty);
+            Assert.That(entry.metadata["state"], Is.EqualTo("EnteredPlayMode"));
+            Assert.That(jsonl, Does.Contain("\"projectPath\":\""));
+            Assert.That(jsonl, Does.Contain("\"source\":\"unity-editor\""));
+            Assert.That(jsonl, Does.Contain("\"category\":\"editor\""));
+            Assert.That(jsonl, Does.Contain("\"action\":\"playmode.state_changed\""));
+            Assert.That(jsonl, Does.Contain("\"hookName\":\"manual.editor_lifecycle\""));
