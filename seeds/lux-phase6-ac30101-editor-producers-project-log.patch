+
+        static LuxAiActionLogEntry RecordEditorHookEvent(
+            string hookName,
+            string eventType,
+            string target,
+            string message,
+            IReadOnlyDictionary<string, string> metadata = null,
+            string severity = "info",
+            bool success = true)
+        {
+            string normalizedEventType = NormalizeEditorEventType(eventType);
+            return RecordWithAttribution(
+                new LuxAiActionAttribution(EditorActor, EditorSource, string.Empty),
+                EditorCategory,
+                normalizedEventType,
+                string.IsNullOrWhiteSpace(target) ? "UnityEditor" : target,
+                string.IsNullOrWhiteSpace(message) ? "Unity Editor event recorded." : message,
+                severity,
+                success,
+                BuildEditorEventMetadata(hookName, normalizedEventType, metadata));
+        }
+
+        static IReadOnlyDictionary<string, string> BuildEditorEventMetadata(
+            string hookName,
+            string eventType,
+            IReadOnlyDictionary<string, string> metadata)
+        {
+            string projectRoot = Linalab.Lux.Editor.LuxBridgeSettings.GetProjectRoot();
+            var result = new Dictionary<string, string>(StringComparer.Ordinal)
+            {
+                ["hookName"] = string.IsNullOrWhiteSpace(hookName) ? "unknown" : hookName.Trim(),
+                ["eventType"] = eventType,
+                ["eventSource"] = EditorSource,
+                ["eventCategory"] = EditorCategory,
+                ["status"] = "completed",
+                ["projectName"] = ProjectName(projectRoot)
+            };
+
+            if (metadata != null)
+            {
+                foreach (var pair in metadata)
+                {
+                    result[pair.Key ?? string.Empty] = Truncate(pair.Value);
+                }
+            }
+
+            return result;
         }
 
