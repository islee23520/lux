+        static LuxAiActionLogEntry RecordWithAttribution(
+            LuxAiActionAttribution attribution,
+            string category,
+            string action,
+            string target,
+            string message,
+            string severity,
+            bool success,
+            IReadOnlyDictionary<string, string> metadata)
+        {
+            var entry = log.Record(
+                attribution.Source,
+                attribution.Actor,
+                category,
+                action,
+                target,
+                message,
+                severity,
+                success,
+                WithCorrelation(metadata, attribution.CorrelationId));
