+        [Test]
+        public void Broadcaster_EditorInteractionEventPersistsThroughProjectScopedLogService()
+        {
+            string path = Path.Combine(_tempDirectory, "UserSettings", "LuxAiActionLog.jsonl");
+            using var log = new UnityEditor.LuxAiActionLog(logPath: path);
+            UnityEditor.LuxAiActionLogBroadcaster.ConfigureForTests(log, null, () => 0.0);
+
+            var entry = UnityEditor.LuxAiActionLogBroadcaster.RecordEditorInteractionEvent(
+                " Selection.Changed ",
+                "Main Camera",
+                "Unity selection changed.",
+                new Dictionary<string, string>
+                {
+                    ["objectCount"] = "1",
+                    ["assetGuidCount"] = "0"
+                });
+            log.Flush();
+
+            string jsonl = File.ReadAllText(path);
+
+            Assert.That(File.Exists(path), Is.True);
+            Assert.That(entry.source, Is.EqualTo("unity-editor"));
+            Assert.That(entry.actor, Is.EqualTo("user"));
+            Assert.That(entry.category, Is.EqualTo("editor"));
+            Assert.That(entry.action, Is.EqualTo("selection.changed"));
+            Assert.That(entry.target, Is.EqualTo("Main Camera"));
+            Assert.That(entry.metadata["hookName"], Is.EqualTo("manual.editor_interaction"));
+            Assert.That(entry.metadata["eventType"], Is.EqualTo("selection.changed"));
+            Assert.That(entry.metadata["eventSource"], Is.EqualTo("unity-editor"));
+            Assert.That(entry.metadata["eventCategory"], Is.EqualTo("editor"));
+            Assert.That(entry.metadata["status"], Is.EqualTo("completed"));
+            Assert.That(entry.metadata["objectCount"], Is.EqualTo("1"));
+            Assert.That(jsonl, Does.Contain("\"source\":\"unity-editor\""));
+            Assert.That(jsonl, Does.Contain("\"actor\":\"user\""));
+            Assert.That(jsonl, Does.Contain("\"category\":\"editor\""));
+            Assert.That(jsonl, Does.Contain("\"action\":\"selection.changed\""));
+            Assert.That(jsonl, Does.Contain("\"hookName\":\"manual.editor_interaction\""));
+        }
