+        static IReadOnlyDictionary<string, object> BuildEditorEventPayloadAttributes(
+            string hookName,
+            string eventType,
+            string status,
+            string target,
+            IReadOnlyDictionary<string, string> metadata)
+        {
+            string projectPath = Linalab.Lux.Editor.LuxBridgeSettings.GetProjectRoot();
+            var result = new Dictionary<string, object>(StringComparer.Ordinal)
+            {
+                ["hookName"] = string.IsNullOrWhiteSpace(hookName) ? "unknown" : hookName.Trim(),
+                ["eventType"] = eventType,
+                ["eventSource"] = EditorSource,
+                ["eventCategory"] = EditorCategory,
+                ["status"] = string.IsNullOrWhiteSpace(status) ? "completed" : status.Trim(),
+                ["targetPath"] = string.IsNullOrWhiteSpace(target) ? "UnityEditor" : target,
+                ["projectName"] = ProjectName(projectPath)
+            };
+
+            if (metadata == null)
+            {
+                return result;
+            }
+
+            foreach (var pair in metadata)
+            {
+                string key = pair.Key ?? string.Empty;
+                if (string.IsNullOrWhiteSpace(key) || string.Equals(key, "projectPath", StringComparison.Ordinal))
+                {
+                    continue;
+                }
+
+                result[key] = ConvertEditorPayloadAttributeValue(Truncate(pair.Value));
+            }
+
+            return result;
+        }
+
+        static object ConvertEditorPayloadAttributeValue(string value)
+        {
+            if (value == null)
+            {
+                return string.Empty;
+            }
+
+            string trimmed = value.Trim();
+            if (bool.TryParse(trimmed, out bool boolean))
+            {
+                return boolean;
+            }
+
+            if (long.TryParse(trimmed, System.Globalization.NumberStyles.Integer, System.Globalization.CultureInfo.InvariantCulture, out long integer))
+            {
+                return integer;
+            }
+
+            if (double.TryParse(trimmed, System.Globalization.NumberStyles.Float, System.Globalization.CultureInfo.InvariantCulture, out double number)
+                && !double.IsNaN(number)
+                && !double.IsInfinity(number))
+            {
+                return number;
+            }
+
+            return value;
+        }
 
