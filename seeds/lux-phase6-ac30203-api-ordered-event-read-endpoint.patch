+
+pub fn read_jsonl_event_entries(
+    path: impl AsRef<Path>,
+    filter: &AiLogFilter,
+) -> Result<Vec<AiLogEntry>> {
+    let path = path.as_ref();
+    if !path.exists() {
+        return Ok(Vec::new());
+    }
+
+    let file = File::open(path)
+        .with_context(|| format!("failed to open project event log {}", path.display()))?;
+    Ok(filter_ordered_entries(
+        parse_entries(BufReader::new(file)),
+        filter,
+    ))
+}
