+        {
+            string path = GetTempLogPath();
+            using var log = new UnityEditor.LuxAiActionLog(logPath: path);
+
+            var entry = log.Record(
+                "unity-editor",
+                "user",
+                "editor",
+                "selection.changed",
+                "Scene/Main Camera",
+                "Unity selection changed.");
+            log.Flush();
+
+            string line = File.ReadAllLines(path)[0];
+            var decoded = JsonUtility.FromJson<EditorActionLogRecordForTests>(line);
+
+            Assert.That(entry.payload.kind, Is.EqualTo("editor-action"));
