+    #[test]
+    fn editor_action_payload_roundtrips_through_serde() {
+        let value = serde_json::to_value(editor_action_payload_example()).unwrap();
+
+        assert_eq!(value["kind"], "editor-action");
+        assert_eq!(value["eventType"], "selection.changed");
+        assert_eq!(value["summary"], "Unity selection changed.");
+        assert_eq!(value["status"], "completed");
+        assert_eq!(value["attributes"]["objectCount"], json!(1));
+        assert_eq!(
+            value["attributes"]["targetPath"],
+            json!("Scene/Main Camera")
+        );
+
+        let roundtrip = EventPayloadConvention::from_json_value(value).unwrap();
+
+        assert_eq!(roundtrip.kind, EventPayloadKind::EditorAction);
+        assert_eq!(roundtrip.event_type, "selection.changed");
+        assert_eq!(roundtrip.summary, "Unity selection changed.");
+        assert_eq!(roundtrip.status.as_deref(), Some("completed"));
+        assert_eq!(roundtrip.attributes["objectCount"], json!(1));
+    }
