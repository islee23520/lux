+            Assert.That(decoded.source, Is.EqualTo("unity-editor"));
+            Assert.That(decoded.actor, Is.EqualTo("user"));
+            Assert.That(decoded.category, Is.EqualTo("editor"));
+            Assert.That(decoded.payload.kind, Is.EqualTo("editor-action"));
+            Assert.That(decoded.payload.eventType, Is.EqualTo("selection.changed"));
+            Assert.That(decoded.payload.summary, Is.EqualTo("Unity selection changed."));
+            Assert.That(decoded.payload.status, Is.EqualTo("completed"));
+            Assert.That(decoded.payload.target, Is.EqualTo("Scene/Main Camera"));
+        }
