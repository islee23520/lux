+            Assert.That(entry.payload.summary, Is.EqualTo("Unity selection changed."));
+            Assert.That(entry.payload.status, Is.EqualTo("completed"));
+            Assert.That(entry.payload.target, Is.EqualTo("Scene/Main Camera"));
