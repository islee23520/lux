+pub fn redact_text_for_output(text: &str) -> String {
+    let mut redact_next = false;
+    let mut parts = Vec::new();
+
+    for part in text.split_whitespace() {
+        let lower = part.to_ascii_lowercase();
+        if redact_next {
+            parts.push(REDACTED);
+            redact_next = lower == "bearer";
+            continue;
+        }
+
+        if lower == "bearer" {
+            parts.push(REDACTED);
+            redact_next = true;
+        } else if lower.starts_with("authorization:") || lower.starts_with("authorization=") {
+            parts.push(redact_assignment_part(part));
+            redact_next = true;
+        } else if contains_sensitive_assignment(&lower) {
+            parts.push(redact_assignment_part(part));
+        } else {
+            parts.push(part);
+        }
+    }
+
+    parts.join(" ")
+}
+
+pub fn redact_value_for_output(value: Value) -> Value {
