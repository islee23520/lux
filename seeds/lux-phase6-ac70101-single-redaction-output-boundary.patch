+fn redact_value_at_key(value: Value, key: Option<&str>) -> Value {
+    if key.map(is_sensitive_key).unwrap_or(false) {
+        return Value::String(REDACTED.to_string());
+    }
+
+    match value {
+        Value::String(text) => Value::String(redact_text_for_output(&text)),
+        Value::Array(items) => Value::Array(
+            items
+                .into_iter()
+                .map(|item| redact_value_at_key(item, None))
+                .collect(),
+        ),
+        Value::Object(map) => Value::Object(
+            map.into_iter()
+                .map(|(key, value)| {
+                    let redacted_value = redact_value_at_key(value, Some(&key));
+                    (key, redacted_value)
+                })
+                .collect(),
+        ),
+        other => other,
+    }
+}
+
+fn redact_assignment_part(part: &str) -> &str {
+    if part.ends_with(':') || part.ends_with('=') {
+        return part;
+    }
+
+    REDACTED
+}
+
+fn contains_sensitive_assignment(lower: &str) -> bool {
+    SENSITIVE_KEY_FRAGMENTS
+        .iter()
+        .any(|fragment| lower.contains(fragment) && (lower.contains('=') || lower.contains(':')))
+}
+
+fn is_sensitive_key(key: &str) -> bool {
+    let normalized = key
+        .chars()
+        .filter(|character| character.is_ascii_alphanumeric())
+        .collect::<String>()
+        .to_ascii_lowercase();
+    SENSITIVE_KEY_FRAGMENTS
+        .iter()
+        .map(|fragment| fragment.replace('_', "").replace('-', ""))
+        .any(|fragment| normalized.contains(&fragment))
+}
