+
+fn redaction_metadata(value: &Value) -> Option<Value> {
+    let metadata = value
+        .get("redactionMetadata")
+        .or_else(|| value.get("redaction_metadata"))?;
+    Some(json!({
+        "policyVersion": metadata
+            .get("policyVersion")
+            .or_else(|| metadata.get("policy_version"))
+            .and_then(Value::as_str)
+            .unwrap_or("unknown"),
+        "applied": metadata
+            .get("applied")
+            .and_then(Value::as_bool)
+            .unwrap_or(false),
+        "redactedCount": metadata
+            .get("redactedCount")
+            .or_else(|| metadata.get("redacted_count"))
+            .and_then(Value::as_u64)
+            .unwrap_or(0),
+        "redactedFields": string_array_field(metadata, "redactedFields")
+            .or_else(|| string_array_field(metadata, "redacted_fields"))
+            .unwrap_or_default(),
+        "redactionClasses": string_array_field(metadata, "redactionClasses")
+            .or_else(|| string_array_field(metadata, "redaction_classes"))
+            .unwrap_or_default(),
+    }))
+}
+
+fn string_array_field(value: &Value, field: &str) -> Option<Vec<String>> {
+    Some(
+        value
+            .get(field)?
+            .as_array()?
+            .iter()
+            .filter_map(Value::as_str)
+            .map(redact_secrets)
+            .collect(),
+    )
+}
