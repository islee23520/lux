+fn create_context_slimming_fixture_skill_source(name: &str) -> std::path::PathBuf {
+    let source = create_temp_dir(&format!("lux-context-slimming-fixture-{name}"));
+    fs::write(
+        source.join("manifest.json"),
+        format!(
+            r#"{{
+  "name": "{name}",
+  "version": "0.1.0",
+  "description": "Context slimming fixture skill",
+  "displayName": "Context Slimming Fixture",
+  "luxVersion": "0.1.0",
+  "author": {{ "name": "Lux Tests" }},
+  "keywords": ["context", "slimming", "fixture"],
+  "type": "test",
+  "source": "{}"
+}}"#,
+            source.display()
+        ),
+    )
+    .expect("write context slimming fixture manifest");
+
+    let skill_lines = (1..=36)
+        .map(|index| format!("Instruction line {index}: keep only the leading preview."))
+        .collect::<Vec<_>>()
+        .join("\n");
+    fs::write(
+        source.join("SKILL.md"),
+        format!("# {name}\n\n{skill_lines}\n"),
+    )
+    .expect("write context slimming fixture skill body");
+
+    let references = source.join("references");
+    fs::create_dir_all(&references).expect("create context slimming fixture references");
+    fs::write(
+        references.join("usage.md"),
+        "# Usage\nThis full usage reference should be deferred out of the default context.\n",
+    )
+    .expect("write context slimming usage reference");
+    fs::write(
+        references.join("advanced.md"),
+        concat!(
+            "# Advanced\n",
+            "Detailed advanced notes provide enough bytes to prove context reduction.\n",
+            "These notes must remain in a deferred reference artifact path only.\n",
+        ),
+    )
+    .expect("write context slimming advanced reference");
+
+    source
+}
