+#[test]
+fn skill_install_adapt_context_slimming_fixture_generates_and_reads_back() {
+    let home = create_temp_dir("lux-skill-adapt-slimming-fixture-home");
+    let project = create_test_unity_project("lux-skill-adapt-slimming-fixture-project", true);
+    let source = create_context_slimming_fixture_skill_source("smoke-context-slimming-fixture");
+
+    let install = Command::new(env!("CARGO_BIN_EXE_lux"))
+        .args([
+            "skill",
+            "install",
+            "smoke-context-slimming-fixture",
+            "--source",
+            source.to_str().expect("source path UTF-8"),
+            "--project",
+            "--adapt",
+            "--json",
+        ])
+        .current_dir(&project)
+        .env("HOME", &home)
+        .output()
+        .expect("run lux skill install --project --adapt --json for context slimming fixture");
+
+    assert_command_success(&install, "lux skill install --adapt context slimming fixture");
+    let install_json: Value = serde_json::from_slice(&install.stdout).expect("install JSON");
+    let install_context = &install_json["adaptation_metadata"]["context_slimming"];
+    assert_eq!(install_context["schema"], "lux.skill.context_slimming_result.v1");
+    assert_eq!(install_context["skill_name"], "smoke-context-slimming-fixture");
+    assert_eq!(install_context["verification"]["status"], "passed");
+    assert_eq!(
+        install_json["adaptation_metadata"]["context_slimming_verification"]["status"],
+        "passed"
+    );
+
+    let installed_dir = project.join(".lux/skills/smoke-context-slimming-fixture");
+    let context_path = installed_dir.join("lux-context-slimming.json");
+    let markdown_path = installed_dir.join("lux-context-slimming.md");
+    assert!(context_path.is_file());
+    assert!(markdown_path.is_file());
+    let artifact_text = fs::read_to_string(&context_path).expect("read context slimming artifact");
+    let artifact_json: Value =
+        serde_json::from_str(&artifact_text).expect("context slimming artifact JSON");
+    assert_eq!(&artifact_json, install_context);
+    assert_eq!(artifact_json["slimmed_context"]["skill_md_preview"]
+        .as_array()
+        .expect("skill preview")
+        .len(), 24);
+    assert_eq!(
+        artifact_json["slimmed_context"]["deferred_reference_paths"],
+        serde_json::json!(["references/advanced.md", "references/usage.md"])
+    );
+    assert_eq!(artifact_json["metrics"]["deferred_reference_count"], 2);
+    assert!(
+        artifact_json["metrics"]["estimated_reduction_percent"]
+            .as_u64()
+            .expect("estimated reduction percent")
+            > 0
+    );
+    let markdown = fs::read_to_string(&markdown_path).expect("read context slimming markdown");
+    assert!(markdown.contains("references/advanced.md"));
+    assert!(markdown.contains("references/usage.md"));
+
+    let info = Command::new(env!("CARGO_BIN_EXE_lux"))
+        .args([
+            "skill",
+            "info",
+            "smoke-context-slimming-fixture",
+            "--json",
+        ])
+        .current_dir(&project)
+        .env("HOME", &home)
+        .output()
+        .expect("run lux skill info --json for context slimming fixture");
+    assert_command_success(&info, "lux skill info context slimming fixture");
+    let info_json: Value = serde_json::from_slice(&info.stdout).expect("info JSON");
+    assert_eq!(
+        info_json["adaptation_metadata"]["context_slimming"],
+        artifact_json
+    );
+    assert_eq!(
+        info_json["adaptation_metadata"]["context_slimming_verification"]["status"],
+        "passed"
+    );
+
+    let recent = Command::new(env!("CARGO_BIN_EXE_lux"))
+        .args([
+            "ai-log",
+            "recent",
+            "--project-path",
+            project.to_str().expect("project path UTF-8"),
+            "--limit",
+            "1",
+            "--json",
+        ])
+        .env("HOME", &home)
+        .output()
+        .expect("run lux ai-log recent for context slimming event");
+    assert_command_success(&recent, "lux ai-log recent context slimming event");
+    let recent_json: Value = serde_json::from_slice(&recent.stdout).expect("recent JSON");
+    assert_eq!(recent_json["count"], 1);
+    let event = &recent_json["entries"][0]["value"];
+    assert_eq!(event["payload"]["stepName"], "context-slimming");
+    assert_eq!(
+        event["payload"]["attributes"]["contextSlimming"]["verification"]["status"],
+        "passed"
+    );
+    assert_eq!(
+        event["payload"]["attributes"]["contextSlimming"]["metrics"]["deferred_reference_count"],
+        2
+    );
+    assert!(
+        event["payload"]["attributes"]["contextSlimming"]
+            .get("slimmedContext")
+            .is_none(),
+        "AI log readback must keep the bulky slimmed context in the artifact, not the event"
+    );
