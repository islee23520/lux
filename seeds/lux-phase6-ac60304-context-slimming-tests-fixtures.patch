+#[cfg(test)]
+mod phase6_context_slimming_tests {
+    use super::*;
+
+    #[test]
+    fn context_slimming_verification_reports_failures_for_invalid_fixture() {
+        let invalid_context_slimming = json!({
+            "schema": "lux.skill.context_slimming_result.v1",
+            "skill_name": "invalid-slimming-fixture",
+            "project_root": "/tmp/lux-project",
+            "mode": "adapted_skill_generation",
+            "rules": {
+                "skill_md_preview_lines": 1,
+                "reference_policy": "inline_reference_bodies",
+                "default_context_policy": "full_source_context",
+                "redaction_policy": "none"
+            },
+            "redaction": {
+                "policy": "lux.skill.context_slimming.redaction.v1",
+                "applied": false
+            },
+            "slimmed_context": {
+                "manifest": {
+                    "name": "invalid-slimming-fixture",
+                    "version": "0.1.0",
+                    "description": "token=raw-phase6-verification-token"
+                },
+                "skill_md_preview": [
+                    "first line",
+                    "second line"
+                ],
+                "deferred_reference_paths": [
+                    "/absolute/reference.md",
+                    "../escaping-reference.md"
+                ],
+                "reference_bodies": {
+                    "usage.md": "Reference body should never be in the slimmed context."
+                }
+            },
+            "included_sources": [
+                { "path": "manifest.json" }
+            ],
+            "excluded_sources": [],
+            "metrics": {
+                "source_bytes": 100,
+                "retained_preview_chars": 500,
+                "deferred_reference_count": 1,
+                "estimated_reduction_percent": 0
+            }
+        });
+
+        let verification = verify_skill_context_slimming_result(&invalid_context_slimming);
+
+        assert_eq!(verification["status"], "failed");
+        assert_context_slimming_check_failed(&verification, "required_fields");
+        assert_context_slimming_check_failed(&verification, "redaction");
+        assert_context_slimming_check_failed(&verification, "context_boundaries");
+        let messages = context_slimming_failed_check_messages(&verification);
+        assert!(messages.contains("Missing required fields"));
+        assert!(messages.contains("Unredacted sensitive markers remain"));
+        assert!(messages.contains("Slimmed context exceeded"));
+    }
+
+    fn assert_context_slimming_check_failed(verification: &Value, name: &str) {
+        let checks = verification["checks"].as_array().expect("checks array");
+        assert!(
+            checks
+                .iter()
+                .any(|check| check["name"] == name && check["ok"] == false),
+            "expected failed context slimming check {name}"
+        );
+    }
+}
