+#[test]
+fn skill_info_returns_project_adaptation_status() {
+    let home = create_temp_dir("lux-skill-info-project-home");
+    let project = create_test_unity_project("lux-skill-info-project", true);
+    let source = create_test_skill_source("smoke-info-scope-skill");
+
+    let global_install = Command::new(env!("CARGO_BIN_EXE_lux"))
+        .args([
+            "skill",
+            "install",
+            "smoke-info-scope-skill",
+            "--source",
+            source.to_str().expect("source path UTF-8"),
+            "--json",
+        ])
+        .env("HOME", &home)
+        .output()
+        .expect("run global lux skill install");
+    assert_command_success(&global_install, "global lux skill install");
+
+    let project_install = Command::new(env!("CARGO_BIN_EXE_lux"))
+        .args([
+            "skill",
+            "install",
+            "smoke-info-scope-skill",
+            "--source",
+            source.to_str().expect("source path UTF-8"),
+            "--project",
+            "--adapt",
+            "--json",
+        ])
+        .current_dir(&project)
+        .env("HOME", &home)
+        .output()
+        .expect("run project lux skill install --adapt");
+    assert_command_success(&project_install, "project lux skill install --adapt");
+
+    let default_info = Command::new(env!("CARGO_BIN_EXE_lux"))
+        .args(["skill", "info", "smoke-info-scope-skill", "--json"])
+        .current_dir(&project)
+        .env("HOME", &home)
+        .output()
+        .expect("run lux skill info default scope");
+    assert_command_success(&default_info, "lux skill info default scope");
+    let default_json: Value =
+        serde_json::from_slice(&default_info.stdout).expect("default info JSON");
+    assert_eq!(default_json["scope"], "project");
+    assert_eq!(default_json["adapted"], true);
+    assert_eq!(default_json["adaptation_status"], "adapted");
+    assert_eq!(
+        default_json["adaptation_metadata"]["skill_name"],
+        "smoke-info-scope-skill"
+    );
+
+    let scoped_info = Command::new(env!("CARGO_BIN_EXE_lux"))
+        .args([
+            "skill",
+            "info",
+            "smoke-info-scope-skill",
+            "--project",
+            "--json",
+        ])
+        .current_dir(&project)
+        .env("HOME", &home)
+        .output()
+        .expect("run project-scoped lux skill info");
+    assert_command_success(&scoped_info, "project-scoped lux skill info");
+    let scoped_json: Value = serde_json::from_slice(&scoped_info.stdout).expect("scoped info JSON");
+    assert_eq!(scoped_json["scope"], "project");
+    assert_eq!(scoped_json["adapted"], true);
+    assert_eq!(scoped_json["adaptation_status"], "adapted");
+    assert_eq!(scoped_json["compatibility_status"], "compatible");
+    assert_eq!(
+        scoped_json["project_metadata"]["schema"],
+        "lux.project_metadata_signals.v1"
+    );
+    assert_eq!(
+        scoped_json["directory_path"],
+        Value::String(
+            project
+                .join(".lux/skills/smoke-info-scope-skill")
+                .to_string_lossy()
+                .into_owned()
+        )
+    );
+}
 
