+        static void AppendPayload(StringBuilder builder, LuxAiActionLogPayload payload)
+        {
+            payload ??= new LuxAiActionLogPayload();
+            builder.Append('{');
+            AppendJsonProperty(builder, "kind", payload.kind, true);
+            AppendJsonProperty(builder, "eventType", payload.eventType, false);
+            AppendJsonProperty(builder, "summary", payload.summary, false);
+            AppendJsonProperty(builder, "status", payload.status, false);
+            AppendJsonProperty(builder, "target", payload.target, false);
+            builder.Append(",\"attributes\":");
+            AppendStructuredObject(builder, payload.attributes);
+            builder.Append('}');
+        }
+
+        static void AppendStructuredObject(StringBuilder builder, IReadOnlyDictionary<string, object> values)
+        {
+            builder.Append('{');
+            bool first = true;
+            if (values != null)
+            {
+                foreach (var pair in values.OrderBy(pair => pair.Key, StringComparer.Ordinal))
+                {
+                    if (!first)
+                    {
+                        builder.Append(',');
+                    }
+
+                    builder.Append('"').Append(EscapeJson(pair.Key)).Append("\":");
+                    AppendJsonValue(builder, pair.Value);
+                    first = false;
+                }
+            }
+
+            builder.Append('}');
+        }
+
+        static void AppendJsonValue(StringBuilder builder, object value)
+        {
+            switch (value)
+            {
+                case null:
+                    builder.Append("null");
+                    break;
+                case string text:
+                    builder.Append('"').Append(EscapeJson(text)).Append('"');
+                    break;
+                case bool boolean:
+                    builder.Append(boolean ? "true" : "false");
+                    break;
+                case byte _:
+                case sbyte _:
+                case short _:
+                case ushort _:
+                case int _:
+                case uint _:
+                case long _:
+                case ulong _:
+                case decimal _:
+                    builder.Append(Convert.ToString(value, CultureInfo.InvariantCulture));
+                    break;
+                case float single:
+                    AppendFloatingPoint(builder, single);
+                    break;
+                case double number:
+                    AppendFloatingPoint(builder, number);
+                    break;
+                case IReadOnlyDictionary<string, object> typedDictionary:
+                    AppendStructuredObject(builder, typedDictionary);
+                    break;
+                case IDictionary dictionary:
+                    AppendStructuredObject(builder, DictionaryToObjectMap(dictionary));
+                    break;
+                case IEnumerable enumerable:
+                    AppendJsonArray(builder, enumerable);
+                    break;
+                default:
+                    builder.Append('"')
+                        .Append(EscapeJson(Convert.ToString(value, CultureInfo.InvariantCulture)))
+                        .Append('"');
+                    break;
+            }
+        }
+
+        static void AppendFloatingPoint(StringBuilder builder, double value)
+        {
+            if (double.IsNaN(value) || double.IsInfinity(value))
+            {
+                builder.Append("null");
+                return;
+            }
+
+            builder.Append(value.ToString("R", CultureInfo.InvariantCulture));
+        }
+
+        static void AppendJsonArray(StringBuilder builder, IEnumerable values)
+        {
+            builder.Append('[');
+            bool first = true;
+            foreach (object value in values)
+            {
+                if (!first)
+                {
+                    builder.Append(',');
+                }
+
+                AppendJsonValue(builder, value);
+                first = false;
+            }
+
+            builder.Append(']');
+        }
+
+        static Dictionary<string, object> DictionaryToObjectMap(IDictionary dictionary)
+        {
+            var result = new Dictionary<string, object>(StringComparer.Ordinal);
+            if (dictionary == null)
+            {
+                return result;
+            }
+
+            foreach (DictionaryEntry entry in dictionary)
+            {
+                string key = Convert.ToString(entry.Key, CultureInfo.InvariantCulture) ?? string.Empty;
+                result[key] = entry.Value;
+            }
+
+            return result;
+        }
+
+        internal static Dictionary<string, object> CloneStructuredDictionary(IReadOnlyDictionary<string, object> source)
+        {
+            var result = new Dictionary<string, object>(StringComparer.Ordinal);
+            if (source == null)
+            {
+                return result;
+            }
+
+            foreach (var pair in source)
+            {
+                result[pair.Key] = CloneStructuredValue(pair.Value);
+            }
+
+            return result;
+        }
+
+        static object CloneStructuredValue(object value)
+        {
+            switch (value)
+            {
+                case null:
+                    return null;
+                case IReadOnlyDictionary<string, object> typedDictionary:
+                    return CloneStructuredDictionary(typedDictionary);
+                case IDictionary dictionary:
+                    return CloneStructuredDictionary(DictionaryToObjectMap(dictionary));
+                case string _:
+                    return value;
+                case IEnumerable enumerable:
+                    return enumerable.Cast<object>().Select(CloneStructuredValue).ToArray();
+                default:
+                    return value;
+            }
         }
 
