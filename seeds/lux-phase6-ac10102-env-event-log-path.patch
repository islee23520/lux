+#[test]
+fn ai_log_recent_json_reads_env_log_path_override() {
+    let nanos = SystemTime::now()
+        .duration_since(UNIX_EPOCH)
+        .expect("system time after Unix epoch")
+        .as_nanos();
+    let project_root = std::env::temp_dir()
+        .join(format!("lux-ai-log-env-override-{}-{nanos}", std::process::id()))
+        .join("Project");
+    let override_relative_path = "EnvLogs/override-events.jsonl";
+    let override_path = project_root.join(override_relative_path);
+    fs::create_dir_all(override_path.parent().expect("override log parent"))
+        .expect("create override log directory");
+    fs::write(
+        &override_path,
+        "{\"timestampUtc\":\"2026-05-04T00:00:05Z\",\"actor\":\"codex\",\"category\":\"ai-action-log\",\"source\":\"cli\",\"action\":\"env-path\",\"eventType\":\"append\",\"summary\":\"env override event\"}\n",
+    )
+    .expect("write override AI log fixture");
+
+    let output = Command::new(env!("CARGO_BIN_EXE_lux"))
+        .args([
+            "ai-log",
+            "recent",
+            "--project-path",
+            project_root.to_str().expect("project path UTF-8"),
+            "--limit",
+            "5",
+            "--json",
+        ])
+        .env("LUX_AI_ACTION_LOG_PATH", override_relative_path)
+        .output()
+        .expect("run lux ai-log recent with env override");
+
+    assert_command_success(&output, "lux ai-log recent env override");
+    let parsed: Value = serde_json::from_slice(&output.stdout).expect("recent JSON");
+    assert_eq!(parsed["path"], override_path.to_string_lossy().as_ref());
+    assert_eq!(parsed["count"], 1);
+    assert_eq!(
+        parsed["entries"][0]["value"]["summary"],
+        "env override event"
+    );
+    assert_eq!(
+        parsed["entries"][0]["value"]["action"],
+        "env-path"
+    );
+}
