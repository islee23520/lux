+        [Test]
+        public void Broadcaster_RegistersUnityEditorLifecycleAndInteractionHooks()
+        {
+            UnityEditor.LuxAiActionLogBroadcaster.RegisterEditorHooksForTests();
+
+            var hooks = UnityEditor.LuxAiActionLogBroadcaster.RegisteredEditorHookNamesForTests();
+
+            Assert.That(hooks, Does.Contain("EditorApplication.update"));
+            Assert.That(hooks, Does.Contain("Selection.selectionChanged"));
+            Assert.That(hooks, Does.Contain("EditorApplication.playModeStateChanged"));
+            Assert.That(hooks, Does.Contain("EditorApplication.pauseStateChanged"));
+            Assert.That(hooks, Does.Contain("EditorApplication.hierarchyChanged"));
+            Assert.That(hooks, Does.Contain("EditorApplication.projectChanged"));
+            Assert.That(hooks, Does.Contain("Undo.undoRedoPerformed"));
+            Assert.That(hooks, Does.Contain("EditorSceneManager.sceneOpened"));
+            Assert.That(hooks, Does.Contain("EditorSceneManager.sceneSaved"));
+            Assert.That(hooks, Does.Contain("EditorSceneManager.sceneClosing"));
+            Assert.That(hooks, Does.Contain("Application.logMessageReceived"));
+            Assert.That(hooks, Does.Contain("AssemblyReloadEvents.beforeAssemblyReload"));
+            Assert.That(hooks, Does.Contain("EditorApplication.quitting"));
+        }
