+using System;
+using System.Collections;
+using System.Collections.Generic;
+using System.Globalization;
+using System.IO;
+using System.Linq;
+using System.Text;
+using System.Text.RegularExpressions;
+using UnityEngine;
+
+namespace Linalab.Lux.Runtime
+{
+    [Serializable]
+    public sealed class LuxRuntimeEventRecord
+    {
+        public int schemaVersion;
+        public string protocol;
+        public string id;
+        public string timestampUtc;
+        public string projectPath;
+        public string source;
+        public string actor;
+        public string category;
+        public string type;
+        public string action;
+        public string target;
+        public string summary;
+        public string message;
+        public string severity;
+        public bool success;
+        public Dictionary<string, string> metadata;
+        public LuxRuntimeEventPayload payload;
+    }
+
+    [Serializable]
+    public sealed class LuxRuntimeEventPayload
+    {
+        public string kind;
+        public string eventType;
+        public string summary;
+        public string status;
+        public string target;
+        public Dictionary<string, object> attributes;
+    }
+
+    public static class LuxRuntimeEvent
+    {
+        public const int SchemaVersion = 1;
+        public const string Protocol = "lux.ai.action_log.v1";
+        public const string Source = "unity-runtime";
+        public const string Actor = "gameplay";
+        public const string Category = "runtime";
+        public const string PayloadKind = "runtime-gameplay-event";
+        public const string LogPathEnvironmentVariable = "LUX_AI_ACTION_LOG_PATH";
+        public const string DefaultRelativeLogPath = "UserSettings/LuxAiActionLog.jsonl";
+
+        const string Redacted = "[REDACTED]";
+        const string Truncated = "[TRUNCATED]";
+        const int DefaultMaxTextLength = 4096;
+        const int DefaultRetentionDays = 30;
+        const int DefaultRetentionMaxEntries = 10000;
+
+        static readonly object Sync = new object();
+        static readonly Regex PrivateKeyBlockPattern = new Regex(
+            "-----BEGIN [A-Z ]*PRIVATE KEY-----[\\s\\S]*?-----END [A-Z ]*PRIVATE KEY-----",
+            RegexOptions.Compiled | RegexOptions.CultureInvariant);
+        static readonly Regex AuthorizationPattern = new Regex(
+            "(?i)(authorization\\s*[:=]\\s*)(bearer\\s+)?[^\\s,;\\\"'}]+",
+            RegexOptions.Compiled | RegexOptions.CultureInvariant);
+        static readonly Regex BearerPattern = new Regex(
+            "(?i)\\bbearer\\s+[^\\s,;\\\"'}]+",
+            RegexOptions.Compiled | RegexOptions.CultureInvariant);
+        static readonly Regex SecretTokenPattern = new Regex(
+            "(?i)secret-token",
+            RegexOptions.Compiled | RegexOptions.CultureInvariant);
+        static readonly Regex SensitiveAssignmentPattern = new Regex(
+            "(?i)\\b(token|api[_-]?key|password|passwd|pwd|secret)\\b\\s*[:=]\\s*[^\\s,;\\\"'}]+",
+            RegexOptions.Compiled | RegexOptions.CultureInvariant);
+        static readonly Regex SensitiveKeyPattern = new Regex(
+            "(?i)(token|authorization|api[_-]?key|password|passwd|pwd|secret|private[_-]?key)",
+            RegexOptions.Compiled | RegexOptions.CultureInvariant);
+
+        static string configuredLogPath;
+        static string configuredProjectRoot;
+        static Func<DateTime> utcNowProvider = () => DateTime.UtcNow;
+
+        public static LuxRuntimeEventRecord Emit(
+            string eventType,
+            IReadOnlyDictionary<string, object> payload = null,
+            string target = null,
+            string summary = null,
+            string status = "completed",
+            string severity = "info",
+            bool success = true,
+            IReadOnlyDictionary<string, string> metadata = null)
+        {
+            string normalizedEventType = NormalizeEventType(eventType);
+            DateTime timestamp = utcNowProvider().ToUniversalTime();
+            string projectRoot = ResolveProjectRoot();
+            string redactedSummary = RedactText(string.IsNullOrWhiteSpace(summary)
+                ? "Gameplay runtime event emitted: " + normalizedEventType + "."
+                : summary);
+            string redactedTarget = RedactText(target);
+            string redactedStatus = RedactText(string.IsNullOrWhiteSpace(status) ? "completed" : status);
+
+            var record = new LuxRuntimeEventRecord
+            {
+                schemaVersion = SchemaVersion,
+                protocol = Protocol,
+                id = Guid.NewGuid().ToString("N"),
+                timestampUtc = timestamp.ToString("o", CultureInfo.InvariantCulture),
+                projectPath = RedactText(projectRoot),
+                source = Source,
+                actor = Actor,
+                category = Category,
+                type = normalizedEventType,
+                action = normalizedEventType,
+                target = redactedTarget,
+                summary = redactedSummary,
+                message = redactedSummary,
+                severity = NormalizeSeverity(severity),
+                success = success,
+                metadata = RedactMetadata(metadata),
+                payload = new LuxRuntimeEventPayload
+                {
+                    kind = PayloadKind,
+                    eventType = normalizedEventType,
+                    summary = redactedSummary,
+                    status = redactedStatus,
+                    target = redactedTarget,
+                    attributes = RedactAttributes(payload)
+                }
+            };
+
+            AppendRecord(record, timestamp);
+            return CloneRecord(record);
+        }
+
+        public static LuxRuntimeEventRecord Record(
+            string eventType,
+            IReadOnlyDictionary<string, object> payload = null,
+            string target = null,
+            string summary = null,
+            string status = "completed",
+            string severity = "info",
+            bool success = true,
+            IReadOnlyDictionary<string, string> metadata = null)
+        {
+            return Emit(eventType, payload, target, summary, status, severity, success, metadata);
+        }
+
+        public static string ResolveLogPath()
+        {
+            if (!string.IsNullOrWhiteSpace(configuredLogPath))
+            {
+                return Path.GetFullPath(configuredLogPath);
+            }
+
+            string projectRoot = ResolveProjectRoot();
+            string overridePath = Environment.GetEnvironmentVariable(LogPathEnvironmentVariable);
+            if (!string.IsNullOrWhiteSpace(overridePath))
+            {
+                return Path.GetFullPath(Path.IsPathRooted(overridePath)
+                    ? overridePath
+                    : Path.Combine(projectRoot, overridePath));
+            }
+
+            return Path.GetFullPath(Path.Combine(projectRoot, DefaultRelativeLogPath));
+        }
+
+        public static void ConfigureForTests(string logPath, string projectRoot = null, Func<DateTime> utcNow = null)
+        {
+            configuredLogPath = string.IsNullOrWhiteSpace(logPath) ? null : logPath;
+            configuredProjectRoot = string.IsNullOrWhiteSpace(projectRoot) ? null : projectRoot;
+            utcNowProvider = utcNow ?? (() => DateTime.UtcNow);
+        }
+
+        public static void ResetForTests()
+        {
+            configuredLogPath = null;
+            configuredProjectRoot = null;
+            utcNowProvider = () => DateTime.UtcNow;
+        }
+
+        static void AppendRecord(LuxRuntimeEventRecord record, DateTime capturedAtUtc)
+        {
+            string logPath = ResolveLogPath();
+            string directory = Path.GetDirectoryName(logPath);
+            string json = ToJson(record, capturedAtUtc);
+
+            lock (Sync)
+            {
+                if (!string.IsNullOrEmpty(directory))
+                {
+                    Directory.CreateDirectory(directory);
+                }
+
+                File.AppendAllText(logPath, json + Environment.NewLine, Encoding.UTF8);
+            }
+        }
+
+        static string ResolveProjectRoot()
+        {
+            if (!string.IsNullOrWhiteSpace(configuredProjectRoot))
+            {
+                return Path.GetFullPath(configuredProjectRoot);
+            }
+
+            string dataPath = Application.dataPath;
+            if (!string.IsNullOrWhiteSpace(dataPath))
+            {
+                var assetsDirectory = Directory.GetParent(dataPath);
+                if (assetsDirectory != null)
+                {
+                    return Path.GetFullPath(assetsDirectory.FullName);
+                }
+            }
+
+            return Path.GetFullPath(Directory.GetCurrentDirectory());
+        }
+
+        static string NormalizeEventType(string eventType)
+        {
+            string normalized = RedactText(eventType).Trim();
+            return string.IsNullOrWhiteSpace(normalized) ? "runtime.event" : normalized;
+        }
+
+        static string NormalizeSeverity(string severity)
+        {
+            string normalized = RedactText(severity).Trim().ToLowerInvariant();
+            return string.IsNullOrWhiteSpace(normalized) ? "info" : normalized;
+        }
+
+        static Dictionary<string, string> RedactMetadata(IReadOnlyDictionary<string, string> metadata)
+        {
+            var result = new Dictionary<string, string>(StringComparer.Ordinal);
+            if (metadata == null)
+            {
+                return result;
+            }
+
+            foreach (var pair in metadata)
+            {
+                string key = RedactText(pair.Key);
+                result[key] = SensitiveKeyPattern.IsMatch(pair.Key ?? string.Empty) ? Redacted : RedactText(pair.Value);
+            }
+
+            return result;
+        }
+
+        static Dictionary<string, object> RedactAttributes(IReadOnlyDictionary<string, object> payload)
+        {
+            var result = new Dictionary<string, object>(StringComparer.Ordinal);
+            if (payload == null)
+            {
+                return result;
+            }
+
+            foreach (var pair in payload)
+            {
+                string key = RedactText(pair.Key);
+                result[key] = SensitiveKeyPattern.IsMatch(pair.Key ?? string.Empty)
+                    ? Redacted
+                    : RedactValue(pair.Value);
+            }
+
+            return result;
+        }
+
+        static object RedactValue(object value)
+        {
+            if (value == null)
+            {
+                return null;
+            }
+
+            if (value is string text)
+            {
+                return RedactText(text);
+            }
+
+            if (value is Vector2 vector2)
+            {
+                return new Dictionary<string, object>
+                {
+                    ["x"] = vector2.x,
+                    ["y"] = vector2.y
+                };
+            }
+
+            if (value is Vector3 vector3)
+            {
+                return new Dictionary<string, object>
+                {
+                    ["x"] = vector3.x,
+                    ["y"] = vector3.y,
+                    ["z"] = vector3.z
+                };
+            }
+
+            if (value is Quaternion quaternion)
+            {
+                return new Dictionary<string, object>
+                {
+                    ["x"] = quaternion.x,
+                    ["y"] = quaternion.y,
+                    ["z"] = quaternion.z,
+                    ["w"] = quaternion.w
+                };
+            }
+
+            if (value is Color color)
+            {
+                return new Dictionary<string, object>
+                {
+                    ["r"] = color.r,
+                    ["g"] = color.g,
+                    ["b"] = color.b,
+                    ["a"] = color.a
+                };
+            }
+
+            if (value is GameObject gameObject)
+            {
+                return RedactText(gameObject.name);
+            }
+
+            if (value is Component component)
+            {
+                return RedactText(component.name);
+            }
+
+            if (value is IDictionary dictionary)
+            {
+                var result = new Dictionary<string, object>(StringComparer.Ordinal);
+                foreach (DictionaryEntry entry in dictionary)
+                {
+                    string key = RedactText(Convert.ToString(entry.Key, CultureInfo.InvariantCulture));
+                    result[key] = SensitiveKeyPattern.IsMatch(key) ? Redacted : RedactValue(entry.Value);
+                }
+
+                return result;
+            }
+
+            if (!(value is string) && value is IEnumerable enumerable)
+            {
+                var result = new List<object>();
+                foreach (var item in enumerable)
+                {
+                    result.Add(RedactValue(item));
+                }
+
+                return result;
+            }
+
+            Type valueType = value.GetType();
+            if (valueType.IsPrimitive || value is decimal)
+            {
+                return value;
+            }
+
+            return RedactText(Convert.ToString(value, CultureInfo.InvariantCulture));
+        }
+
+        static string RedactText(string value)
+        {
+            string redacted = value ?? string.Empty;
+            redacted = PrivateKeyBlockPattern.Replace(redacted, Redacted);
+            redacted = AuthorizationPattern.Replace(redacted, match => match.Groups[1].Value + Redacted);
+            redacted = BearerPattern.Replace(redacted, Redacted);
+            redacted = SecretTokenPattern.Replace(redacted, Redacted);
+            redacted = SensitiveAssignmentPattern.Replace(redacted, match => match.Groups[1].Value + "=" + Redacted);
+
+            if (redacted.Length <= DefaultMaxTextLength)
+            {
+                return redacted;
+            }
+
+            return redacted.Substring(0, DefaultMaxTextLength) + Truncated;
+        }
+
+        static LuxRuntimeEventRecord CloneRecord(LuxRuntimeEventRecord record)
+        {
+            return new LuxRuntimeEventRecord
+            {
+                schemaVersion = record.schemaVersion,
+                protocol = record.protocol,
+                id = record.id,
+                timestampUtc = record.timestampUtc,
+                projectPath = record.projectPath,
+                source = record.source,
+                actor = record.actor,
+                category = record.category,
+                type = record.type,
+                action = record.action,
+                target = record.target,
+                summary = record.summary,
+                message = record.message,
+                severity = record.severity,
+                success = record.success,
+                metadata = record.metadata == null
+                    ? new Dictionary<string, string>()
+                    : new Dictionary<string, string>(record.metadata),
+                payload = new LuxRuntimeEventPayload
+                {
+                    kind = record.payload.kind,
+                    eventType = record.payload.eventType,
+                    summary = record.payload.summary,
+                    status = record.payload.status,
+                    target = record.payload.target,
+                    attributes = CloneDictionary(record.payload.attributes)
+                }
+            };
+        }
+
+        static Dictionary<string, object> CloneDictionary(IReadOnlyDictionary<string, object> source)
+        {
+            var result = new Dictionary<string, object>(StringComparer.Ordinal);
+            if (source == null)
+            {
+                return result;
+            }
+
+            foreach (var pair in source)
+            {
+                result[pair.Key] = pair.Value;
+            }
+
+            return result;
+        }
+
+        static string ToJson(LuxRuntimeEventRecord record, DateTime capturedAtUtc)
+        {
+            var builder = new StringBuilder(1024);
+            builder.Append('{');
+            AppendJsonProperty(builder, "schemaVersion", record.schemaVersion, true);
+            AppendJsonProperty(builder, "protocol", record.protocol, false);
+            AppendJsonProperty(builder, "id", record.id, false);
+            AppendJsonProperty(builder, "timestampUtc", record.timestampUtc, false);
+            AppendJsonProperty(builder, "projectPath", record.projectPath, false);
+            AppendJsonProperty(builder, "source", record.source, false);
+            AppendJsonProperty(builder, "actor", record.actor, false);
+            AppendJsonProperty(builder, "category", record.category, false);
+            AppendJsonProperty(builder, "type", record.type, false);
+            AppendJsonProperty(builder, "action", record.action, false);
+            AppendJsonProperty(builder, "target", record.target, false);
+            AppendJsonProperty(builder, "summary", record.summary, false);
+            AppendJsonProperty(builder, "message", record.message, false);
+            AppendJsonProperty(builder, "severity", record.severity, false);
+            AppendJsonProperty(builder, "success", record.success, false);
+            builder.Append(",\"metadata\":");
+            AppendStringDictionary(builder, record.metadata);
+            builder.Append(",\"redactionMetadata\":");
+            AppendRedactionMetadata(builder, record);
+            builder.Append(",\"retentionMetadata\":");
+            AppendRetentionMetadata(builder, capturedAtUtc);
+            builder.Append(",\"payload\":");
+            AppendPayload(builder, record.payload);
+            builder.Append('}');
+            return builder.ToString();
+        }
+
+        static void AppendPayload(StringBuilder builder, LuxRuntimeEventPayload payload)
+        {
+            builder.Append('{');
+            AppendJsonProperty(builder, "kind", payload.kind, true);
+            AppendJsonProperty(builder, "eventType", payload.eventType, false);
+            AppendJsonProperty(builder, "summary", payload.summary, false);
+            AppendJsonProperty(builder, "status", payload.status, false);
+            AppendJsonProperty(builder, "target", payload.target, false);
+            builder.Append(",\"attributes\":");
+            AppendJsonValue(builder, payload.attributes);
+            builder.Append('}');
+        }
+
+        static void AppendRedactionMetadata(StringBuilder builder, LuxRuntimeEventRecord record)
+        {
+            bool applied = ContainsRedaction(record);
+            builder.Append('{');
+            AppendJsonProperty(builder, "policyVersion", "lux.redaction.v1", true);
+            AppendJsonProperty(builder, "applied", applied, false);
+            AppendJsonProperty(builder, "redactedCount", applied ? 1 : 0, false);
+            builder.Append(",\"redactedFields\":");
+            AppendJsonValue(builder, applied ? new[] { "runtime-event" } : Array.Empty<string>());
+            builder.Append(",\"redactionClasses\":");
+            AppendJsonValue(builder, applied ? new[] { "credential" } : Array.Empty<string>());
+            builder.Append('}');
+        }
+
+        static void AppendRetentionMetadata(StringBuilder builder, DateTime capturedAtUtc)
+        {
+            DateTime expiresAtUtc = capturedAtUtc.AddDays(DefaultRetentionDays);
+            builder.Append('{');
+            AppendJsonProperty(builder, "policyVersion", "lux.retention.v1", true);
+            AppendJsonProperty(builder, "policyName", "project-jsonl-30d-or-10000", false);
+            AppendJsonProperty(builder, "lifecycleState", "active", false);
+            AppendJsonProperty(builder, "retentionDays", DefaultRetentionDays, false);
+            AppendJsonProperty(builder, "maxEntries", DefaultRetentionMaxEntries, false);
+            AppendJsonProperty(builder, "expiresAtUtc", expiresAtUtc.ToString("o", CultureInfo.InvariantCulture), false);
+            AppendJsonProperty(builder, "cleanupEligible", false, false);
+            AppendJsonProperty(builder, "cleanupReason", string.Empty, false);
+            builder.Append('}');
+        }
+
+        static bool ContainsRedaction(LuxRuntimeEventRecord record)
+        {
+            return ToSearchText(record).Contains(Redacted);
+        }
+
+        static string ToSearchText(LuxRuntimeEventRecord record)
+        {
+            var builder = new StringBuilder();
+            builder.Append(record.projectPath).Append(record.target).Append(record.summary).Append(record.message);
+            if (record.metadata != null)
+            {
+                foreach (var pair in record.metadata)
+                {
+                    builder.Append(pair.Key).Append(pair.Value);
+                }
+            }
+
+            if (record.payload != null && record.payload.attributes != null)
+            {
+                AppendSearchText(builder, record.payload.attributes);
+            }
+
+            return builder.ToString();
+        }
+
+        static void AppendSearchText(StringBuilder builder, object value)
+        {
+            if (value == null)
+            {
+                return;
+            }
+
+            if (value is IDictionary dictionary)
+            {
+                foreach (DictionaryEntry entry in dictionary)
+                {
+                    builder.Append(entry.Key);
+                    AppendSearchText(builder, entry.Value);
+                }
+
+                return;
+            }
+
+            if (!(value is string) && value is IEnumerable enumerable)
+            {
+                foreach (var item in enumerable)
+                {
+                    AppendSearchText(builder, item);
+                }
+
+                return;
+            }
+
+            builder.Append(value);
+        }
+
+        static void AppendJsonProperty(StringBuilder builder, string name, string value, bool first)
+        {
+            if (!first)
+            {
+                builder.Append(',');
+            }
+
+            builder.Append('"').Append(name).Append("\":\"").Append(EscapeJson(value)).Append('"');
+        }
+
+        static void AppendJsonProperty(StringBuilder builder, string name, int value, bool first)
+        {
+            if (!first)
+            {
+                builder.Append(',');
+            }
+
+            builder.Append('"').Append(name).Append("\":").Append(value.ToString(CultureInfo.InvariantCulture));
+        }
+
+        static void AppendJsonProperty(StringBuilder builder, string name, bool value, bool first)
+        {
+            if (!first)
+            {
+                builder.Append(',');
+            }
+
+            builder.Append('"').Append(name).Append("\":").Append(value ? "true" : "false");
+        }
+
+        static void AppendStringDictionary(StringBuilder builder, IReadOnlyDictionary<string, string> dictionary)
+        {
+            builder.Append('{');
+            bool first = true;
+            if (dictionary != null)
+            {
+                foreach (var pair in dictionary.OrderBy(pair => pair.Key, StringComparer.Ordinal))
+                {
+                    if (!first)
+                    {
+                        builder.Append(',');
+                    }
+
+                    builder.Append('"').Append(EscapeJson(pair.Key)).Append("\":\"").Append(EscapeJson(pair.Value)).Append('"');
+                    first = false;
+                }
+            }
+
+            builder.Append('}');
+        }
+
+        static void AppendJsonValue(StringBuilder builder, object value)
+        {
+            if (value == null)
+            {
+                builder.Append("null");
+                return;
+            }
+
+            if (value is string text)
+            {
+                builder.Append('"').Append(EscapeJson(text)).Append('"');
+                return;
+            }
+
+            if (value is bool boolean)
+            {
+                builder.Append(boolean ? "true" : "false");
+                return;
+            }
+
+            if (value is byte || value is sbyte || value is short || value is ushort ||
+                value is int || value is uint || value is long || value is ulong ||
+                value is float || value is double || value is decimal)
+            {
+                builder.Append(Convert.ToString(value, CultureInfo.InvariantCulture));
+                return;
+            }
+
+            if (value is IDictionary dictionary)
+            {
+                builder.Append('{');
+                bool first = true;
+                foreach (DictionaryEntry entry in dictionary)
+                {
+                    if (!first)
+                    {
+                        builder.Append(',');
+                    }
+
+                    builder.Append('"')
+                        .Append(EscapeJson(Convert.ToString(entry.Key, CultureInfo.InvariantCulture)))
+                        .Append("\":");
+                    AppendJsonValue(builder, entry.Value);
+                    first = false;
+                }
+
+                builder.Append('}');
+                return;
+            }
+
+            if (!(value is string) && value is IEnumerable enumerable)
+            {
+                builder.Append('[');
+                bool first = true;
+                foreach (var item in enumerable)
+                {
+                    if (!first)
+                    {
+                        builder.Append(',');
+                    }
+
+                    AppendJsonValue(builder, item);
+                    first = false;
+                }
+
+                builder.Append(']');
+                return;
+            }
+
+            builder.Append('"').Append(EscapeJson(Convert.ToString(value, CultureInfo.InvariantCulture))).Append('"');
+        }
+
+        static string EscapeJson(string value)
+        {
+            if (string.IsNullOrEmpty(value))
+            {
+                return string.Empty;
+            }
+
+            var builder = new StringBuilder(value.Length + 16);
+            foreach (char character in value)
+            {
+                switch (character)
+                {
+                    case '\\':
+                        builder.Append("\\\\");
+                        break;
+                    case '"':
+                        builder.Append("\\\"");
+                        break;
+                    case '\n':
+                        builder.Append("\\n");
+                        break;
+                    case '\r':
+                        builder.Append("\\r");
+                        break;
+                    case '\t':
+                        builder.Append("\\t");
+                        break;
+                    default:
+                        if (char.IsControl(character))
+                        {
+                            builder.Append("\\u").Append(((int)character).ToString("x4", CultureInfo.InvariantCulture));
+                        }
+                        else
+                        {
+                            builder.Append(character);
+                        }
+
+                        break;
+                }
+            }
+
+            return builder.ToString();
+        }
+    }
