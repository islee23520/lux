+fn validate_ai_log_project_scope(project_root: &Path, path: &Path) -> anyhow::Result<()> {
+    let scoped_path = canonical_existing_path_or_parent(path)?;
+    if scoped_path.starts_with(project_root) {
+        Ok(())
+    } else {
+        Err(anyhow::anyhow!(
+            "AI log path {} resolved outside configured project scope {}",
+            scoped_path.display(),
+            project_root.display()
+        ))
+    }
+}
+
+fn canonical_existing_path_or_parent(path: &Path) -> anyhow::Result<PathBuf> {
+    if path.exists() {
+        return path.canonicalize().map_err(|error| {
+            anyhow::anyhow!(
+                "failed to canonicalize AI log path {}: {error}",
+                path.display()
+            )
+        });
+    }
+
+    let mut ancestor = path.parent().ok_or_else(|| {
+        anyhow::anyhow!(
+            "AI log path {} does not have a parent directory",
+            path.display()
+        )
+    })?;
+    while !ancestor.exists() {
+        ancestor = ancestor.parent().ok_or_else(|| {
+            anyhow::anyhow!(
+                "AI log path {} does not have an existing ancestor",
+                path.display()
+            )
+        })?;
+    }
+
+    let canonical_ancestor = ancestor.canonicalize().map_err(|error| {
+        anyhow::anyhow!(
+            "failed to canonicalize AI log ancestor {}: {error}",
+            ancestor.display()
+        )
+    })?;
+    let remainder = path.strip_prefix(ancestor).map_err(|error| {
+        anyhow::anyhow!(
+            "failed to resolve AI log path {} against ancestor {}: {error}",
+            path.display(),
+            ancestor.display()
+        )
+    })?;
+    Ok(canonical_ancestor.join(remainder))
 }
 
