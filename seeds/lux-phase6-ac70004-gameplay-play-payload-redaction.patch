+pub fn redact_event_value_for_output(value: &Value) -> Value {
+    match value {
+        Value::String(text) => Value::String(redact_secrets(text)),
+        Value::Array(items) => Value::Array(items.iter().map(redact_event_value_for_output).collect()),
+        Value::Object(object) => Value::Object(
+            object
+                .iter()
+                .map(|(key, value)| {
+                    if is_sensitive_output_key(key) || is_gameplay_sensitive_output_key(key) {
+                        (key.clone(), Value::String("[REDACTED]".to_string()))
+                    } else {
+                        (key.clone(), redact_event_value_for_output(value))
+                    }
+                })
+                .collect(),
+        ),
+        other => other.clone(),
+    }
+}
+
+fn is_sensitive_output_key(key: &str) -> bool {
+    let normalized = normalize_output_key(key);
+    normalized.contains("token")
+        || normalized.contains("secret")
+        || normalized.contains("password")
+        || normalized.contains("authorization")
+        || normalized.contains("apikey")
+        || normalized.contains("credential")
+        || normalized.contains("privatekey")
+}
+
+fn is_gameplay_sensitive_output_key(key: &str) -> bool {
+    let normalized = normalize_output_key(key);
+    normalized.contains("playerid")
+        || normalized.contains("userid")
+        || normalized.contains("accountid")
+        || normalized.contains("profileid")
+        || normalized.contains("deviceid")
+        || normalized.contains("platformuserid")
+        || normalized.contains("playername")
+        || normalized.contains("username")
+        || normalized.contains("displayname")
+        || normalized.contains("chatmessage")
+        || normalized.contains("rawinput")
+        || normalized.contains("inputhistory")
+        || normalized.contains("savedata")
+        || normalized.contains("saveblob")
+        || normalized.contains("savefile")
+        || normalized.contains("inventory")
+        || normalized.contains("loadout")
+        || normalized.contains("wallet")
+        || normalized.contains("currency")
+        || normalized.contains("balance")
+        || normalized.contains("economy")
+        || normalized.contains("telemetry")
+        || normalized.contains("analyticspayload")
+        || normalized.contains("preciseposition")
+        || normalized.contains("coordinates")
+        || normalized.contains("geolocation")
+}
+
+fn normalize_output_key(key: &str) -> String {
+    key.chars()
+        .filter(|character| character.is_ascii_alphanumeric())
+        .map(|character| character.to_ascii_lowercase())
+        .collect()
+}
