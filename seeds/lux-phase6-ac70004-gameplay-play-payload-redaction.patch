@@ -0,0 +1,86 @@
+using System;
+using System.Collections.Generic;
+using System.IO;
+using Linalab.Lux.Runtime;
+using NUnit.Framework;
+
+namespace Linalab.LuxEditor.Tests
+{
+    public sealed class LuxRuntimeEventGameplayRedactionTests
+    {
+        string tempDirectory;
+
+        [SetUp]
+        public void SetUp()
+        {
+            tempDirectory = Path.Combine(Path.GetTempPath(), "LuxRuntimeEventGameplayRedactionTests", Guid.NewGuid().ToString("N"));
+            Directory.CreateDirectory(tempDirectory);
+            LuxRuntimeEvent.ConfigureForTests(
+                Path.Combine(tempDirectory, "UserSettings", "LuxAiActionLog.jsonl"),
+                tempDirectory,
+                () => new DateTime(2026, 5, 5, 13, 0, 0, DateTimeKind.Utc));
+        }
+
+        [TearDown]
+        public void TearDown()
+        {
+            LuxRuntimeEvent.ResetForTests();
+            if (!string.IsNullOrWhiteSpace(tempDirectory) && Directory.Exists(tempDirectory))
+            {
+                Directory.Delete(tempDirectory, true);
+            }
+        }
+
+        [Test]
+        public void Emit_RedactsGameplaySensitivePayloadFieldsButPreservesSafeStructure()
+        {
+            var record = LuxRuntimeEvent.Emit(
+                "quest_step_completed",
+                new Dictionary<string, object>
+                {
+                    ["questId"] = "quest-7",
+                    ["playerId"] = "player-secret-42",
+                    ["playerName"] = "Raw Player",
+                    ["saveData"] = new Dictionary<string, object>
+                    {
+                        ["slot"] = "slot-raw",
+                        ["checkpoint"] = "castle"
+                    },
+                    ["inventory"] = new[] { "gold-key", "rare-sword" },
+                    ["rawInput"] = "WASD enter",
+                    ["telemetryPayload"] = "{\"fps\":60,\"device\":\"private-device\"}",
+                    ["precisePosition"] = new Dictionary<string, object>
+                    {
+                        ["x"] = 12.25f,
+                        ["y"] = 0f,
+                        ["z"] = -4.5f
+                    }
+                },
+                "Quests/Quest-7",
+                "Quest step completed.");
+
+            string jsonl = File.ReadAllText(Path.Combine(tempDirectory, "UserSettings", "LuxAiActionLog.jsonl"));
+
+            Assert.That(record.payload.attributes["questId"], Is.EqualTo("quest-7"));
+            Assert.That(record.payload.attributes["playerId"], Is.EqualTo("[REDACTED]"));
+            Assert.That(record.payload.attributes["playerName"], Is.EqualTo("[REDACTED]"));
+            Assert.That(record.payload.attributes["rawInput"], Is.EqualTo("[REDACTED]"));
+            Assert.That(record.payload.attributes["telemetryPayload"], Is.EqualTo("[REDACTED]"));
+            Assert.That(record.payload.attributes, Does.ContainKey("saveData"));
+            Assert.That(record.payload.attributes, Does.ContainKey("inventory"));
+            Assert.That(jsonl, Does.Contain("\"questId\":\"quest-7\""));
+            Assert.That(jsonl, Does.Contain("\"playerId\":\"[REDACTED]\""));
+            Assert.That(jsonl, Does.Contain("\"saveData\":{\"slot\":\"[REDACTED]\",\"checkpoint\":\"[REDACTED]\"}"));
+            Assert.That(jsonl, Does.Contain("\"inventory\":[\"[REDACTED]\",\"[REDACTED]\"]"));
+            Assert.That(jsonl, Does.Contain("\"precisePosition\":{\"x\":\"[REDACTED]\",\"y\":\"[REDACTED]\",\"z\":\"[REDACTED]\"}"));
+            Assert.That(jsonl, Does.Contain("\"redactionClasses\":[\"gameplay-sensitive\"]"));
+            Assert.That(jsonl, Does.Contain("\"payload.attributes.playerId\""));
+            Assert.That(jsonl, Does.Contain("\"payload.attributes.saveData\""));
+            Assert.That(jsonl, Does.Not.Contain("player-secret-42"));
+            Assert.That(jsonl, Does.Not.Contain("Raw Player"));
+            Assert.That(jsonl, Does.Not.Contain("slot-raw"));
+            Assert.That(jsonl, Does.Not.Contain("gold-key"));
+            Assert.That(jsonl, Does.Not.Contain("private-device"));
+        }
+    }
+}
