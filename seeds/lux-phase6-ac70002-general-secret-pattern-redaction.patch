+fn redact_private_key_blocks(text: &str) -> String {
+    let mut output = String::with_capacity(text.len());
+    let mut remaining = text;
+
+    while let Some(begin) = find_ascii_case_insensitive(remaining, "-----begin ") {
+        let after_begin = &remaining[begin..];
+        let Some(key_suffix) = find_ascii_case_insensitive(after_begin, "private key-----") else {
+            break;
+        };
+        output.push_str(&remaining[..begin]);
+        output.push_str(REDACTED);
+
+        let after_begin_marker = begin + key_suffix + "private key-----".len();
+        let after_marker = &remaining[after_begin_marker..];
+        if let Some(end) = find_ascii_case_insensitive(after_marker, "-----end ") {
+            let after_end = &after_marker[end..];
+            if let Some(end_suffix) = find_ascii_case_insensitive(after_end, "private key-----") {
+                let resume = after_begin_marker + end + end_suffix + "private key-----".len();
+                remaining = &remaining[resume..];
+                continue;
+            }
+        }
+
+        remaining = "";
+        break;
+    }
+
+    output.push_str(remaining);
+    output
+}
+
+fn redact_authorization_values(text: &str) -> String {
+    let mut output = String::with_capacity(text.len());
+    let mut cursor = 0usize;
+
+    while let Some(relative) = find_ascii_case_insensitive(&text[cursor..], "authorization") {
+        let key_start = cursor + relative;
+        let key_end = key_start + "authorization".len();
+        if !is_boundary_before(text, key_start) || !is_boundary_after(text, key_end) {
+            output.push_str(&text[cursor..key_end]);
+            cursor = key_end;
+            continue;
+        }
+
+        let separator = skip_ascii_whitespace(text, key_end);
+        let Some(separator_char) = text[separator..].chars().next() else {
+            break;
+        };
+        if separator_char != ':' && separator_char != '=' {
+            output.push_str(&text[cursor..key_end]);
+            cursor = key_end;
+            continue;
+        }
+
+        let value_start = skip_ascii_whitespace(text, separator + separator_char.len_utf8());
+        let scheme_end = authorization_scheme_end(text, value_start);
+        let (content_start, content_end, resume) = secret_value_bounds(text, scheme_end, false);
+        output.push_str(&text[cursor..content_start]);
+        output.push_str(REDACTED);
+        if content_end < resume {
+            output.push_str(&text[content_end..resume]);
+        }
+        cursor = resume;
+    }
+
+    output.push_str(&text[cursor..]);
+    output
+}
+
+fn authorization_scheme_end(text: &str, value_start: usize) -> usize {
+    for scheme in ["bearer", "basic"] {
+        let scheme_end = value_start + scheme.len();
+        if text[value_start..]
+            .get(..scheme.len())
+            .is_some_and(|candidate| candidate.eq_ignore_ascii_case(scheme))
+            && text[scheme_end..]
+                .chars()
+                .next()
+                .is_some_and(|character| character.is_ascii_whitespace())
+        {
+            return skip_ascii_whitespace(text, scheme_end);
+        }
+    }
+
+    value_start
+}
+
+fn redact_bearer_values(text: &str) -> String {
+    let mut output = String::with_capacity(text.len());
+    let mut cursor = 0usize;
+
+    while let Some(relative) = find_ascii_case_insensitive(&text[cursor..], "bearer") {
+        let start = cursor + relative;
+        let end = start + "bearer".len();
+        if !is_boundary_before(text, start) || !is_boundary_after(text, end) {
+            output.push_str(&text[cursor..end]);
+            cursor = end;
+            continue;
+        }
+
+        let value_start = skip_ascii_whitespace(text, end);
+        if value_start == end {
+            output.push_str(&text[cursor..end]);
+            cursor = end;
+            continue;
+        }
+
+        if text[value_start..].starts_with(REDACTED) {
+            let value_end = value_start + REDACTED.len();
+            output.push_str(&text[cursor..value_end]);
+            cursor = value_end;
+            continue;
+        }
+
+        let value_end = secret_value_end(text, value_start, false);
+        output.push_str(&text[cursor..value_start]);
+        output.push_str(REDACTED);
+        cursor = value_end;
+    }
+
+    output.push_str(&text[cursor..]);
+    output
+}
+
+fn redact_sensitive_assignments(text: &str) -> String {
+    let mut output = String::with_capacity(text.len());
+    let mut cursor = 0usize;
+
+    while cursor < text.len() {
+        let Some((separator, separator_char)) = next_assignment_separator(text, cursor) else {
+            break;
+        };
+
+        let Some((key_start, key_end)) = key_bounds_before_separator(text, separator) else {
+            output.push_str(&text[cursor..separator + separator_char.len_utf8()]);
+            cursor = separator + separator_char.len_utf8();
+            continue;
+        };
+
+        let key = &text[key_start..key_end];
+        if !is_sensitive_key(key) {
+            output.push_str(&text[cursor..separator + separator_char.len_utf8()]);
+            cursor = separator + separator_char.len_utf8();
+            continue;
+        }
+
+        let value_start = skip_ascii_whitespace(text, separator + separator_char.len_utf8());
+        let (content_start, content_end, resume) =
+            secret_value_bounds(text, value_start, is_connection_key(key));
+        output.push_str(&text[cursor..content_start]);
+        output.push_str(REDACTED);
+        if content_end < resume {
+            output.push_str(&text[content_end..resume]);
+        }
+        cursor = resume;
+    }
+
+    output.push_str(&text[cursor..]);
+    output
+}
+
+fn redact_credential_urls(text: &str) -> String {
+    let mut output = String::with_capacity(text.len());
+    let mut cursor = 0usize;
+
+    while let Some(relative) = text[cursor..].find("://") {
+        let scheme_end = cursor + relative;
+        let scheme_start = scan_scheme_start(text, scheme_end);
+        let after_scheme = scheme_end + 3;
+        if scheme_start == scheme_end || !is_sensitive_url_scheme(&text[scheme_start..scheme_end])
+        {
+            output.push_str(&text[cursor..after_scheme]);
+            cursor = after_scheme;
+            continue;
+        }
+
+        let url_end = secret_value_end(text, after_scheme, true);
+        let url_body = &text[after_scheme..url_end];
+        let has_userinfo = url_body
+            .find('@')
+            .is_some_and(|at| url_body[..at].contains(':'));
+        if !has_userinfo {
+            output.push_str(&text[cursor..after_scheme]);
+            cursor = after_scheme;
+            continue;
+        }
+
+        output.push_str(&text[cursor..scheme_start]);
+        output.push_str(REDACTED);
+        cursor = url_end;
+    }
+
+    output.push_str(&text[cursor..]);
+    output
+}
+
+fn next_assignment_separator(text: &str, cursor: usize) -> Option<(usize, char)> {
+    text[cursor..]
+        .char_indices()
+        .find_map(|(relative, character)| {
+            (character == ':' || character == '=').then_some((cursor + relative, character))
+        })
+}
+
+fn key_bounds_before_separator(text: &str, separator: usize) -> Option<(usize, usize)> {
+    let before_separator = text[..separator].trim_end();
+    let mut key_end = before_separator.len();
+    if key_end == 0 {
+        return None;
+    }
+
+    if before_separator[..key_end].ends_with('"') || before_separator[..key_end].ends_with('\'') {
+        let quote = before_separator[..key_end].chars().next_back()?;
+        key_end -= quote.len_utf8();
+        let key_start = before_separator[..key_end].rfind(quote)? + quote.len_utf8();
+        return (key_start < key_end).then_some((key_start, key_end));
+    }
+
+    let key_start = before_separator[..key_end]
+        .char_indices()
+        .rev()
+        .find_map(|(index, character)| {
+            (!is_key_character(character)).then_some(index + character.len_utf8())
+        })
+        .unwrap_or(0);
+    (key_start < key_end).then_some((key_start, key_end))
+}
+
+fn secret_value_bounds(
+    text: &str,
+    value_start: usize,
+    allow_semicolons: bool,
+) -> (usize, usize, usize) {
+    let Some(first) = text[value_start..].chars().next() else {
+        return (value_start, value_start, value_start);
+    };
+
+    if first == '"' || first == '\'' {
+        let content_start = value_start + first.len_utf8();
+        if let Some(relative_end) = text[content_start..].find(first) {
+            let content_end = content_start + relative_end;
+            return (content_start, content_end, content_end + first.len_utf8());
+        }
+
+        return (content_start, text.len(), text.len());
+    }
+
+    let value_end = secret_value_end(text, value_start, allow_semicolons);
+    (value_start, value_end, value_end)
+}
+
+fn secret_value_end(text: &str, start: usize, allow_semicolons: bool) -> usize {
+    text[start..]
+        .char_indices()
+        .find_map(|(relative, character)| {
+            (character.is_whitespace()
+                || character == ','
+                || character == '"'
+                || character == '\''
+                || character == '}'
+                || character == ']'
+                || character == '&'
+                || (!allow_semicolons && character == ';'))
+            .then_some(start + relative)
+        })
+        .unwrap_or(text.len())
+}
+
+fn skip_ascii_whitespace(text: &str, start: usize) -> usize {
+    text[start..]
+        .char_indices()
+        .find_map(|(relative, character)| {
+            (!character.is_ascii_whitespace()).then_some(start + relative)
+        })
+        .unwrap_or(text.len())
+}
+
+fn scan_scheme_start(text: &str, scheme_end: usize) -> usize {
+    text[..scheme_end]
+        .char_indices()
+        .rev()
+        .find_map(|(index, character)| {
+            (!character.is_ascii_alphanumeric()
+                && character != '+'
+                && character != '.'
+                && character != '-')
+            .then_some(index + character.len_utf8())
+        })
+        .unwrap_or(0)
+}
+
+fn find_ascii_case_insensitive(haystack: &str, needle: &str) -> Option<usize> {
+    haystack
+        .to_ascii_lowercase()
+        .find(&needle.to_ascii_lowercase())
+}
+
+fn is_boundary_before(text: &str, index: usize) -> bool {
+    text[..index]
+        .chars()
+        .next_back()
+        .map_or(true, |character| !is_key_character(character))
+}
+
+fn is_boundary_after(text: &str, index: usize) -> bool {
+    text[index..]
+        .chars()
+        .next()
+        .map_or(true, |character| !is_key_character(character))
+}
+
+fn is_key_character(character: char) -> bool {
+    character.is_ascii_alphanumeric() || character == '_' || character == '-' || character == '.'
+}
+
+fn is_sensitive_key(key: &str) -> bool {
+    let normalized = normalize_key(key);
+    normalized.contains("token")
+        || normalized.contains("secret")
+        || normalized.contains("password")
+        || normalized.contains("passwd")
+        || normalized == "pwd"
+        || normalized.contains("credential")
+        || normalized.contains("privatekey")
+        || normalized.contains("apikey")
+        || normalized.contains("connectionstring")
+        || normalized.contains("connstring")
+        || normalized.contains("databaseurl")
+        || normalized == "dburl"
+        || normalized == "dsn"
+}
+
+fn is_connection_key(key: &str) -> bool {
+    let normalized = normalize_key(key);
+    normalized.contains("connectionstring")
+        || normalized.contains("connstring")
+        || normalized.contains("databaseurl")
+        || normalized == "dburl"
+        || normalized == "dsn"
+}
+
+fn is_sensitive_url_scheme(scheme: &str) -> bool {
+    matches!(
+        scheme.to_ascii_lowercase().as_str(),
+        "http"
+            | "https"
+            | "postgres"
+            | "postgresql"
+            | "mysql"
+            | "mariadb"
+            | "redis"
+            | "rediss"
+            | "mongodb"
+            | "amqp"
+            | "amqps"
+            | "smtp"
+            | "smtps"
+    )
+}
+
+fn normalize_key(key: &str) -> String {
+    key.chars()
+        .filter(|character| character.is_ascii_alphanumeric())
+        .flat_map(char::to_lowercase)
+        .collect()
+}
