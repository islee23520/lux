diff --git a/RustGateway~/src/project_metadata.rs b/RustGateway~/src/project_metadata.rs
--- a/RustGateway~/src/project_metadata.rs
+++ b/RustGateway~/src/project_metadata.rs
@@ -315,2 +315,266 @@ fn sanitize_project_signal_value_for_key(key: &str, value: &Value) -> Value {
     if looks_sensitive_key(key) {
         return Value::String("[REDACTED]".to_string());
+    }
+    sanitize_project_signal_value(value)
+}
+
+fn redact_project_signal_text(text: &str) -> String {
+    ai_log::redact_secrets(text)
+}
+
+fn looks_sensitive_key(key: &str) -> bool {
+    let normalized = key.to_ascii_lowercase();
+    normalized.contains("token")
+        || normalized.contains("secret")
+        || normalized.contains("password")
+        || normalized.contains("api_key")
+        || normalized.contains("apikey")
+        || normalized.contains("accesskey")
+        || normalized.contains("privatekey")
+        || normalized.contains("credential")
+}
+
+#[cfg(test)]
+mod tests {
+    use super::*;
+
+    use std::{
+        fs,
+        path::{Path, PathBuf},
+        time::{SystemTime, UNIX_EPOCH},
+    };
+
+    #[test]
+    fn detects_urp_lux_android_project_from_fixture_files() {
+        let project = create_fixture_project("urp-lux-android");
+        create_unity_project_dirs(&project);
+        write_project_version(&project, "6000.3.0f1");
+        write_package_manifest(
+            &project,
+            r#"{
+  "dependencies": {
+    "com.linalab.lux": "file:Packages/com.linalab.lux",
+    "com.unity.render-pipelines.universal": "17.0.3",
+    "com.example.tokenized": "https://packages.example.invalid/feed?token=raw-secret"
+  },
+  "scopedRegistries": [
+    {
+      "name": "Private Registry",
+      "url": "https://registry.example.invalid/npm?token=registry-secret",
+      "scopes": ["com.example"]
+    }
+  ]
+}"#,
+        );
+        write_project_settings(
+            &project,
+            "%YAML 1.1
+PlayerSettings:
+  companyName: Linalab
+  productName: LUX URP Fixture
+  bundleVersion: 1.2.3
+  activeColorSpace: 1
+  defaultScreenOrientation: 4
+  AndroidTargetArchitectures: 5
+",
+        );
+        write_project_settings_file(
+            &project,
+            "GraphicsSettings.asset",
+            "m_CustomRenderPipeline: {fileID: 0}\n",
+        );
+        write_project_settings_file(
+            &project,
+            "EditorBuildSettings.asset",
+            "Standalone\nAndroid\niPhone\n",
+        );
+        fs::create_dir_all(project.join(".lux/skills")).expect("create project skills dir");
+        fs::create_dir_all(project.join("UserSettings")).expect("create UserSettings dir");
+        fs::write(project.join("UserSettings/LuxAiActionLog.jsonl"), "")
+            .expect("write AI action log fixture");
+        fs::create_dir_all(project.join("Library/UnityAiBridge"))
+            .expect("create UnityAiBridge dir");
+        fs::write(project.join("Library/UnityAiBridge/server.json"), "{}")
+            .expect("write bridge discovery fixture");
+        fs::write(project.join("ProjectSettings/LuxSettings.json"), "{}")
+            .expect("write LUX settings fixture");
+
+        let metadata = collect_project_metadata_signals(&project);
+
+        assert_eq!(metadata["schema"], "lux.project_metadata_signals.v1");
+        assert_eq!(metadata["collection"]["mode"], "offline_file_scan");
+        assert_eq!(metadata["collection"]["requires_unity_editor"], false);
+        assert_eq!(metadata["unity"]["version"], "6000.3.0f1");
+        assert_eq!(
+            metadata["package_manifest"]["lux_package"]["version_or_source"],
+            "file:Packages/com.linalab.lux"
+        );
+        assert_eq!(
+            metadata["package_manifest"]["dependencies"]["com.example.tokenized"],
+            "[REDACTED]"
+        );
+        assert_eq!(
+            metadata["package_manifest"]["scoped_registries"][0]["url"],
+            "[REDACTED]"
+        );
+        assert_eq!(metadata["render_pipeline"]["pipeline"], "urp");
+        assert_eq!(metadata["enabled_lux_features"]["package_dependency"], true);
+        assert_eq!(metadata["enabled_lux_features"]["project_skills_directory"], true);
+        assert_eq!(metadata["enabled_lux_features"]["ai_action_log"], true);
+        assert_eq!(
+            metadata["enabled_lux_features"]["unity_ai_bridge_discovery"],
+            true
+        );
+        assert_eq!(metadata["enabled_lux_features"]["project_lux_settings"], true);
+        assert_eq!(
+            metadata["project_settings"]["project_settings"]["signals"]["productName"],
+            "LUX URP Fixture"
+        );
+        assert_platform_targets(&metadata, &["android", "ios", "standalone"]);
+        assert!(
+            !metadata.to_string().contains("raw-secret"),
+            "metadata must not expose raw dependency secrets"
+        );
+        assert!(
+            !metadata.to_string().contains("registry-secret"),
+            "metadata must not expose raw scoped registry secrets"
+        );
+    }
+
+    #[test]
+    fn detects_hdrp_from_graphics_settings_without_lux_package() {
+        let project = create_fixture_project("hdrp-graphics-settings");
+        create_unity_project_dirs(&project);
+        write_project_version(&project, "2022.3.45f1");
+        write_package_manifest(
+            &project,
+            r#"{
+  "dependencies": {
+    "com.unity.modules.ai": "1.0.0"
+  }
+}"#,
+        );
+        write_project_settings(
+            &project,
+            "%YAML 1.1
+PlayerSettings:
+  companyName: Linalab
+  productName: HDRP Fixture
+  bundleVersion: 2.0.0
+",
+        );
+        write_project_settings_file(
+            &project,
+            "GraphicsSettings.asset",
+            "m_CustomRenderPipeline: {fileID: 11400000, type: 2}\nHDRenderPipelineAsset\n",
+        );
+        write_project_settings_file(&project, "EditorBuildSettings.asset", "WebGL\nVisionOS\n");
+
+        let metadata = collect_project_metadata_signals(&project);
+
+        assert_eq!(metadata["unity"]["version"], "2022.3.45f1");
+        assert_eq!(
+            metadata["package_manifest"]["lux_package"]["present"],
+            false
+        );
+        assert_eq!(metadata["enabled_lux_features"]["package_dependency"], false);
+        assert_eq!(metadata["enabled_lux_features"]["ai_action_log"], false);
+        assert_eq!(metadata["render_pipeline"]["pipeline"], "hdrp");
+        assert!(
+            metadata["render_pipeline"]["evidence"]
+                .as_array()
+                .expect("render pipeline evidence array")
+                .contains(&Value::String(
+                    "ProjectSettings/GraphicsSettings.asset:HDRenderPipelineAsset".to_string()
+                ))
+        );
+        assert_platform_targets(&metadata, &["visionos", "webgl"]);
+        assert_eq!(
+            metadata["project_settings"]["project_settings"]["signals"]["productName"],
+            "HDRP Fixture"
+        );
+    }
+
+    #[test]
+    fn reports_minimal_builtin_project_with_missing_optional_metadata() {
+        let project = create_fixture_project("minimal-built-in");
+        create_unity_project_dirs(&project);
+        write_project_version(&project, "2021.3.39f1");
+
+        let metadata = collect_project_metadata_signals(&project);
+
+        assert_eq!(metadata["unity"]["available"], true);
+        assert_eq!(metadata["unity"]["version"], "2021.3.39f1");
+        assert_eq!(metadata["package_manifest"]["available"], false);
+        assert!(
+            metadata["package_manifest"]["warning"]
+                .as_str()
+                .expect("package manifest warning")
+                .contains("failed to read Packages/manifest.json")
+        );
+        assert_eq!(metadata["render_pipeline"]["pipeline"], "built-in-or-unknown");
+        assert_platform_targets(&metadata, &[]);
+        assert_eq!(
+            metadata["project_settings"]["project_settings"]["available"],
+            false
+        );
+        assert_eq!(
+            metadata["project_settings"]["graphics_settings"]["available"],
+            false
+        );
+        assert_eq!(metadata["enabled_lux_features"]["package_dependency"], false);
+        assert_eq!(metadata["enabled_lux_features"]["project_skills_directory"], false);
+    }
+
+    fn create_fixture_project(name: &str) -> PathBuf {
+        let nanos = SystemTime::now()
+            .duration_since(UNIX_EPOCH)
+            .expect("system clock is after Unix epoch")
+            .as_nanos();
+        let root = std::env::temp_dir().join(format!(
+            "lux-project-metadata-{name}-{}-{nanos}",
+            std::process::id()
+        ));
+        fs::create_dir_all(&root).expect("create fixture project root");
+        root
+    }
+
+    fn create_unity_project_dirs(project: &Path) {
+        fs::create_dir_all(project.join("Assets")).expect("create Assets dir");
+        fs::create_dir_all(project.join("Packages")).expect("create Packages dir");
+        fs::create_dir_all(project.join("ProjectSettings")).expect("create ProjectSettings dir");
+    }
+
+    fn write_project_version(project: &Path, version: &str) {
+        fs::write(
+            project.join("ProjectSettings/ProjectVersion.txt"),
+            format!("m_EditorVersion: {version}\nm_EditorVersionWithRevision: {version} (abcdef123456)\n"),
+        )
+        .expect("write ProjectVersion.txt");
+    }
+
+    fn write_package_manifest(project: &Path, contents: &str) {
+        fs::write(project.join("Packages/manifest.json"), contents)
+            .expect("write Packages/manifest.json");
+    }
+
+    fn write_project_settings(project: &Path, contents: &str) {
+        write_project_settings_file(project, "ProjectSettings.asset", contents);
+    }
+
+    fn write_project_settings_file(project: &Path, file_name: &str, contents: &str) {
+        fs::write(project.join("ProjectSettings").join(file_name), contents)
+            .expect("write ProjectSettings fixture file");
+    }
+
+    fn assert_platform_targets(metadata: &Value, expected: &[&str]) {
+        let mut actual = metadata["platform_targets"]["declared_or_referenced"]
+            .as_array()
+            .expect("platform targets array")
+            .iter()
+            .map(|value| value.as_str().expect("platform target string"))
+            .collect::<Vec<_>>();
+        actual.sort_unstable();
+        assert_eq!(actual, expected);
+    }
+}
