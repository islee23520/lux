+test('tools/call AI work steps reads only the configured project log', async () => {
+  await withTempProject(async (projectRoot) => {
+    await withTempProject(async (otherProjectRoot) => {
+      writeAiWorkStepLog(projectRoot, [
+        JSON.stringify({
+          timestampUtc: '2026-05-04T00:00:02Z',
+          id: 'configured-second',
+          source: 'codex',
+          actor: 'codex',
+          category: 'ai-action-log',
+          type: 'tool.patch.completed',
+          payload: { kind: 'ai-work-step', stepName: 'apply_patch', status: 'completed', summary: 'configured second', ordering: { sequence: 2 } },
+        }),
+        JSON.stringify({
+          timestampUtc: '2026-05-04T00:00:01Z',
+          id: 'configured-first',
+          source: 'codex',
+          actor: 'codex',
+          category: 'ai-action-log',
+          type: 'tool.read.completed',
+          payload: { kind: 'ai-work-step', stepName: 'read', status: 'completed', summary: 'configured first', ordering: { sequence: 1 } },
+        }),
+      ]);
+      writeAiWorkStepLog(otherProjectRoot, [
+        JSON.stringify({
+          timestampUtc: '2026-05-04T00:00:01Z',
+          id: 'other-project-step',
+          source: 'codex',
+          actor: 'codex',
+          category: 'ai-action-log',
+          type: 'tool.read.completed',
+          payload: { kind: 'ai-work-step', stepName: 'read', status: 'completed', summary: 'other project', ordering: { sequence: 1 } },
+        }),
+      ]);
+
+      const { parsed, serialized } = await readAiWorkStepsTool(projectRoot, 10);
+
+      assert.equal(parsed.projectPath, projectRoot);
+      assert.equal(parsed.path, path.join(projectRoot, 'UserSettings', 'LuxAiActionLog.jsonl'));
+      assert.equal(parsed.pathSource, 'project');
+      assert.equal(parsed.count, 2);
+      assert.deepEqual(parsed.entries.map((entry) => entry.id), ['configured-first', 'configured-second']);
+      assert.ok(!serialized.includes('other-project-step'));
+      assert.ok(!serialized.includes('other project'));
+      assert.ok(fs.existsSync(path.join(otherProjectRoot, 'UserSettings', 'LuxAiActionLog.jsonl')));
+    });
+  });
+});
