+interface AiWorkStepsToolResponse {
+  protocol: string;
+  surface: string;
+  projectPath: string;
+  path: string;
+  pathSource: string;
+  limit: number;
+  count: number;
+  warningCount: number;
+  entries: Array<{
+    id: string;
+    sequence: number;
+    stepName: string;
+    summary: string;
+    value: {
+      payload?: {
+        credentials?: unknown;
+      };
+    };
+  }>;
+  warnings: Array<{
+    lineNumber: number;
+    reason: string;
+  }>;
+}
+
+async function readAiWorkStepsTool(
+  projectRoot: string,
+  limit?: number,
+): Promise<{ parsed: AiWorkStepsToolResponse; serialized: string }> {
+  const pair = await connectMcpServer(projectRoot);
+
+  try {
+    const result = await pair.client.callTool({
+      name: LUX_AI_WORK_STEPS_TOOL_NAME,
+      arguments: limit === undefined ? {} : { limit },
+    });
+    const content = (result as { content: Array<{ type: string; text?: string }> }).content;
+    const serialized = content[0]?.text ?? '{}';
+
+    return {
+      parsed: JSON.parse(serialized) as AiWorkStepsToolResponse,
+      serialized,
+    };
+  } finally {
+    await pair.close();
+  }
+}
+
+function writeAiWorkStepLog(projectRoot: string, lines: string[]): void {
+  const logDirectory = path.join(projectRoot, 'UserSettings');
+  fs.mkdirSync(logDirectory, { recursive: true });
+  fs.writeFileSync(path.join(logDirectory, 'LuxAiActionLog.jsonl'), `${lines.join('\n')}\n`, 'utf8');
+}
