+#[test]
+fn ai_log_work_steps_json_handles_empty_and_invalid_logs() {
+    let empty_project = create_ai_work_step_project_with_log("lux-ai-log-work-steps-empty", "");
+    let empty_output = Command::new(env!("CARGO_BIN_EXE_lux"))
+        .args([
+            "ai-log",
+            "work-steps",
+            "--project-path",
+            empty_project.to_str().expect("project path UTF-8"),
+            "--limit",
+            "10",
+            "--json",
+        ])
+        .output()
+        .expect("run lux ai-log work-steps on empty log");
+
+    assert_command_success(&empty_output, "lux ai-log work-steps empty");
+    let empty: Value = serde_json::from_slice(&empty_output.stdout).expect("empty work steps JSON");
+    assert_eq!(empty["count"], 0);
+    assert_eq!(empty["warningCount"], 0);
+    assert!(empty["entries"].as_array().unwrap().is_empty());
+    assert!(empty["warnings"].as_array().unwrap().is_empty());
+
+    let invalid_project = create_ai_work_step_project_with_log(
+        "lux-ai-log-work-steps-invalid",
+        concat!(
+            "not-json\n",
+            "\n",
+            r#"{"payload":{"kind":"editor-user-action"}}"#,
+            "\n",
+        ),
+    );
+    let invalid_output = Command::new(env!("CARGO_BIN_EXE_lux"))
+        .args([
+            "ai-log",
+            "work-steps",
+            "--project-path",
+            invalid_project.to_str().expect("project path UTF-8"),
+            "--limit",
+            "10",
+            "--json",
+        ])
+        .output()
+        .expect("run lux ai-log work-steps on invalid log");
+
+    assert_command_success(&invalid_output, "lux ai-log work-steps invalid");
+    let invalid: Value =
+        serde_json::from_slice(&invalid_output.stdout).expect("invalid work steps JSON");
+    assert_eq!(invalid["count"], 0);
+    assert_eq!(invalid["warningCount"], 2);
+    assert!(invalid["entries"].as_array().unwrap().is_empty());
+    assert_eq!(invalid["warnings"][0]["lineNumber"], 1);
+    assert_eq!(invalid["warnings"][1]["lineNumber"], 3);
+}
