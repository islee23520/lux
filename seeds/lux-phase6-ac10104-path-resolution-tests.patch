+#[test]
+fn ai_log_recent_json_reads_default_user_settings_path() {
+    let nanos = SystemTime::now()
+        .duration_since(UNIX_EPOCH)
+        .expect("system time after Unix epoch")
+        .as_nanos();
+    let project_root = std::env::temp_dir()
+        .join(format!(
+            "lux-ai-log-default-path-{}-{nanos}",
+            std::process::id()
+        ))
+        .join("Project");
+    let log_path = project_root.join("UserSettings/LuxAiActionLog.jsonl");
+    fs::create_dir_all(log_path.parent().expect("default log parent"))
+        .expect("create default log directory");
+    fs::write(
+        &log_path,
+        "{\"timestampUtc\":\"2026-05-04T00:00:04Z\",\"actor\":\"codex\",\"category\":\"ai-action-log\",\"source\":\"cli\",\"action\":\"default-path\",\"eventType\":\"append\",\"summary\":\"default path event\"}\n",
+    )
+    .expect("write default AI log fixture");
+
+    let output = Command::new(env!("CARGO_BIN_EXE_lux"))
+        .args([
+            "ai-log",
+            "recent",
+            "--project-path",
+            project_root.to_str().expect("project path UTF-8"),
+            "--limit",
+            "5",
+            "--json",
+        ])
+        .env_remove("LUX_AI_ACTION_LOG_PATH")
+        .output()
+        .expect("run lux ai-log recent with default path");
+
+    assert_command_success(&output, "lux ai-log recent default path");
+    let parsed: Value = serde_json::from_slice(&output.stdout).expect("default JSON");
+    assert_eq!(parsed["path"], log_path.to_string_lossy().as_ref());
+    assert_eq!(parsed["count"], 1);
+    assert_eq!(parsed["entries"][0]["value"]["action"], "default-path");
+}
