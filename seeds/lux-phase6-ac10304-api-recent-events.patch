+async fn read_recent_ai_log(
+    State(state): State<GatewayState>,
+    headers: HeaderMap,
+    Query(query): Query<AiLogRecentQuery>,
+) -> Result<Json<AiLogRecentResponse>, Response> {
+    require_token(&state, &headers)?;
+    let request = parse_ai_log_recent_request(&state, query)?;
+    if !request.path.exists() {
+        return Ok(Json(build_ai_log_recent_response(&request, Vec::new())));
+    }
+
+    let limit = request.filter.limit.unwrap_or(AI_LOG_DEFAULT_LIMIT);
+    let read_filter = AiLogFilter {
+        limit: None,
+        actor: request.filter.actor.clone(),
+        category: request.filter.category.clone(),
+        source: request.filter.source.clone(),
+        action: request.filter.action.clone(),
+        event_type: request.filter.event_type.clone(),
+    };
+    let entries = ai_log::read_log_entries(&request.path, &read_filter).map_err(internal_error)?;
+    let entries = recent_entries(entries, limit)
+        .into_iter()
+        .map(redact_ai_log_recent_entry)
+        .collect();
+
+    Ok(Json(build_ai_log_recent_response(&request, entries)))
+}
