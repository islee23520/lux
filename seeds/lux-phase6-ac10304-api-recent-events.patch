+
+fn parse_ai_log_recent_request(
+    state: &GatewayState,
+    query: AiLogRecentQuery,
+) -> Result<AiLogRecentRequest, Response> {
+    let project_root = resolve_ai_log_recent_project_root(state, query.project_path.clone())?;
+    let path = ai_log::ensure_log_path(&project_root).map_err(internal_error)?;
+    Ok(AiLogRecentRequest {
+        project_root,
+        path,
+        filter: ai_log_recent_filter(query),
+    })
+}
+
+fn resolve_ai_log_recent_project_root(
+    state: &GatewayState,
+    requested_project_path: Option<PathBuf>,
+) -> Result<PathBuf, Response> {
+    let project_root = match requested_project_path {
+        Some(path) => canonicalize_ai_log_unity_project_path(&path)?,
+        None => {
+            let Some(configured_project_root) = state.config.project_root.as_ref() else {
+                return Err((
+                    StatusCode::SERVICE_UNAVAILABLE,
+                    "project path is not configured",
+                )
+                    .into_response());
+            };
+            canonicalize_ai_log_unity_project_path(configured_project_root)?
+        }
+    };
+
+    if let Some(configured_project_root) = state.config.project_root.as_ref() {
+        let configured_project_root =
+            canonicalize_ai_log_unity_project_path(configured_project_root)?;
+        if configured_project_root != project_root {
+            return Err((
+                StatusCode::FORBIDDEN,
+                "requested project path is outside the configured project scope",
+            )
+                .into_response());
+        }
+    }
+
+    Ok(project_root)
+}
+
+fn canonicalize_ai_log_unity_project_path(path: &Path) -> Result<PathBuf, Response> {
+    if path.as_os_str().is_empty() {
+        return Err((StatusCode::BAD_REQUEST, "project path is required").into_response());
+    }
+
+    let project_root = path.canonicalize().map_err(|_| {
+        (
+            StatusCode::BAD_REQUEST,
+            "project path must be an accessible Unity project directory",
+        )
+            .into_response()
+    })?;
+
+    if !project_root.is_dir()
+        || !project_root.join("Assets").is_dir()
+        || !project_root.join("ProjectSettings").is_dir()
+    {
+        return Err((
+            StatusCode::BAD_REQUEST,
+            "project path must contain Assets and ProjectSettings directories",
+        )
+            .into_response());
+    }
+
+    Ok(project_root)
+}
+
+fn ai_log_recent_filter(query: AiLogRecentQuery) -> AiLogFilter {
+    AiLogFilter {
+        limit: Some(clamp_ai_log_limit(query.limit)),
+        actor: query.actor,
+        category: query.category,
+        source: query.source,
+        action: query.action,
+        event_type: query.event_type,
+    }
+}
+
+fn recent_entries(mut entries: Vec<AiLogEntry>, limit: usize) -> Vec<AiLogEntry> {
+    entries.sort_by(|left, right| {
+        left.timestamp
+            .cmp(&right.timestamp)
+            .then(left.line_number.cmp(&right.line_number))
+    });
+
+    if entries.len() > limit {
+        entries = entries.split_off(entries.len() - limit);
+    }
+
+    entries
+}
+
+fn build_ai_log_recent_response(
+    request: &AiLogRecentRequest,
+    entries: Vec<AiLogRecentEntry>,
+) -> AiLogRecentResponse {
+    AiLogRecentResponse {
+        schema_version: 1,
+        protocol: "lux.ai_log.recent.v1",
+        project_path: request.project_root.display().to_string(),
+        path: request.path.display().to_string(),
+        limit: request.filter.limit.unwrap_or(AI_LOG_DEFAULT_LIMIT),
+        filters: AiLogRecentFilters {
+            actor: request.filter.actor.clone(),
+            category: request.filter.category.clone(),
+            source: request.filter.source.clone(),
+            action: request.filter.action.clone(),
+            event_type: request.filter.event_type.clone(),
+        },
+        count: entries.len(),
+        entries,
+    }
+}
+
+fn redact_ai_log_recent_entry(entry: AiLogEntry) -> AiLogRecentEntry {
+    AiLogRecentEntry {
+        line_number: entry.line_number,
+        timestamp_utc: redact_ai_log_response_text(&entry.timestamp),
+        value: redact_ai_log_response_value(&entry.value),
+    }
+}
+
+fn redact_ai_log_response_value(value: &serde_json::Value) -> serde_json::Value {
+    match value {
+        serde_json::Value::String(text) => {
+            serde_json::Value::String(redact_ai_log_response_text(text))
+        }
+        serde_json::Value::Array(items) => {
+            serde_json::Value::Array(items.iter().map(redact_ai_log_response_value).collect())
+        }
+        serde_json::Value::Object(object) => serde_json::Value::Object(
+            object
+                .iter()
+                .map(|(key, value)| {
+                    if is_sensitive_ai_log_response_key(key) {
+                        (
+                            key.clone(),
+                            serde_json::Value::String("[REDACTED]".to_string()),
+                        )
+                    } else {
+                        (key.clone(), redact_ai_log_response_value(value))
+                    }
+                })
+                .collect(),
+        ),
+        other => other.clone(),
+    }
+}
+
+fn is_sensitive_ai_log_response_key(key: &str) -> bool {
+    let key = key.to_ascii_lowercase();
+    key.contains("token")
+        || key.contains("secret")
+        || key.contains("password")
+        || key.contains("authorization")
+        || key.contains("api_key")
+        || key.contains("apikey")
+}
+
+fn redact_ai_log_response_text(text: &str) -> String {
+    let mut redact_next = false;
+    text.split_whitespace()
+        .map(|part| {
+            if redact_next {
+                redact_next = false;
+                "[REDACTED]".to_string()
+            } else if part.eq_ignore_ascii_case("bearer") {
+                redact_next = true;
+                "[REDACTED]".to_string()
+            } else {
+                ai_log::redact_secrets(part)
+            }
+        })
+        .collect::<Vec<_>>()
+        .join(" ")
 }
 
