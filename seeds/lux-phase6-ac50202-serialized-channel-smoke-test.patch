+using System;
+using System.Collections.Generic;
+using System.IO;
+using Linalab.Lux.Runtime;
+using NUnit.Framework;
+using UnityEditor;
+using UnityEngine;
+
+namespace Linalab.LuxEditor.Tests
+{
+    public sealed class LuxRuntimeEventSerializedChannelSmokeTests
+    {
+        string tempDirectory;
+
+        [SetUp]
+        public void SetUp()
+        {
+            tempDirectory = Path.Combine(Path.GetTempPath(), "LuxRuntimeEventSerializedChannelSmokeTests", Guid.NewGuid().ToString("N"));
+            Directory.CreateDirectory(tempDirectory);
+            LuxRuntimeEvent.ConfigureForTests(
+                null,
+                tempDirectory,
+                () => new DateTime(2026, 5, 5, 12, 45, 0, DateTimeKind.Utc));
+        }
+
+        [TearDown]
+        public void TearDown()
+        {
+            LuxRuntimeEvent.ResetForTests();
+            if (!string.IsNullOrWhiteSpace(tempDirectory) && Directory.Exists(tempDirectory))
+            {
+                Directory.Delete(tempDirectory, true);
+            }
+        }
+
+        [Test]
+        public void SerializedChannelSmokeSample_EmitsUnifiedRuntimeEventSchema()
+        {
+            string projectRoot = Path.Combine(tempDirectory, "Project");
+            string logPath = Path.Combine(projectRoot, "UserSettings", "LuxAiActionLog.jsonl");
+            var configuredChannel = ScriptableObject.CreateInstance<LuxRuntimeEventChannel>();
+            var serializedChannel = ScriptableObject.CreateInstance<LuxRuntimeEventChannel>();
+            var sampleObject = new GameObject("LuxRuntimeEventSerializedChannelSmokeSample");
+
+            try
+            {
+                configuredChannel.Configure(
+                    "checkpoint_reached",
+                    "Checkpoints/Finish",
+                    "Serialized channel smoke sample emitted checkpoint.",
+                    projectRoot,
+                    logPath,
+                    new[]
+                    {
+                        new LuxRuntimeEventChannelMetadata("sample", "serialized-channel-smoke"),
+                        new LuxRuntimeEventChannelMetadata("scenePath", "Assets/Scenes/Checkpoint.unity")
+                    },
+                    new[]
+                    {
+                        LuxRuntimeEventChannelAttribute.String("checkpointId", "finish"),
+                        LuxRuntimeEventChannelAttribute.Float("elapsedSeconds", 42.5f),
+                        LuxRuntimeEventChannelAttribute.Integer("scoreValue", 500),
+                        LuxRuntimeEventChannelAttribute.Boolean("isFinal", true),
+                        LuxRuntimeEventChannelAttribute.Vector3("position", new Vector3(4.5f, 1f, -2.25f))
+                    });
+                EditorJsonUtility.FromJsonOverwrite(EditorJsonUtility.ToJson(configuredChannel), serializedChannel);
+
+                var emitter = sampleObject.AddComponent<LuxRuntimeEventChannelEmitter>();
+                emitter.Configure(
+                    serializedChannel,
+                    null,
+                    null,
+                    null,
+                    new[] { LuxRuntimeEventChannelAttribute.String("trigger", "serialized-component") });
+
+                var record = emitter.Emit();
+                string[] lines = File.ReadAllLines(logPath);
+                var decoded = JsonUtility.FromJson<LuxRuntimeEventSerializedChannelSmokeRecord>(lines[0]);
+
+                Assert.That(lines, Has.Length.EqualTo(1));
+                Assert.That(record.schemaVersion, Is.EqualTo(1));
+                Assert.That(record.protocol, Is.EqualTo("lux.ai.action_log.v1"));
+                Assert.That(record.timestampUtc, Is.EqualTo("2026-05-05T12:45:00.0000000Z"));
+                Assert.That(record.projectPath, Is.EqualTo(projectRoot));
+                Assert.That(record.source, Is.EqualTo("unity-runtime"));
+                Assert.That(record.actor, Is.EqualTo("gameplay"));
+                Assert.That(record.category, Is.EqualTo("runtime"));
+                Assert.That(record.type, Is.EqualTo("checkpoint_reached"));
+                Assert.That(record.action, Is.EqualTo("checkpoint_reached"));
+                Assert.That(record.target, Is.EqualTo("Checkpoints/Finish"));
+                Assert.That(record.summary, Is.EqualTo("Serialized channel smoke sample emitted checkpoint."));
+                Assert.That(record.message, Is.EqualTo(record.summary));
+                Assert.That(record.severity, Is.EqualTo("info"));
+                Assert.That(record.success, Is.True);
+                Assert.That(record.metadata["sample"], Is.EqualTo("serialized-channel-smoke"));
+                Assert.That(record.metadata["scenePath"], Is.EqualTo("Assets/Scenes/Checkpoint.unity"));
+                Assert.That(record.payload.kind, Is.EqualTo("runtime-gameplay-event"));
+                Assert.That(record.payload.eventType, Is.EqualTo("checkpoint_reached"));
+                Assert.That(record.payload.summary, Is.EqualTo("Serialized channel smoke sample emitted checkpoint."));
+                Assert.That(record.payload.status, Is.EqualTo("completed"));
+                Assert.That(record.payload.target, Is.EqualTo("Checkpoints/Finish"));
+                Assert.That(record.payload.attributes["checkpointId"], Is.EqualTo("finish"));
+                Assert.That(record.payload.attributes["elapsedSeconds"], Is.EqualTo(42.5f));
+                Assert.That(record.payload.attributes["scoreValue"], Is.EqualTo(500));
+                Assert.That(record.payload.attributes["isFinal"], Is.EqualTo(true));
+                Assert.That(record.payload.attributes["trigger"], Is.EqualTo("serialized-component"));
+                Assert.That(record.payload.attributes["gameObject"], Is.EqualTo("LuxRuntimeEventSerializedChannelSmokeSample"));
+
+                Assert.That(decoded.schemaVersion, Is.EqualTo(1));
+                Assert.That(decoded.protocol, Is.EqualTo("lux.ai.action_log.v1"));
+                Assert.That(decoded.timestampUtc, Is.EqualTo("2026-05-05T12:45:00.0000000Z"));
+                Assert.That(decoded.projectPath, Is.EqualTo(projectRoot));
+                Assert.That(decoded.source, Is.EqualTo("unity-runtime"));
+                Assert.That(decoded.actor, Is.EqualTo("gameplay"));
+                Assert.That(decoded.category, Is.EqualTo("runtime"));
+                Assert.That(decoded.type, Is.EqualTo("checkpoint_reached"));
+                Assert.That(decoded.action, Is.EqualTo("checkpoint_reached"));
+                Assert.That(decoded.target, Is.EqualTo("Checkpoints/Finish"));
+                Assert.That(decoded.summary, Is.EqualTo("Serialized channel smoke sample emitted checkpoint."));
+                Assert.That(decoded.message, Is.EqualTo(decoded.summary));
+                Assert.That(decoded.severity, Is.EqualTo("info"));
+                Assert.That(decoded.success, Is.True);
+                Assert.That(decoded.payload.kind, Is.EqualTo("runtime-gameplay-event"));
+                Assert.That(decoded.payload.eventType, Is.EqualTo("checkpoint_reached"));
+                Assert.That(decoded.payload.summary, Is.EqualTo("Serialized channel smoke sample emitted checkpoint."));
+                Assert.That(decoded.payload.status, Is.EqualTo("completed"));
+                Assert.That(decoded.payload.target, Is.EqualTo("Checkpoints/Finish"));
+                Assert.That(decoded.payload.attributes.checkpointId, Is.EqualTo("finish"));
+                Assert.That(decoded.payload.attributes.elapsedSeconds, Is.EqualTo(42.5f));
+                Assert.That(decoded.payload.attributes.position.x, Is.EqualTo(4.5f));
+                Assert.That(decoded.payload.attributes.position.y, Is.EqualTo(1f));
+                Assert.That(decoded.payload.attributes.position.z, Is.EqualTo(-2.25f));
+                Assert.That(decoded.payload.attributes.scoreValue, Is.EqualTo(500));
+                Assert.That(decoded.payload.attributes.isFinal, Is.True);
+                Assert.That(decoded.payload.attributes.trigger, Is.EqualTo("serialized-component"));
+                Assert.That(decoded.payload.attributes.gameObject, Is.EqualTo("LuxRuntimeEventSerializedChannelSmokeSample"));
+                Assert.That(lines[0], Does.Contain("\"metadata\":{\"sample\":\"serialized-channel-smoke\",\"scenePath\":\"Assets/Scenes/Checkpoint.unity\"}"));
+                Assert.That(lines[0], Does.Contain("\"redactionMetadata\""));
+                Assert.That(lines[0], Does.Contain("\"retentionMetadata\""));
+            }
+            finally
+            {
+                UnityEngine.Object.DestroyImmediate(sampleObject);
+                UnityEngine.Object.DestroyImmediate(configuredChannel);
+                UnityEngine.Object.DestroyImmediate(serializedChannel);
+            }
+        }
+
+        [Serializable]
+        sealed class LuxRuntimeEventSerializedChannelSmokeRecord
+        {
+            public int schemaVersion;
+            public string protocol;
+            public string id;
+            public string timestampUtc;
+            public string projectPath;
+            public string source;
+            public string actor;
+            public string category;
+            public string type;
+            public string action;
+            public string target;
+            public string summary;
+            public string message;
+            public string severity;
+            public bool success;
+            public LuxRuntimeEventSerializedChannelSmokePayload payload;
+        }
+
+        [Serializable]
+        sealed class LuxRuntimeEventSerializedChannelSmokePayload
+        {
+            public string kind;
+            public string eventType;
+            public string summary;
+            public string status;
+            public string target;
+            public LuxRuntimeEventSerializedChannelSmokeAttributes attributes;
+        }
+
+        [Serializable]
+        sealed class LuxRuntimeEventSerializedChannelSmokeAttributes
+        {
+            public string checkpointId;
+            public float elapsedSeconds;
+            public Vector3 position;
+            public int scoreValue;
+            public bool isFinal;
+            public string trigger;
+            public string gameObject;
+        }
+    }
+}
