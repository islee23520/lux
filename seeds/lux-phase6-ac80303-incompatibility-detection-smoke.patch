+#[test]
+fn skill_install_adapt_reports_unsupported_and_conflicting_project_conditions() {
+    let home = create_temp_dir("lux-skill-adapt-conflicting-home");
+    let project = create_test_unity_project("lux-skill-adapt-conflicting-project", true);
+    fs::write(
+        project.join("Packages/manifest.json"),
+        r#"{
+  "dependencies": {
+    "com.linalab.lux": "file:Packages/com.linalab.lux",
+    "com.unity.render-pipelines.universal": "17.0.3",
+    "com.unity.render-pipelines.high-definition": "17.0.3"
+  }
+}
+"#,
+    )
+    .expect("write conflicting render pipeline package manifest");
+    let source = create_test_skill_source_with_compatibility(
+        "smoke-adapt-conflicting-project-skill",
+        Some(
+            r#"{
+    "requiresLuxPackage": true,
+    "requiredPackages": ["com.linalab.lux"],
+    "renderPipelines": ["urp"],
+    "platformTargets": ["visionos"]
+  }"#,
+        ),
+    );
+
+    let output = Command::new(env!("CARGO_BIN_EXE_lux"))
+        .args([
+            "skill",
+            "install",
+            "smoke-adapt-conflicting-project-skill",
+            "--source",
+            source.to_str().expect("source path UTF-8"),
+            "--project",
+            "--adapt",
+            "--json",
+        ])
+        .current_dir(&project)
+        .env("HOME", &home)
+        .output()
+        .expect("run conflicting project lux skill install --adapt");
+
+    assert!(!output.status.success());
+    assert_eq!(output.status.code(), Some(1));
+    let parsed: Value = serde_json::from_slice(&output.stdout).expect("error JSON");
+    assert_eq!(parsed["installed"], false);
+    assert_eq!(parsed["error_code"], "adapted_skill_incompatible");
+    assert_compatibility_failed_checks(
+        &parsed["failure"],
+        &["project_conflicts", "render_pipeline", "platform_targets"],
+    );
+    let conflict_check = parsed["failure"]["compatibility"]["checks"]
+        .as_array()
+        .expect("compatibility checks array")
+        .iter()
+        .find(|check| check["name"] == "project_conflicts")
+        .expect("project conflicts compatibility check");
+    assert_eq!(conflict_check["ok"], false);
+    assert_eq!(conflict_check["actual"][0]["kind"], "render_pipeline_conflict");
+    assert_eq!(
+        parsed["failure"]["compatibility"]["declared"]["renderPipelines"][0],
+        "urp"
+    );
+    assert!(
+        !project
+            .join(".lux/skills/smoke-adapt-conflicting-project-skill")
+            .exists(),
+        "unsupported/conflicting project conditions must block adapted install"
+    );
+}
