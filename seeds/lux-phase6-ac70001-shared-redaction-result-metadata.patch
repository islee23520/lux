+fn sanitize_redaction_location(location: &str) -> String {
+    let trimmed = location.trim();
+    if trimmed.is_empty() {
+        return "unknown".to_string();
+    }
+
+    trimmed
+        .split('.')
+        .map(|segment| {
+            let segment = segment.trim();
+            if segment.is_empty() {
+                "<empty>".to_string()
+            } else if is_sensitive_location_segment(segment) {
+                "<sensitive-key>".to_string()
+            } else {
+                segment
+                    .chars()
+                    .map(|character| {
+                        if character.is_ascii_alphanumeric()
+                            || matches!(character, '_' | '-' | '[' | ']' | '<' | '>')
+                        {
+                            character
+                        } else {
+                            '_'
+                        }
+                    })
+                    .collect::<String>()
+            }
+        })
+        .collect::<Vec<_>>()
+        .join(".")
+}
+
+fn is_sensitive_location_segment(segment: &str) -> bool {
+    let normalized = segment.to_ascii_lowercase();
+    [
+        "authorization",
+        "api_key",
+        "apikey",
+        "password",
+        "passwd",
+        "private_key",
+        "privatekey",
+        "pwd",
+        "secret",
+        "token",
+    ]
+    .iter()
+    .any(|needle| normalized.contains(needle))
+}
+
+fn push_unique<T: PartialEq>(values: &mut Vec<T>, value: T) {
+    if !values.contains(&value) {
+        values.push(value);
+    }
+}
