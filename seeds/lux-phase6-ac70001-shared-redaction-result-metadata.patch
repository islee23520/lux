+#[derive(Clone, Debug, Deserialize, Eq, PartialEq, Serialize)]
+#[serde(rename_all = "camelCase")]
+pub struct RedactionMetadata {
+    pub policy_version: String,
+    pub applied: bool,
+    pub redacted_count: usize,
+    pub redacted_fields: Vec<String>,
+    pub redaction_classes: Vec<RedactionCategory>,
+    pub location_hints: Vec<RedactionLocationHint>,
+}
+
+impl Default for RedactionMetadata {
+    fn default() -> Self {
+        Self {
+            policy_version: REDACTION_POLICY_VERSION.to_string(),
+            applied: false,
+            redacted_count: 0,
+            redacted_fields: Vec::new(),
+            redaction_classes: Vec::new(),
+            location_hints: Vec::new(),
+        }
+    }
+}
+
+impl RedactionMetadata {
+    pub fn record(&mut self, location: impl AsRef<str>, category: RedactionCategory) {
+        let location = sanitize_redaction_location(location.as_ref());
+        self.applied = true;
+        self.redacted_count += 1;
+        push_unique(&mut self.redacted_fields, location.clone());
+        push_unique(&mut self.redaction_classes, category.clone());
+        if !self
+            .location_hints
+            .iter()
+            .any(|hint| hint.location == location && hint.category == category)
+        {
+            self.location_hints
+                .push(RedactionLocationHint { location, category });
+        }
+    }
+
+    pub fn merge(&mut self, other: RedactionMetadata) {
+        if other.applied {
+            self.applied = true;
+        }
+
+        self.redacted_count += other.redacted_count;
+        for location in other.redacted_fields {
+            push_unique(&mut self.redacted_fields, location);
+        }
+        for category in other.redaction_classes {
+            push_unique(&mut self.redaction_classes, category);
+        }
+        for hint in other.location_hints {
+            if !self.location_hints.iter().any(|existing| existing == &hint) {
+                self.location_hints.push(hint);
+            }
+        }
+    }
+}
