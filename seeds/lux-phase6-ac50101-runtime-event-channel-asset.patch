diff --git a/Runtime/LuxRuntimeEventChannel.cs b/Runtime/LuxRuntimeEventChannel.cs
new file mode 100644
index 0000000..39bd87e
--- /dev/null
+++ b/Runtime/LuxRuntimeEventChannel.cs
@@ -0,0 +1,332 @@
+using System;
+using System.Collections.Generic;
+using UnityEngine;
+
+namespace Linalab.Lux.Runtime
+{
+    public enum LuxRuntimeEventChannelValueType
+    {
+        String,
+        Integer,
+        Float,
+        Boolean,
+        Vector2,
+        Vector3,
+        ObjectName
+    }
+
+    [Serializable]
+    public sealed class LuxRuntimeEventChannelMetadata
+    {
+        [SerializeField] string key = string.Empty;
+        [SerializeField] string value = string.Empty;
+
+        public LuxRuntimeEventChannelMetadata()
+        {
+        }
+
+        public LuxRuntimeEventChannelMetadata(string key, string value)
+        {
+            this.key = key ?? string.Empty;
+            this.value = value ?? string.Empty;
+        }
+
+        public bool TryAddTo(Dictionary<string, string> target)
+        {
+            if (target == null || string.IsNullOrWhiteSpace(key))
+            {
+                return false;
+            }
+
+            target[key] = value ?? string.Empty;
+            return true;
+        }
+    }
+
+    [Serializable]
+    public sealed class LuxRuntimeEventChannelAttribute
+    {
+        [SerializeField] string key = string.Empty;
+        [SerializeField] LuxRuntimeEventChannelValueType valueType = LuxRuntimeEventChannelValueType.String;
+        [SerializeField] string stringValue = string.Empty;
+        [SerializeField] int integerValue;
+        [SerializeField] float floatValue;
+        [SerializeField] bool boolValue;
+        [SerializeField] Vector2 vector2Value;
+        [SerializeField] Vector3 vector3Value;
+        [SerializeField] UnityEngine.Object objectValue;
+
+        public LuxRuntimeEventChannelAttribute()
+        {
+        }
+
+        public static LuxRuntimeEventChannelAttribute String(string key, string value)
+        {
+            return new LuxRuntimeEventChannelAttribute
+            {
+                key = key ?? string.Empty,
+                valueType = LuxRuntimeEventChannelValueType.String,
+                stringValue = value ?? string.Empty
+            };
+        }
+
+        public static LuxRuntimeEventChannelAttribute Integer(string key, int value)
+        {
+            return new LuxRuntimeEventChannelAttribute
+            {
+                key = key ?? string.Empty,
+                valueType = LuxRuntimeEventChannelValueType.Integer,
+                integerValue = value
+            };
+        }
+
+        public static LuxRuntimeEventChannelAttribute Float(string key, float value)
+        {
+            return new LuxRuntimeEventChannelAttribute
+            {
+                key = key ?? string.Empty,
+                valueType = LuxRuntimeEventChannelValueType.Float,
+                floatValue = value
+            };
+        }
+
+        public static LuxRuntimeEventChannelAttribute Boolean(string key, bool value)
+        {
+            return new LuxRuntimeEventChannelAttribute
+            {
+                key = key ?? string.Empty,
+                valueType = LuxRuntimeEventChannelValueType.Boolean,
+                boolValue = value
+            };
+        }
+
+        public static LuxRuntimeEventChannelAttribute Vector2(string key, UnityEngine.Vector2 value)
+        {
+            return new LuxRuntimeEventChannelAttribute
+            {
+                key = key ?? string.Empty,
+                valueType = LuxRuntimeEventChannelValueType.Vector2,
+                vector2Value = value
+            };
+        }
+
+        public static LuxRuntimeEventChannelAttribute Vector3(string key, UnityEngine.Vector3 value)
+        {
+            return new LuxRuntimeEventChannelAttribute
+            {
+                key = key ?? string.Empty,
+                valueType = LuxRuntimeEventChannelValueType.Vector3,
+                vector3Value = value
+            };
+        }
+
+        public static LuxRuntimeEventChannelAttribute ObjectName(string key, UnityEngine.Object value)
+        {
+            return new LuxRuntimeEventChannelAttribute
+            {
+                key = key ?? string.Empty,
+                valueType = LuxRuntimeEventChannelValueType.ObjectName,
+                objectValue = value
+            };
+        }
+
+        public bool TryAddTo(Dictionary<string, object> target)
+        {
+            if (target == null || string.IsNullOrWhiteSpace(key))
+            {
+                return false;
+            }
+
+            target[key] = ToValue();
+            return true;
+        }
+
+        object ToValue()
+        {
+            switch (valueType)
+            {
+                case LuxRuntimeEventChannelValueType.Integer:
+                    return integerValue;
+                case LuxRuntimeEventChannelValueType.Float:
+                    return floatValue;
+                case LuxRuntimeEventChannelValueType.Boolean:
+                    return boolValue;
+                case LuxRuntimeEventChannelValueType.Vector2:
+                    return vector2Value;
+                case LuxRuntimeEventChannelValueType.Vector3:
+                    return vector3Value;
+                case LuxRuntimeEventChannelValueType.ObjectName:
+                    return objectValue == null ? string.Empty : objectValue.name;
+                default:
+                    return stringValue ?? string.Empty;
+            }
+        }
+    }
+
+    [Serializable]
+    public sealed class LuxRuntimeEventChannelRetentionSettings
+    {
+        [SerializeField] bool enabled = true;
+        [SerializeField] int retentionDays = LuxRuntimeEvent.DefaultRetentionDays;
+        [SerializeField] int maxEntries = LuxRuntimeEvent.DefaultRetentionMaxEntries;
+
+        public bool Enabled => enabled;
+        public int RetentionDays => Math.Max(1, retentionDays);
+        public int MaxEntries => Math.Max(0, maxEntries);
+
+        public void Configure(bool enabled, int retentionDays, int maxEntries)
+        {
+            this.enabled = enabled;
+            this.retentionDays = Math.Max(1, retentionDays);
+            this.maxEntries = Math.Max(0, maxEntries);
+        }
+    }
+
+    [CreateAssetMenu(fileName = "LuxRuntimeEventChannel", menuName = "LUX/Runtime Event Channel", order = 410)]
+    public sealed class LuxRuntimeEventChannel : ScriptableObject
+    {
+        [SerializeField] string eventType = "runtime.event";
+        [SerializeField] string target = string.Empty;
+        [SerializeField] string summary = string.Empty;
+        [SerializeField] string status = "completed";
+        [SerializeField] string severity = "info";
+        [SerializeField] bool success = true;
+        [SerializeField] bool useProjectRootOverride;
+        [SerializeField] string projectRootOverride = string.Empty;
+        [SerializeField] bool useLogPathOverride;
+        [SerializeField] string logPathOverride = string.Empty;
+        [SerializeField] List<LuxRuntimeEventChannelMetadata> metadata = new List<LuxRuntimeEventChannelMetadata>();
+        [SerializeField] List<LuxRuntimeEventChannelAttribute> attributes = new List<LuxRuntimeEventChannelAttribute>();
+        [SerializeField] LuxRuntimeEventChannelRetentionSettings retention = new LuxRuntimeEventChannelRetentionSettings();
+
+        public LuxRuntimeEventRecord Emit()
+        {
+            return Emit(null);
+        }
+
+        public LuxRuntimeEventRecord Emit(IReadOnlyDictionary<string, object> runtimeAttributes)
+        {
+            var mergedAttributes = BuildAttributes();
+            if (runtimeAttributes != null)
+            {
+                foreach (var pair in runtimeAttributes)
+                {
+                    if (!string.IsNullOrWhiteSpace(pair.Key))
+                    {
+                        mergedAttributes[pair.Key] = pair.Value;
+                    }
+                }
+            }
+
+            return LuxRuntimeEvent.Emit(
+                eventType,
+                mergedAttributes,
+                target,
+                summary,
+                status,
+                severity,
+                success,
+                BuildMetadata(),
+                BuildOptions());
+        }
+
+        public LuxRuntimeEventRecord Emit(
+            string runtimeEventType,
+            IReadOnlyDictionary<string, object> runtimeAttributes = null,
+            string runtimeTarget = null,
+            string runtimeSummary = null)
+        {
+            string selectedEventType = string.IsNullOrWhiteSpace(runtimeEventType) ? eventType : runtimeEventType;
+            return LuxRuntimeEvent.Emit(
+                selectedEventType,
+                MergeAttributes(runtimeAttributes),
+                string.IsNullOrWhiteSpace(runtimeTarget) ? target : runtimeTarget,
+                string.IsNullOrWhiteSpace(runtimeSummary) ? summary : runtimeSummary,
+                status,
+                severity,
+                success,
+                BuildMetadata(),
+                BuildOptions());
+        }
+
+        public void Configure(
+            string eventType,
+            string target,
+            string summary,
+            string projectRoot,
+            string logPath,
+            IEnumerable<LuxRuntimeEventChannelMetadata> metadata,
+            IEnumerable<LuxRuntimeEventChannelAttribute> attributes,
+            int retentionDays = LuxRuntimeEvent.DefaultRetentionDays,
+            int retentionMaxEntries = LuxRuntimeEvent.DefaultRetentionMaxEntries)
+        {
+            this.eventType = string.IsNullOrWhiteSpace(eventType) ? "runtime.event" : eventType;
+            this.target = target ?? string.Empty;
+            this.summary = summary ?? string.Empty;
+            this.projectRootOverride = projectRoot ?? string.Empty;
+            this.useProjectRootOverride = !string.IsNullOrWhiteSpace(projectRoot);
+            this.logPathOverride = logPath ?? string.Empty;
+            this.useLogPathOverride = !string.IsNullOrWhiteSpace(logPath);
+            this.metadata = metadata == null
+                ? new List<LuxRuntimeEventChannelMetadata>()
+                : new List<LuxRuntimeEventChannelMetadata>(metadata);
+            this.attributes = attributes == null
+                ? new List<LuxRuntimeEventChannelAttribute>()
+                : new List<LuxRuntimeEventChannelAttribute>(attributes);
+            retention.Configure(true, retentionDays, retentionMaxEntries);
+        }
+
+        Dictionary<string, object> MergeAttributes(IReadOnlyDictionary<string, object> runtimeAttributes)
+        {
+            var mergedAttributes = BuildAttributes();
+            if (runtimeAttributes == null)
+            {
+                return mergedAttributes;
+            }
+
+            foreach (var pair in runtimeAttributes)
+            {
+                if (!string.IsNullOrWhiteSpace(pair.Key))
+                {
+                    mergedAttributes[pair.Key] = pair.Value;
+                }
+            }
+
+            return mergedAttributes;
+        }
+
+        Dictionary<string, object> BuildAttributes()
+        {
+            var result = new Dictionary<string, object>(StringComparer.Ordinal);
+            foreach (var attribute in attributes)
+            {
+                attribute?.TryAddTo(result);
+            }
+
+            return result;
+        }
+
+        Dictionary<string, string> BuildMetadata()
+        {
+            var result = new Dictionary<string, string>(StringComparer.Ordinal);
+            foreach (var item in metadata)
+            {
+                item?.TryAddTo(result);
+            }
+
+            return result;
+        }
+
+        LuxRuntimeEventOptions BuildOptions()
+        {
+            return new LuxRuntimeEventOptions
+            {
+                ProjectRoot = useProjectRootOverride ? projectRootOverride : null,
+                LogPath = useLogPathOverride ? logPathOverride : null,
+                RetentionEnabled = retention == null || retention.Enabled,
+                RetentionDays = retention == null ? LuxRuntimeEvent.DefaultRetentionDays : retention.RetentionDays,
+                MaxEntries = retention == null ? LuxRuntimeEvent.DefaultRetentionMaxEntries : retention.MaxEntries
+            };
+        }
+    }
+}
