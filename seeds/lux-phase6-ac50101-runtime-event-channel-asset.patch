+++ b/LuxEditorTests/Editor/LuxRuntimeEventChannelTests.cs
@@ -0,0 +1,125 @@
+using System;
+using System.IO;
+using Linalab.Lux.Runtime;
+using NUnit.Framework;
+using UnityEditor;
+using UnityEngine;
+
+namespace Linalab.LuxEditor.Tests
+{
+    public sealed class LuxRuntimeEventChannelTests
+    {
+        string tempDirectory;
+
+        [SetUp]
+        public void SetUp()
+        {
+            tempDirectory = Path.Combine(Path.GetTempPath(), "LuxRuntimeEventChannelTests", Guid.NewGuid().ToString("N"));
+            Directory.CreateDirectory(tempDirectory);
+            LuxRuntimeEvent.ConfigureForTests(null, tempDirectory, () => new DateTime(2026, 5, 5, 0, 0, 0, DateTimeKind.Utc));
+        }
+
+        [TearDown]
+        public void TearDown()
+        {
+            LuxRuntimeEvent.ResetForTests();
+            if (!string.IsNullOrWhiteSpace(tempDirectory) && Directory.Exists(tempDirectory))
+            {
+                Directory.Delete(tempDirectory, true);
+            }
+        }
+
+        [Test]
+        public void Emit_UsesSerializedProjectScopedConfiguration()
+        {
+            string projectRoot = Path.Combine(tempDirectory, "Project");
+            var channel = ScriptableObject.CreateInstance<LuxRuntimeEventChannel>();
+            channel.Configure(
+                "enemy_death",
+                "Enemies/Enemy-7",
+                "Gameplay runtime enemy death logged.",
+                projectRoot,
+                null,
+                new[] { new LuxRuntimeEventChannelMetadata("scenePath", "Assets/Scenes/Arena.unity") },
+                new[]
+                {
+                    LuxRuntimeEventChannelAttribute.String("entityId", "enemy-7"),
+                    LuxRuntimeEventChannelAttribute.Integer("scoreValue", 150),
+                    LuxRuntimeEventChannelAttribute.Boolean("isBoss", false),
+                    LuxRuntimeEventChannelAttribute.Vector3("position", new Vector3(12.5f, 0f, -3.25f))
+                });
+
+            var record = channel.Emit();
+
+            string logPath = Path.Combine(projectRoot, "UserSettings", "LuxAiActionLog.jsonl");
+            string line = File.ReadAllText(logPath);
+            Assert.That(record.source, Is.EqualTo("unity-runtime"));
+            Assert.That(record.actor, Is.EqualTo("gameplay"));
+            Assert.That(record.category, Is.EqualTo("runtime"));
+            Assert.That(record.payload.kind, Is.EqualTo("runtime-gameplay-event"));
+            Assert.That(record.payload.eventType, Is.EqualTo("enemy_death"));
+            Assert.That(line, Does.Contain("\"projectPath\":\"" + Escape(projectRoot) + "\""));
+            Assert.That(line, Does.Contain("\"payload\":{\"kind\":\"runtime-gameplay-event\""));
+            Assert.That(line, Does.Contain("\"entityId\":\"enemy-7\""));
+            Assert.That(line, Does.Contain("\"scoreValue\":150"));
+            Assert.That(line, Does.Contain("\"isBoss\":false"));
+            Assert.That(line, Does.Contain("\"position\":{\"x\":12.5,\"y\":0,\"z\":-3.25}"));
+            Assert.That(line, Does.Contain("\"scenePath\":\"Assets/Scenes/Arena.unity\""));
+            UnityEngine.Object.DestroyImmediate(channel);
+        }
+
+        [Test]
+        public void Emit_RedactsSerializedSecretsAndAppliesRetentionLimit()
+        {
+            string logPath = Path.Combine(tempDirectory, "custom", "runtime-events.jsonl");
+            var channel = ScriptableObject.CreateInstance<LuxRuntimeEventChannel>();
+            channel.Configure(
+                "runtime_secret",
+                "Runtime",
+                "token=raw-secret should be redacted",
+                null,
+                logPath,
+                new[] { new LuxRuntimeEventChannelMetadata("apiKey", "raw-secret") },
+                new[] { LuxRuntimeEventChannelAttribute.String("authorization", "Bearer raw-secret") },
+                retentionMaxEntries: 1);
+
+            channel.Emit("first_event");
+            channel.Emit("second_event");
+
+            string[] lines = File.ReadAllLines(logPath);
+            Assert.That(lines.Length, Is.EqualTo(1));
+            Assert.That(lines[0], Does.Contain("\"eventType\":\"second_event\""));
+            Assert.That(lines[0], Does.Not.Contain("raw-secret"));
+            Assert.That(lines[0], Does.Contain("[REDACTED]"));
+            Assert.That(lines[0], Does.Contain("\"retentionMetadata\""));
+            UnityEngine.Object.DestroyImmediate(channel);
+        }
+
+        [Test]
+        public void ChannelConfiguration_IsUnitySerialized()
+        {
+            var channel = ScriptableObject.CreateInstance<LuxRuntimeEventChannel>();
+            channel.Configure(
+                "checkpoint_reached",
+                "Checkpoints/Finish",
+                "Checkpoint reached.",
+                tempDirectory,
+                null,
+                null,
+                new[] { LuxRuntimeEventChannelAttribute.Float("elapsedSeconds", 42.5f) });
+
+            string json = EditorJsonUtility.ToJson(channel);
+
+            Assert.That(json, Does.Contain("checkpoint_reached"));
+            Assert.That(json, Does.Contain("Checkpoints/Finish"));
+            Assert.That(json, Does.Contain("elapsedSeconds"));
+            Assert.That(json, Does.Contain("retentionDays"));
+            UnityEngine.Object.DestroyImmediate(channel);
+        }
+
+        static string Escape(string value)
+        {
+            return value.Replace("\\", "\\\\").Replace("\"", "\\\"");
+        }
+    }
+}
