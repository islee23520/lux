+fn compare_ai_work_step_entries(left: &AiWorkStepEntry, right: &AiWorkStepEntry) -> Ordering {
+    compare_timestamp_fields(&left.sort_key.timestamp_utc, &right.sort_key.timestamp_utc)
+        .then(left.sort_key.sequence.cmp(&right.sort_key.sequence))
+        .then(left.sort_key.line_number.cmp(&right.sort_key.line_number))
+        .then(left.sort_key.id.cmp(&right.sort_key.id))
+}
+
+fn compare_timestamp_fields(left: &str, right: &str) -> Ordering {
+    match (!left.is_empty(), !right.is_empty()) {
+        (true, true) => left.cmp(right),
+        (true, false) => Ordering::Less,
+        (false, true) => Ordering::Greater,
+        (false, false) => Ordering::Equal,
+    }
+}
+
+fn validate_ai_work_step_record(value: &Value) -> Result<()> {
+    if !value.is_object() {
+        anyhow::bail!("AI work step record must be a JSON object");
+    }
+    let payload = value
+        .get("payload")
+        .and_then(Value::as_object)
+        .context("AI work step record must include an object payload")?;
+    let kind = required_string(payload.get("kind"), "payload.kind")?;
+    if kind != "ai-work-step" {
+        anyhow::bail!("AI work step record payload.kind must be ai-work-step");
+    }
+    Ok(())
+}
+
+fn ai_work_step_timestamp(value: &Value) -> Result<String> {
+    required_string(
+        value
+            .get("timestampUtc")
+            .or_else(|| value.get("captured_at_utc"))
+            .or_else(|| value.pointer("/payload/timestamps/recordedAtUtc")),
+        "timestampUtc",
+    )
+    .map(ToOwned::to_owned)
+}
+
+fn ai_work_step_event_type(value: &Value) -> Result<&str> {
+    required_string(
+        value
+            .get("type")
+            .or_else(|| value.get("eventType"))
+            .or_else(|| value.get("event_type"))
+            .or_else(|| value.pointer("/payload/eventType"))
+            .or_else(|| value.pointer("/payload/event_type")),
+        "type",
+    )
+}
+
+fn ai_work_step_sequence(value: &Value) -> Result<u64> {
+    let sequence = value
+        .pointer("/payload/ordering/sequence")
+        .context("AI work step record must include payload.ordering.sequence")?;
+    sequence
+        .as_u64()
+        .or_else(|| {
+            sequence
+                .as_i64()
+                .and_then(|sequence| u64::try_from(sequence).ok())
+        })
+        .context("AI work step record payload.ordering.sequence must be a non-negative integer")
+}
+
+fn required_string<'a>(value: Option<&'a Value>, field: &str) -> Result<&'a str> {
+    value
+        .and_then(Value::as_str)
+        .with_context(|| format!("AI work step record must include string {field}"))
 }
 
