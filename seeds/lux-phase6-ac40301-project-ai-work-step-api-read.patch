+pub fn read_project_ai_work_steps(
+    project_root: impl AsRef<Path>,
+    limit: usize,
+) -> Result<ProjectAiWorkStepReadResult> {
+    let project_root = project_root.as_ref();
+    let path = ensure_log_path(project_root)?;
+    let (mut entries, warnings) = if path.exists() {
+        let file = File::open(&path)
+            .with_context(|| format!("failed to open AI work step log {}", path.display()))?;
+        parse_ordered_ai_work_step_records_with_warnings(BufReader::new(file))
+    } else {
+        (Vec::new(), Vec::new())
+    };
+
+    if entries.len() > limit {
+        entries = entries.split_off(entries.len() - limit);
+    }
+
+    Ok(ProjectAiWorkStepReadResult {
+        project_path: project_root.to_path_buf(),
+        path,
+        limit,
+        entries,
+        warnings,
+    })
+}
+
+pub fn parse_ordered_ai_work_step_records_with_warnings(
+    reader: impl BufRead,
+) -> (Vec<AiWorkStepEntry>, Vec<AiWorkStepParseWarning>) {
+    let mut entries = Vec::new();
+    let mut warnings = Vec::new();
+
+    for (index, line) in reader.lines().enumerate() {
+        let line_number = index + 1;
+        let line = match line {
+            Ok(line) => line,
+            Err(error) => {
+                warnings.push(AiWorkStepParseWarning {
+                    line_number,
+                    reason: format!("failed to read line: {error}"),
+                });
+                continue;
+            }
+        };
+        let trimmed = line.trim();
+        if trimmed.is_empty() {
+            continue;
+        }
+        let value = match serde_json::from_str::<Value>(trimmed) {
+            Ok(value) => value,
+            Err(error) => {
+                warnings.push(AiWorkStepParseWarning {
+                    line_number,
+                    reason: format!("line is not valid JSON: {error}"),
+                });
+                continue;
+            }
+        };
+        match AiWorkStepEntry::from_log_entry(AiLogEntry {
+            line_number,
+            timestamp: timestamp(&value).unwrap_or_default(),
+            value,
+        }) {
+            Ok(entry) => entries.push(entry),
+            Err(error) => warnings.push(AiWorkStepParseWarning {
+                line_number,
+                reason: error.to_string(),
+            }),
+        }
+    }
+
+    entries.sort_by(compare_ai_work_step_entries);
+    (entries, warnings)
+}
