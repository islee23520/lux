 #[test]
+fn ai_log_work_steps_json_returns_ordered_project_scoped_steps() {
+    let project_root = create_ai_work_step_fixture_project("lux-ai-log-work-steps");
+    let output = Command::new(env!("CARGO_BIN_EXE_lux"))
+        .args([
+            "ai-log",
+            "work-steps",
+            "--project-path",
+            project_root.to_str().expect("project path UTF-8"),
+            "--limit",
+            "2",
+            "--json",
+        ])
+        .output()
+        .expect("run lux ai-log work-steps --json");
+
+    assert_command_success(&output, "lux ai-log work-steps --json");
+    let parsed: Value = serde_json::from_slice(&output.stdout).expect("work steps JSON");
+    assert_eq!(parsed["schemaVersion"], 1);
+    assert_eq!(parsed["protocol"], "lux.ai_work_steps.read.v1");
+    assert_eq!(parsed["projectPath"], project_root.display().to_string());
+    assert_eq!(
+        parsed["path"],
+        project_root
+            .join(".lux/ai-action-log.jsonl")
+            .display()
+            .to_string()
+    );
+    assert_eq!(parsed["limit"], 2);
+    assert_eq!(parsed["count"], 2);
+    assert_eq!(parsed["warningCount"], 2);
+
+    let entries = parsed["entries"].as_array().expect("entries array");
+    assert_eq!(entries[0]["id"], "ai-step-second");
+    assert_eq!(entries[0]["sequence"], 2);
+    assert_eq!(entries[0]["stepName"], "apply_patch");
+    assert_eq!(entries[0]["status"], "completed");
+    assert_eq!(entries[0]["sortKey"]["sequence"], 2);
+    assert_eq!(entries[1]["id"], "ai-step-third");
+    assert_eq!(entries[1]["summary"], "third [REDACTED]");
+    assert_eq!(parsed["warnings"][0]["lineNumber"], 2);
+
+    let serialized = String::from_utf8(output.stdout).expect("stdout UTF-8");
+    assert!(!serialized.contains("token=raw-secret"));
+    assert!(!serialized.contains("editor-only"));
+}
