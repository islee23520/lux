+fn print_ai_log_work_steps(args: AiLogWorkStepsArgs) -> anyhow::Result<()> {
+    let result = ai_log::read_project_ai_work_steps(&args.project_path, args.limit)?;
+    let entries = ai_log::redact_ai_work_step_entries(&result.entries);
+
+    if args.json {
+        println!(
+            "{}",
+            serde_json::to_string_pretty(&json!({
+                "schemaVersion": 1,
+                "protocol": "lux.ai_work_steps.read.v1",
+                "projectPath": result.project_path,
+                "path": result.path,
+                "limit": result.limit,
+                "count": entries.len(),
+                "warningCount": result.warnings.len(),
+                "entries": entries,
+                "warnings": result.warnings,
+            }))?
+        );
+        return Ok(());
+    }
+
+    for entry in entries {
+        println!(
+            "{} #{} [{}] {}: {}",
+            entry.timestamp_utc, entry.sequence, entry.status, entry.step_name, entry.summary
+        );
+    }
+    for warning in result.warnings {
+        eprintln!("warning line {}: {}", warning.line_number, warning.reason);
+    }
     Ok(())
 }
 
