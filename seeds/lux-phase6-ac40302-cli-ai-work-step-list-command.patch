+fn ai_log_work_steps_text_returns_readable_ordered_steps_and_warnings() {
+    let project_root = create_ai_work_step_fixture_project("lux-ai-log-work-steps-text");
+    let output = Command::new(env!("CARGO_BIN_EXE_lux"))
+        .args([
+            "ai-log",
+            "work-steps",
+            "--project-path",
+            project_root.to_str().expect("project path UTF-8"),
+            "--limit",
+            "3",
+        ])
+        .output()
+        .expect("run lux ai-log work-steps text");
+
+    assert_command_success(&output, "lux ai-log work-steps text");
+    let stdout = String::from_utf8(output.stdout).expect("stdout UTF-8");
+    let stderr = String::from_utf8(output.stderr).expect("stderr UTF-8");
+    let lines: Vec<_> = stdout.lines().collect();
+
+    assert_eq!(lines.len(), 3);
+    assert!(lines[0].contains("2026-05-04T00:00:01Z #1 [completed] read: first"));
+    assert!(lines[1].contains("2026-05-04T00:00:02Z #2 [completed] apply_patch: second"));
+    assert!(lines[2].contains("2026-05-04T00:00:03Z #3 [completed] test: third [REDACTED]"));
+    assert!(stderr.contains("warning line 2:"));
+    assert!(!stdout.contains("token=raw-secret"));
+    assert!(!stdout.contains("editor-only"));
+}
