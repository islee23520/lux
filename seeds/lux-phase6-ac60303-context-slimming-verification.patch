+fn verify_skill_context_slimming_result(context_slimming: &Value) -> Value {
+    let mut checks = Vec::new();
+
+    let required_fields = [
+        "/schema",
+        "/skill_name",
+        "/project_root",
+        "/mode",
+        "/artifacts/json",
+        "/artifacts/markdown",
+        "/rules/skill_md_preview_lines",
+        "/rules/reference_policy",
+        "/rules/default_context_policy",
+        "/rules/redaction_policy",
+        "/redaction/policy",
+        "/redaction/applied",
+        "/slimmed_context/manifest/name",
+        "/slimmed_context/manifest/version",
+        "/slimmed_context/manifest/description",
+        "/slimmed_context/skill_md_preview",
+        "/slimmed_context/deferred_reference_paths",
+        "/included_sources",
+        "/excluded_sources",
+        "/metrics/source_bytes",
+        "/metrics/retained_preview_chars",
+        "/metrics/deferred_reference_count",
+        "/metrics/estimated_reduction_percent",
+    ];
+    let missing_fields = required_fields
+        .iter()
+        .filter(|pointer| !context_slimming_required_field_present(context_slimming, pointer))
+        .map(|pointer| pointer.trim_start_matches('/').replace('/', "."))
+        .collect::<Vec<_>>();
+    push_context_slimming_check(
+        &mut checks,
+        "required_fields",
+        missing_fields.is_empty(),
+        if missing_fields.is_empty() {
+            "Context slimming output contains all required fields.".to_string()
+        } else {
+            format!("Missing required fields: {}", missing_fields.join(", "))
+        },
+    );
+
+    let serialized = serde_json::to_string(context_slimming).unwrap_or_default();
+    let leaks = sensitive_context_slimming_markers(&serialized);
+    push_context_slimming_check(
+        &mut checks,
+        "redaction",
+        leaks.is_empty()
+            && context_slimming
+                .pointer("/redaction/applied")
+                .and_then(Value::as_bool)
+                == Some(true),
+        if leaks.is_empty() {
+            "Secret-like values are redacted before context slimming output is persisted."
+                .to_string()
+        } else {
+            format!("Unredacted sensitive markers remain: {}", leaks.join(", "))
+        },
+    );
+
+    let preview_limit = context_slimming
+        .pointer("/rules/skill_md_preview_lines")
+        .and_then(Value::as_u64)
+        .unwrap_or_default() as usize;
+    let preview_count = context_slimming
+        .pointer("/slimmed_context/skill_md_preview")
+        .and_then(Value::as_array)
+        .map(Vec::len)
+        .unwrap_or_default();
+    let deferred_paths = context_slimming
+        .pointer("/slimmed_context/deferred_reference_paths")
+        .and_then(Value::as_array)
+        .cloned()
+        .unwrap_or_default();
+    let deferred_count = context_slimming
+        .pointer("/metrics/deferred_reference_count")
+        .and_then(Value::as_u64)
+        .unwrap_or_default() as usize;
+    let excluded_count = context_slimming
+        .get("excluded_sources")
+        .and_then(Value::as_array)
+        .map(Vec::len)
+        .unwrap_or_default();
+    let included_paths = context_slimming
+        .get("included_sources")
+        .and_then(Value::as_array)
+        .map(|sources| {
+            sources
+                .iter()
+                .filter_map(|source| source.get("path").and_then(Value::as_str))
+                .collect::<Vec<_>>()
+        })
+        .unwrap_or_default();
+    let slimmed_context = context_slimming
+        .get("slimmed_context")
+        .cloned()
+        .unwrap_or(Value::Null);
+    let slimmed_context_text = serde_json::to_string(&slimmed_context).unwrap_or_default();
+    let context_boundary_ok = preview_count <= preview_limit
+        && context_slimming
+            .pointer("/rules/reference_policy")
+            .and_then(Value::as_str)
+            == Some("defer_reference_bodies")
+        && context_slimming
+            .pointer("/rules/default_context_policy")
+            .and_then(Value::as_str)
+            == Some("manifest_summary_plus_skill_preview")
+        && deferred_count == deferred_paths.len()
+        && excluded_count == deferred_paths.len()
+        && included_paths.contains(&"manifest.json")
+        && included_paths.contains(&"SKILL.md")
+        && !slimmed_context_text.contains("reference_bodies")
+        && !slimmed_context_text.contains("referenceBodies")
+        && !slimmed_context_text.contains("reference_contents")
+        && !slimmed_context_text.contains("source_files")
+        && context_slimming_paths_are_relative(&deferred_paths);
+    push_context_slimming_check(
+        &mut checks,
+        "context_boundaries",
+        context_boundary_ok,
+        if context_boundary_ok {
+            "Slimmed context is bounded to manifest summary, SKILL.md preview, and deferred reference paths.".to_string()
+        } else {
+            "Slimmed context exceeded the expected manifest-plus-preview boundary.".to_string()
+        },
+    );
+
+    let all_ok = checks
+        .iter()
+        .all(|check: &Value| check.get("ok").and_then(Value::as_bool) == Some(true));
+
+    json!({
+        "schema": "lux.skill.context_slimming_verification.v1",
+        "status": if all_ok { "passed" } else { "failed" },
+        "checks": checks,
+    })
+}
+
+fn context_slimming_required_field_present(value: &Value, pointer: &str) -> bool {
+    match value.pointer(pointer) {
+        Some(Value::String(text)) => !text.trim().is_empty(),
+        Some(Value::Array(_)) | Some(Value::Bool(_)) | Some(Value::Number(_)) => true,
+        Some(Value::Object(object)) => !object.is_empty(),
+        _ => false,
+    }
+}
+
+fn push_context_slimming_check(checks: &mut Vec<Value>, name: &str, ok: bool, message: String) {
+    checks.push(json!({
+        "name": name,
+        "ok": ok,
+        "message": message,
+    }));
+}
+
+fn context_slimming_paths_are_relative(paths: &[Value]) -> bool {
+    paths.iter().all(|path| {
+        path.as_str().is_some_and(|path| {
+            !path.starts_with('/')
+                && !path.contains('\\')
+                && !path.split('/').any(|segment| segment == "..")
+        })
+    })
+}
+
+fn context_slimming_failed_check_messages(verification: &Value) -> String {
+    verification
+        .get("checks")
+        .and_then(Value::as_array)
+        .into_iter()
+        .flatten()
+        .filter(|check| check.get("ok").and_then(Value::as_bool) != Some(true))
+        .filter_map(|check| check.get("message").and_then(Value::as_str))
+        .collect::<Vec<_>>()
+        .join("; ")
+}
+
+fn redact_context_slimming_text(text: &str) -> String {
+    text.split_whitespace()
+        .map(|part| {
+            let lower = part.to_ascii_lowercase();
+            if part.eq_ignore_ascii_case("bearer")
+                || lower.starts_with("token=")
+                || lower.starts_with("password=")
+                || lower.starts_with("secret=")
+                || lower.starts_with("api_key=")
+                || lower.starts_with("apikey=")
+                || lower.starts_with("x-lux-token=")
+                || part.starts_with("sk-")
+            {
+                "[REDACTED]"
+            } else {
+                part
+            }
+        })
+        .collect::<Vec<_>>()
+        .join(" ")
+}
+
+fn sensitive_context_slimming_markers(text: &str) -> Vec<&'static str> {
+    let lower = text.to_ascii_lowercase();
+    let mut markers = Vec::new();
+    for (name, needle) in [
+        ("bearer-token", "authorization: bearer"),
+        ("token-assignment", "token="),
+        ("password-assignment", "password="),
+        ("secret-assignment", "secret="),
+        ("api-key-assignment", "api_key="),
+        ("openai-key", "sk-"),
+    ] {
+        if lower.contains(needle) {
+            markers.push(name);
+        }
+    }
+    markers
+}
