+#[test]
+fn skill_install_adapt_verifies_slimming_redaction_and_boundaries() {
+    let home = create_temp_dir("lux-skill-adapt-verify-slimming-home");
+    let project = create_test_unity_project("lux-skill-adapt-verify-slimming", true);
+    let source = create_test_skill_source("smoke-adapt-verify-slimming-skill");
+    fs::write(
+        source.join("manifest.json"),
+        format!(
+            r#"{{
+  "name": "smoke-adapt-verify-slimming-skill",
+  "version": "0.1.0",
+  "description": "Uses token=raw-phase6-token password=raw-phase6-password",
+  "displayName": "Smoke Verify Skill secret=raw-phase6-display-secret",
+  "luxVersion": "0.1.0",
+  "author": {{ "name": "Lux Tests" }},
+  "keywords": ["smoke", "api_key=raw-phase6-keyword"],
+  "type": "test",
+  "source": "{}"
+}}"#,
+            source.display()
+        ),
+    )
+    .expect("write sensitive test skill manifest");
+    fs::write(
+        source.join("SKILL.md"),
+        "# Verify Slimming\nUse token=raw-phase6-preview-token\nAuthorization: Bearer raw-phase6-bearer\n",
+    )
+    .expect("write sensitive test skill body");
+    fs::write(
+        source.join("references/usage.md"),
+        "# Usage\nReference body raw-phase6-reference-secret must stay out of slimmed context.\n",
+    )
+    .expect("write sensitive reference body");
+
+    let install = Command::new(env!("CARGO_BIN_EXE_lux"))
+        .args([
+            "skill",
+            "install",
+            "smoke-adapt-verify-slimming-skill",
+            "--source",
+            source.to_str().expect("source path UTF-8"),
+            "--project",
+            "--adapt",
+            "--json",
+        ])
+        .current_dir(&project)
+        .env("HOME", &home)
+        .output()
+        .expect("run lux skill install --project --adapt --json");
+
+    assert_command_success(&install, "lux skill install --adapt verification");
+    let install_json: Value = serde_json::from_slice(&install.stdout).expect("install JSON");
+    assert_eq!(
+        install_json["adaptation_metadata"]["context_slimming_verification"]["status"],
+        "passed"
+    );
+
+    let installed_dir = project.join(".lux/skills/smoke-adapt-verify-slimming-skill");
+    let context_path = installed_dir.join("lux-context-slimming.json");
+    let context_text =
+        fs::read_to_string(&context_path).expect("read context slimming verification artifact");
+    for raw_secret in [
+        "raw-phase6-token",
+        "raw-phase6-password",
+        "raw-phase6-display-secret",
+        "raw-phase6-keyword",
+        "raw-phase6-preview-token",
+        "raw-phase6-bearer",
+        "raw-phase6-reference-secret",
+    ] {
+        assert!(
+            !context_text.contains(raw_secret),
+            "context slimming artifact leaked {raw_secret}"
+        );
+    }
+    assert!(context_text.contains("[REDACTED]"));
+
+    let context_slimming: Value =
+        serde_json::from_str(&context_text).expect("context slimming JSON");
+    let checks = context_slimming["verification"]["checks"]
+        .as_array()
+        .expect("verification checks");
+    for expected_check in ["required_fields", "redaction", "context_boundaries"] {
+        assert!(
+            checks
+                .iter()
+                .any(|check| check["name"] == expected_check && check["ok"] == true),
+            "missing passing verification check {expected_check}"
+        );
+    }
+    let preview_count = context_slimming["slimmed_context"]["skill_md_preview"]
+        .as_array()
+        .expect("preview array")
+        .len();
+    let preview_limit = context_slimming["rules"]["skill_md_preview_lines"]
+        .as_u64()
+        .expect("preview line limit") as usize;
+    assert!(preview_count <= preview_limit);
+    let slimmed_context_text =
+        serde_json::to_string(&context_slimming["slimmed_context"]).expect("serialize context");
+    assert!(!slimmed_context_text.contains(&source.display().to_string()));
+    assert!(!slimmed_context_text.contains("Reference body"));
+}
