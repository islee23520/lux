+
+    #[test]
+    fn event_envelope_roundtrips_optional_metadata() {
+        let event = EventEnvelope {
+            metadata: Some(json!({
+                "producer": "unity-editor",
+                "correlationId": "corr-1",
+                "attempt": 2,
+                "tags": ["phase6", "metadata"]
+            })),
+            ..EventEnvelope::schema_example()
+        };
+
+        let serialized = serde_json::to_value(&event).unwrap();
+        assert_eq!(serialized["metadata"]["producer"], "unity-editor");
+        assert_eq!(serialized["metadata"]["attempt"], 2);
+        assert_eq!(serialized["metadata"]["tags"][0], "phase6");
+
+        let deserialized: EventEnvelope = serde_json::from_value(serialized).unwrap();
+        assert_eq!(
+            deserialized.metadata.unwrap()["correlationId"],
+            "corr-1"
+        );
+    }
+
+    #[test]
+    fn event_envelope_deserializes_absent_or_null_metadata_as_none() {
+        let absent: EventEnvelope = serde_json::from_value(json!({
+            "schema_version": 0,
+            "event_id": "absent-metadata",
+            "category": "tool",
+            "source": "codex",
+            "session_id": "session-1",
+            "captured_at_utc": "2026-05-04T00:00:00.0000000Z",
+            "payload": {"kind": "ai-work-step"}
+        }))
+        .unwrap();
+        let null = serde_json::from_value::<EventEnvelope>(json!({
+            "schema_version": 1,
+            "event_id": "null-metadata",
+            "category": "tool",
+            "source": "codex",
+            "session_id": "session-1",
+            "captured_at_utc": "2026-05-04T00:00:00.0000000Z",
+            "metadata": null,
+            "payload": {"kind": "ai-work-step"}
+        }))
+        .unwrap()
+        .normalize();
+
+        let absent = absent.normalize();
+        assert_eq!(absent.schema_version, PROTOCOL_VERSION);
+        assert!(absent.metadata.is_none());
+        assert!(null.metadata.is_none());
+        assert!(serde_json::to_value(null).unwrap().get("metadata").is_none());
+    }
 }
