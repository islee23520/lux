+#[test]
+fn ai_log_recent_json_skips_malformed_truncated_and_mixed_invalid_jsonl_files() {
+    let project_root = create_malformed_ai_log_fixture_project("lux-ai-log-malformed-mixed");
+    let output = Command::new(env!("CARGO_BIN_EXE_lux"))
+        .args([
+            "ai-log",
+            "recent",
+            "--project-path",
+            project_root.to_str().expect("project path UTF-8"),
+            "--limit",
+            "10",
+            "--json",
+        ])
+        .output()
+        .expect("run lux ai-log recent against malformed fixture");
+
+    assert_command_success(&output, "lux ai-log recent malformed fixture");
+    let stdout = String::from_utf8(output.stdout).expect("recent JSON stdout is UTF-8");
+    assert!(!stdout.contains("malformed-secret"));
+    assert!(!stdout.contains("truncated-secret"));
+    assert!(!stdout.contains("plain-invalid-secret"));
+
+    let parsed: Value = serde_json::from_str(&stdout).expect("recent JSON");
+    assert_eq!(parsed["count"], 3);
+    let entries = parsed["entries"].as_array().expect("entries array");
+    assert_eq!(entries[0]["line_number"], 1);
+    assert_eq!(entries[0]["value"]["summary"], "valid before malformed");
+    assert_eq!(entries[1]["line_number"], 4);
+    assert_eq!(entries[1]["value"]["summary"], "valid after truncated");
+    assert_eq!(entries[2]["line_number"], 6);
+    assert_eq!(
+        entries[2]["value"]["message"],
+        "valid after mixed invalid"
+    );
+
+    let _ = fs::remove_dir_all(project_root);
+}
