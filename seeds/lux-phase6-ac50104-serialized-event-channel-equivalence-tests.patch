+        [Test]
+        public void SerializedChannel_ProducesSameRuntimeRecordAsDirectLoggingApi()
+        {
+            string projectRoot = Path.Combine(tempDirectory, "Project");
+            string directLogPath = Path.Combine(tempDirectory, "direct-runtime-events.jsonl");
+            string channelLogPath = Path.Combine(tempDirectory, "channel-runtime-events.jsonl");
+            var directAttributes = new Dictionary<string, object>
+            {
+                ["entityId"] = "enemy-7",
+                ["scoreValue"] = 150,
+                ["isBoss"] = false,
+                ["position"] = new Vector3(12.5f, 0f, -3.25f)
+            };
+            var directMetadata = new Dictionary<string, string>
+            {
+                ["scenePath"] = "Assets/Scenes/Arena.unity",
+                ["source"] = "serialized-channel"
+            };
+            var directRecord = LuxRuntimeEvent.Emit(
+                "enemy_death",
+                directAttributes,
+                "Enemies/Enemy-7",
+                "Gameplay runtime enemy death logged.",
+                metadata: directMetadata,
+                options: new LuxRuntimeEventOptions
+                {
+                    ProjectRoot = projectRoot,
+                    LogPath = directLogPath
+                });
+            var configuredChannel = ScriptableObject.CreateInstance<LuxRuntimeEventChannel>();
+            var serializedChannel = ScriptableObject.CreateInstance<LuxRuntimeEventChannel>();
+            configuredChannel.Configure(
+                "enemy_death",
+                "Enemies/Enemy-7",
+                "Gameplay runtime enemy death logged.",
+                projectRoot,
+                channelLogPath,
+                new[]
+                {
+                    new LuxRuntimeEventChannelMetadata("scenePath", "Assets/Scenes/Arena.unity"),
+                    new LuxRuntimeEventChannelMetadata("source", "serialized-channel")
+                },
+                new[]
+                {
+                    LuxRuntimeEventChannelAttribute.String("entityId", "enemy-7"),
+                    LuxRuntimeEventChannelAttribute.Integer("scoreValue", 150),
+                    LuxRuntimeEventChannelAttribute.Boolean("isBoss", false),
+                    LuxRuntimeEventChannelAttribute.Vector3("position", new Vector3(12.5f, 0f, -3.25f))
+                });
+            EditorJsonUtility.FromJsonOverwrite(EditorJsonUtility.ToJson(configuredChannel), serializedChannel);
+
+            var channelRecord = serializedChannel.Emit();
+
+            AssertRuntimeRecordsMatch(directRecord, channelRecord);
+            Assert.That(File.ReadAllText(directLogPath), Does.Contain("\"eventType\":\"enemy_death\""));
+            Assert.That(File.ReadAllText(channelLogPath), Does.Contain("\"eventType\":\"enemy_death\""));
+            Assert.That(File.ReadAllText(channelLogPath), Does.Contain("\"projectPath\":\"" + Escape(projectRoot) + "\""));
+            UnityEngine.Object.DestroyImmediate(configuredChannel);
+            UnityEngine.Object.DestroyImmediate(serializedChannel);
+        }
