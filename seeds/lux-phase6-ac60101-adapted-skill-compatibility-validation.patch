 #[test]
+fn skill_install_adapt_incompatible_compatibility_metadata_exits_1() {
+    let home = create_temp_dir("lux-skill-adapt-compatibility-home");
+    let project = create_test_unity_project("lux-skill-adapt-compatibility-project", true);
+    let source = create_test_skill_source_with_compatibility(
+        "smoke-adapt-hdrp-only-skill",
+        Some(
+            r#"{
+    "requiresLuxPackage": true,
+    "requiredPackages": ["com.linalab.lux"],
+    "renderPipelines": ["hdrp"],
+    "platformTargets": ["android"],
+    "unityVersion": { "min": "6000.0" },
+    "requiredFeatures": ["package_dependency"]
+  }"#,
+        ),
+    );
+
+    let output = Command::new(env!("CARGO_BIN_EXE_lux"))
+        .args([
+            "skill",
+            "install",
+            "smoke-adapt-hdrp-only-skill",
+            "--source",
+            source.to_str().expect("source path UTF-8"),
+            "--project",
+            "--adapt",
+            "--json",
+        ])
+        .current_dir(&project)
+        .env("HOME", &home)
+        .output()
+        .expect("run incompatible compatibility lux skill install --adapt");
+
+    assert!(!output.status.success());
+    assert_eq!(output.status.code(), Some(1));
+    let parsed: Value = serde_json::from_slice(&output.stdout).expect("error JSON");
+    assert_eq!(parsed["installed"], false);
+    assert!(parsed["error"]
+        .as_str()
+        .expect("error string")
+        .contains("render_pipeline"));
+}
