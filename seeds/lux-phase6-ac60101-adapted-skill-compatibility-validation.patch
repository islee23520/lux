+impl SkillCompatibilityEvaluation {
+    fn to_json(&self) -> Value {
+        json!({
+            "schema": "lux.skill.compatibility.v1",
+            "status": if self.compatible { "compatible" } else { "incompatible" },
+            "declared": self.declared,
+            "checks": self.checks,
+            "warnings": self.warnings,
+        })
+    }
+}
+
+fn evaluate_skill_compatibility(
+    manifest: &SkillManifest,
+    project_metadata: &Value,
+) -> anyhow::Result<SkillCompatibilityEvaluation> {
+    let declared = manifest
+        .compatibility
+        .as_ref()
+        .map(serde_json::to_value)
+        .transpose()
+        .context("failed to serialize skill compatibility metadata")?
+        .unwrap_or(Value::Null);
+    let Some(compatibility) = manifest.compatibility.as_ref() else {
+        return Ok(SkillCompatibilityEvaluation {
+            compatible: true,
+            declared,
+            checks: vec![json!({
+                "name": "compatibility_metadata",
+                "ok": true,
+                "severity": "info",
+                "message": "Source manifest does not declare compatibility metadata; only default adaptation checks apply",
+            })],
+            warnings: vec!["source manifest does not declare compatibility metadata".to_string()],
+        });
+    };
+
+    let mut checks = Vec::new();
+
+    if compatibility.requires_lux_package.unwrap_or(false) {
+        let present = metadata_bool(
+            project_metadata,
+            &["package_manifest", "lux_package", "present"],
+        );
+        checks.push(json!({
+            "name": "requires_lux_package",
+            "ok": present,
+            "severity": "error",
+            "expected": true,
+            "actual": present,
+            "message": "Project Packages/manifest.json must include com.linalab.lux",
+        }));
+    }
+
+    if !compatibility.required_packages.is_empty() {
+        let dependencies = project_metadata
+            .get("package_manifest")
+            .and_then(|value| value.get("dependencies"))
+            .and_then(Value::as_object);
+        let missing = compatibility
+            .required_packages
+            .iter()
+            .filter(|package_name| {
+                dependencies
+                    .map(|dependencies| !dependencies.contains_key(package_name.as_str()))
+                    .unwrap_or(true)
+            })
+            .cloned()
+            .collect::<Vec<_>>();
+        checks.push(json!({
+            "name": "required_packages",
+            "ok": missing.is_empty(),
+            "severity": "error",
+            "expected": compatibility.required_packages,
+            "actual": dependencies
+                .map(|dependencies| dependencies.keys().cloned().collect::<Vec<_>>())
+                .unwrap_or_default(),
+            "missing": missing,
+            "message": "Project package dependencies must satisfy the adapted skill requirements",
+        }));
+    }
+
+    if !compatibility.render_pipelines.is_empty() {
+        let actual = metadata_string(project_metadata, &["render_pipeline", "pipeline"])
+            .unwrap_or_else(|| "unknown".to_string());
+        let ok = compatibility
+            .render_pipelines
+            .iter()
+            .any(|pipeline| pipeline.eq_ignore_ascii_case(&actual));
+        checks.push(json!({
+            "name": "render_pipeline",
+            "ok": ok,
+            "severity": "error",
+            "expected": compatibility.render_pipelines,
+            "actual": actual,
+            "message": "Project render pipeline must be supported by the adapted skill",
+        }));
+    }
+
+    if !compatibility.platform_targets.is_empty() {
+        let actual = metadata_string_array(
+            project_metadata,
+            &["platform_targets", "declared_or_referenced"],
+        );
+        let ok = compatibility.platform_targets.iter().any(|expected| {
+            actual
+                .iter()
+                .any(|actual| actual.eq_ignore_ascii_case(expected))
+        });
+        checks.push(json!({
+            "name": "platform_targets",
+            "ok": ok,
+            "severity": "error",
+            "expected": compatibility.platform_targets,
+            "actual": actual,
+            "message": "Project platform targets must overlap the adapted skill supported targets",
+        }));
+    }
+
+    if let Some(unity_version) = compatibility.unity_version.as_ref() {
+        let actual = metadata_string(project_metadata, &["unity", "version"]);
+        if let Some(minimum) = unity_version.min.as_deref() {
+            let ok = actual
+                .as_deref()
+                .map(|actual| version_at_least(actual, minimum))
+                .unwrap_or(false);
+            checks.push(json!({
+                "name": "unity_version_min",
+                "ok": ok,
+                "severity": "error",
+                "expected": minimum,
+                "actual": actual,
+                "message": "Project Unity version must be at least the adapted skill minimum",
+            }));
+        }
+        if let Some(maximum) = unity_version.max.as_deref() {
+            let ok = actual
+                .as_deref()
+                .map(|actual| version_at_most(actual, maximum))
+                .unwrap_or(false);
+            checks.push(json!({
+                "name": "unity_version_max",
+                "ok": ok,
+                "severity": "error",
+                "expected": maximum,
+                "actual": actual,
+                "message": "Project Unity version must not exceed the adapted skill maximum",
+            }));
+        }
+    }
+
+    if !compatibility.required_features.is_empty() {
+        let missing = compatibility
+            .required_features
+            .iter()
+            .filter(|feature| {
+                !metadata_bool(
+                    project_metadata,
+                    &["enabled_lux_features", feature.as_str()],
+                )
+            })
+            .cloned()
+            .collect::<Vec<_>>();
+        checks.push(json!({
+            "name": "required_features",
+            "ok": missing.is_empty(),
+            "severity": "error",
+            "expected": compatibility.required_features,
+            "missing": missing,
+            "message": "Project LUX feature signals must satisfy the adapted skill requirements",
+        }));
+    }
+
+    Ok(SkillCompatibilityEvaluation {
+        compatible: failed_compatibility_check_names(&checks).is_empty(),
+        declared,
+        checks,
+        warnings: Vec::new(),
+    })
+}
+
+fn metadata_bool(metadata: &Value, path: &[&str]) -> bool {
+    metadata_path(metadata, path)
+        .and_then(Value::as_bool)
+        .unwrap_or(false)
+}
+
+fn metadata_string(metadata: &Value, path: &[&str]) -> Option<String> {
+    metadata_path(metadata, path)
+        .and_then(Value::as_str)
+        .map(ToOwned::to_owned)
+}
+
+fn metadata_string_array(metadata: &Value, path: &[&str]) -> Vec<String> {
+    metadata_path(metadata, path)
+        .and_then(Value::as_array)
+        .map(|items| {
+            items
+                .iter()
+                .filter_map(Value::as_str)
+                .map(ToOwned::to_owned)
+                .collect()
+        })
+        .unwrap_or_default()
+}
+
+fn metadata_path<'a>(metadata: &'a Value, path: &[&str]) -> Option<&'a Value> {
+    path.iter()
+        .try_fold(metadata, |current, segment| current.get(*segment))
+}
+
+fn failed_compatibility_check_names(checks: &[Value]) -> Vec<String> {
+    checks
+        .iter()
+        .filter(|check| {
+            check.get("severity").and_then(Value::as_str) == Some("error")
+                && check.get("ok").and_then(Value::as_bool) == Some(false)
+        })
+        .filter_map(|check| check.get("name").and_then(Value::as_str))
+        .map(ToOwned::to_owned)
+        .collect()
+}
+
+fn version_at_least(actual: &str, minimum: &str) -> bool {
+    compare_version(actual, minimum)
+        .map(|ordering| ordering != std::cmp::Ordering::Less)
+        .unwrap_or(false)
+}
+
+fn version_at_most(actual: &str, maximum: &str) -> bool {
+    compare_version(actual, maximum)
+        .map(|ordering| ordering != std::cmp::Ordering::Greater)
+        .unwrap_or(false)
+}
+
+fn compare_version(left: &str, right: &str) -> Option<std::cmp::Ordering> {
+    let left = parse_version_components(left)?;
+    let right = parse_version_components(right)?;
+    let width = left.len().max(right.len());
+    for index in 0..width {
+        let left_part = left.get(index).copied().unwrap_or(0);
+        let right_part = right.get(index).copied().unwrap_or(0);
+        match left_part.cmp(&right_part) {
+            std::cmp::Ordering::Equal => {}
+            ordering => return Some(ordering),
+        }
+    }
+    Some(std::cmp::Ordering::Equal)
+}
+
+fn parse_version_components(version: &str) -> Option<Vec<u64>> {
+    let parts = version
+        .split(|character: char| !character.is_ascii_digit())
+        .filter(|part| !part.is_empty())
+        .map(str::parse::<u64>)
+        .collect::<Result<Vec<_>, _>>()
+        .ok()?;
+    if parts.is_empty() {
+        None
+    } else {
+        Some(parts)
+    }
+}
