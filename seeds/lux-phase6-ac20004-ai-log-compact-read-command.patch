+#[test]
+fn ai_log_compact_json_reads_project_scoped_flat_entries_without_rewriting_log() {
+    let project_root = create_ai_log_fixture_project("lux-ai-log-compact-read");
+    let log_path = project_root.join(".lux/ai-action-log.jsonl");
+    let before = fs::read_to_string(&log_path).expect("read fixture before compact read");
+    let output = Command::new(env!("CARGO_BIN_EXE_lux"))
+        .args([
+            "ai-log",
+            "compact",
+            "--project-path",
+            project_root.to_str().expect("project path UTF-8"),
+            "--limit",
+            "2",
+            "--json",
+        ])
+        .output()
+        .expect("run lux ai-log compact read");
+
+    assert_command_success(&output, "lux ai-log compact read");
+    let parsed: Value = serde_json::from_slice(&output.stdout).expect("compact read JSON");
+    assert_eq!(
+        parsed["projectPath"],
+        project_root.to_str().expect("project path UTF-8")
+    );
+    assert!(parsed["path"]
+        .as_str()
+        .expect("compact read path string")
+        .ends_with(".lux/ai-action-log.jsonl"));
     assert_eq!(parsed["count"], 2);
     let entries = parsed["entries"].as_array().expect("entries array");
+    assert_eq!(entries[0]["lineNumber"], 4);
     assert_eq!(entries[0]["summary"], "third codex edit");
+    assert_eq!(entries[0]["message"], "third codex edit");
+    assert_eq!(entries[0]["type"], "append");
     assert_eq!(entries[1]["summary"], "opencode review");
+    assert_eq!(entries[1]["category"], "review");
+    assert!(entries[1].get("value").is_none());
+    assert_eq!(
+        fs::read_to_string(&log_path).expect("read fixture after compact read"),
+        before
+    );
 }
 
