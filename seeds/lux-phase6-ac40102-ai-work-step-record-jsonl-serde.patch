+pub fn serialize_ai_work_step_record(record: &Value) -> Result<String> {
+    validate_ai_work_step_record(record)?;
+    let line =
+        serde_json::to_string(record).context("failed to encode AI work step JSONL record")?;
+    if line.contains('\n') {
+        anyhow::bail!("AI work step JSONL record encoded with an embedded newline");
+    }
+
+    Ok(line)
+}
+
+pub fn deserialize_ai_work_step_record(line: &str) -> Result<Value> {
+    let trimmed = line.trim();
+    if trimmed.is_empty() {
+        anyhow::bail!("AI work step JSONL record line is empty");
+    }
+
+    let value = serde_json::from_str::<Value>(trimmed)
+        .context("failed to decode AI work step JSONL record")?;
+    validate_ai_work_step_record(&value)?;
+    Ok(value)
+}
+
+pub fn parse_ai_work_step_records(reader: impl BufRead) -> Vec<AiLogEntry> {
+    reader
+        .lines()
+        .enumerate()
+        .filter_map(|(index, line)| {
+            let value = deserialize_ai_work_step_record(&line.ok()?).ok()?;
+            Some(AiLogEntry {
+                line_number: index + 1,
+                timestamp: timestamp(&value).unwrap_or_default(),
+                value,
+            })
+        })
+        .collect()
+}
 
