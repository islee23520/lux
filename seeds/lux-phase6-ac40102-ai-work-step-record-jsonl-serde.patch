+                    "name": "apply_patch",
+                    "action": "edit",
+                    "exitCode": 0
+                },
+                "content": {
+                    "summary": "Applied a patch to the AI action log tests.",
+                    "inputSummary": "[REDACTED]"
+                }
+            }
+        });
+
+        let line = serialize_ai_work_step_record(&record).unwrap();
+
+        assert!(!line.contains('\n'));
+        assert!(line.contains("\\nwithout splitting"));
+        assert!(line.ends_with('}'));
+        let decoded = deserialize_ai_work_step_record(&line).unwrap();
+
+        assert_eq!(decoded["payload"]["kind"], "ai-work-step");
+        assert_eq!(decoded["payload"]["stepName"], "apply_patch");
+        assert_eq!(decoded["payload"]["ordering"]["sequence"], 3);
+        assert_eq!(
