+fn validate_ai_work_step_record(value: &Value) -> Result<()> {
+    if !value.is_object() {
+        anyhow::bail!("AI work step JSONL record must be a JSON object");
+    }
+
+    let payload = value
+        .get("payload")
+        .and_then(Value::as_object)
+        .context("AI work step JSONL record must include an object payload")?;
+    let kind = payload
+        .get("kind")
+        .and_then(Value::as_str)
+        .context("AI work step JSONL record payload must include kind")?;
+    if kind != "ai-work-step" {
+        anyhow::bail!("AI work step JSONL record payload kind must be ai-work-step");
+    }
+
+    Ok(())
+}
