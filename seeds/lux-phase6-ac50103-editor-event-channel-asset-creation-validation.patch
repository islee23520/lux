diff --git a/LuxEditor/LuxRuntimeEventChannelAssetUtility.cs b/LuxEditor/LuxRuntimeEventChannelAssetUtility.cs
new file mode 100644
index 0000000..3cb3b94
--- /dev/null
+++ b/LuxEditor/LuxRuntimeEventChannelAssetUtility.cs
@@ -0,0 +1,309 @@
+using System;
+using System.Collections.Generic;
+using System.IO;
+using Linalab.Lux.Runtime;
+using UnityEditor;
+using UnityEngine;
+
+namespace Linalab.Lux.Editor
+{
+    public sealed class LuxRuntimeEventChannelValidationResult
+    {
+        readonly List<string> errors = new List<string>();
+        readonly List<string> warnings = new List<string>();
+
+        public IReadOnlyList<string> Errors => errors;
+        public IReadOnlyList<string> Warnings => warnings;
+        public bool IsValid => errors.Count == 0;
+        public bool HasWarnings => warnings.Count > 0;
+
+        internal void AddError(string message)
+        {
+            if (!string.IsNullOrWhiteSpace(message))
+            {
+                errors.Add(message);
+            }
+        }
+
+        internal void AddWarning(string message)
+        {
+            if (!string.IsNullOrWhiteSpace(message))
+            {
+                warnings.Add(message);
+            }
+        }
+    }
+
+    public static class LuxRuntimeEventChannelAssetUtility
+    {
+        public const string DefaultAssetName = "LuxRuntimeEventChannel.asset";
+
+        [MenuItem("Tools/Linalab/Lux/Runtime Events/Create Event Channel Asset")]
+        public static void CreateRuntimeEventChannelAssetFromMenu()
+        {
+            var channel = CreateRuntimeEventChannelAsset(GetSelectedAssetDirectory(), DefaultAssetName);
+            Selection.activeObject = channel;
+            EditorGUIUtility.PingObject(channel);
+            Debug.Log("Lux runtime event channel asset created: " + AssetDatabase.GetAssetPath(channel));
+        }
+
+        [MenuItem("Tools/Linalab/Lux/Runtime Events/Assign Selected Event Channel To Emitters", true)]
+        static bool CanAssignSelectedEventChannelToEmitters()
+        {
+            return FindSelectedChannel() != null && FindSelectedEmitters().Count > 0;
+        }
+
+        [MenuItem("Tools/Linalab/Lux/Runtime Events/Assign Selected Event Channel To Emitters")]
+        public static void AssignSelectedEventChannelToEmittersFromMenu()
+        {
+            var channel = FindSelectedChannel();
+            var emitters = FindSelectedEmitters();
+            int assigned = AssignChannelToEmitters(channel, emitters);
+            Debug.Log("Lux runtime event channel assigned to " + assigned + " emitter(s).");
+        }
+
+        public static LuxRuntimeEventChannel CreateRuntimeEventChannelAsset(
+            string directoryAssetPath = "Assets",
+            string assetName = DefaultAssetName)
+        {
+            string directory = NormalizeAssetDirectory(directoryAssetPath);
+            string fileName = NormalizeAssetName(assetName);
+            string path = AssetDatabase.GenerateUniqueAssetPath(CombineAssetPath(directory, fileName));
+            var channel = ScriptableObject.CreateInstance<LuxRuntimeEventChannel>();
+            AssetDatabase.CreateAsset(channel, path);
+            AssetDatabase.SaveAssets();
+            AssetDatabase.ImportAsset(path, ImportAssetOptions.ForceUpdate);
+            return AssetDatabase.LoadAssetAtPath<LuxRuntimeEventChannel>(path) ?? channel;
+        }
+
+        public static int AssignChannelToEmitters(
+            LuxRuntimeEventChannel channel,
+            IEnumerable<LuxRuntimeEventChannelEmitter> emitters)
+        {
+            if (channel == null || emitters == null)
+            {
+                return 0;
+            }
+
+            int assigned = 0;
+            foreach (var emitter in emitters)
+            {
+                if (emitter == null)
+                {
+                    continue;
+                }
+
+                var serialized = new SerializedObject(emitter);
+                var eventChannel = serialized.FindProperty("eventChannel");
+                if (eventChannel == null)
+                {
+                    continue;
+                }
+
+                eventChannel.objectReferenceValue = channel;
+                serialized.ApplyModifiedProperties();
+                EditorUtility.SetDirty(emitter);
+                assigned++;
+            }
+
+            return assigned;
+        }
+
+        public static LuxRuntimeEventChannelValidationResult ValidateChannel(LuxRuntimeEventChannel channel)
+        {
+            var result = new LuxRuntimeEventChannelValidationResult();
+            if (channel == null)
+            {
+                result.AddError("eventChannel asset reference is missing.");
+                return result;
+            }
+
+            var serialized = new SerializedObject(channel);
+            string eventType = ReadString(serialized, "eventType");
+            if (string.IsNullOrWhiteSpace(eventType))
+            {
+                result.AddError("eventType must be configured before runtime gameplay events can be emitted.");
+            }
+
+            string target = ReadString(serialized, "target");
+            if (string.IsNullOrWhiteSpace(target))
+            {
+                result.AddWarning("target is empty; runtime events will be readable but less specific.");
+            }
+
+            string summary = ReadString(serialized, "summary");
+            if (string.IsNullOrWhiteSpace(summary))
+            {
+                result.AddWarning("summary is empty; the runtime event logger will synthesize a default summary.");
+            }
+
+            ValidateOptionalOverride(serialized, "useProjectRootOverride", "projectRootOverride", "projectRootOverride", result);
+            ValidateOptionalOverride(serialized, "useLogPathOverride", "logPathOverride", "logPathOverride", result);
+            ValidateRetention(serialized, result);
+            return result;
+        }
+
+        public static LuxRuntimeEventChannelValidationResult ValidateEmitter(LuxRuntimeEventChannelEmitter emitter)
+        {
+            var result = new LuxRuntimeEventChannelValidationResult();
+            if (emitter == null)
+            {
+                result.AddError("runtime event channel emitter is missing.");
+                return result;
+            }
+
+            var serialized = new SerializedObject(emitter);
+            var eventChannel = serialized.FindProperty("eventChannel");
+            if (eventChannel == null)
+            {
+                result.AddError("eventChannel serialized field is missing.");
+                return result;
+            }
+
+            if (eventChannel.objectReferenceValue == null)
+            {
+                result.AddError("eventChannel must reference a LuxRuntimeEventChannel asset before this emitter can log events.");
+            }
+
+            string eventTypeOverride = ReadString(serialized, "eventTypeOverride");
+            if (string.IsNullOrWhiteSpace(eventTypeOverride) && eventChannel.objectReferenceValue == null)
+            {
+                result.AddWarning("eventTypeOverride is empty and no channel asset is assigned.");
+            }
+
+            return result;
+        }
+
+        internal static void DrawValidationResult(LuxRuntimeEventChannelValidationResult result)
+        {
+            if (result == null)
+            {
+                return;
+            }
+
+            foreach (string error in result.Errors)
+            {
+                EditorGUILayout.HelpBox(error, MessageType.Error);
+            }
+
+            foreach (string warning in result.Warnings)
+            {
+                EditorGUILayout.HelpBox(warning, MessageType.Warning);
+            }
+        }
+
+        internal static string GetSelectedAssetDirectory()
+        {
+            var selected = Selection.activeObject;
+            if (selected == null)
+            {
+                return "Assets";
+            }
+
+            string path = AssetDatabase.GetAssetPath(selected);
+            return NormalizeAssetDirectory(path);
+        }
+
+        internal static LuxRuntimeEventChannel FindSelectedChannel()
+        {
+            foreach (var selected in Selection.objects)
+            {
+                var channel = selected as LuxRuntimeEventChannel;
+                if (channel != null)
+                {
+                    return channel;
+                }
+            }
+
+            return null;
+        }
+
+        internal static List<LuxRuntimeEventChannelEmitter> FindSelectedEmitters()
+        {
+            var emitters = new List<LuxRuntimeEventChannelEmitter>();
+            var seen = new HashSet<int>();
+            foreach (var selected in Selection.objects)
+            {
+                var emitter = selected as LuxRuntimeEventChannelEmitter;
+                if (emitter != null)
+                {
+                    AddEmitter(emitter, emitters, seen);
+                    continue;
+                }
+
+                var gameObject = selected as GameObject;
+                if (gameObject == null)
+                {
+                    continue;
+                }
+
+                foreach (var component in gameObject.GetComponents<LuxRuntimeEventChannelEmitter>())
+                {
+                    AddEmitter(component, emitters, seen);
+                }
+            }
+
+            return emitters;
+        }
+
+        static void AddEmitter(
+            LuxRuntimeEventChannelEmitter emitter,
+            ICollection<LuxRuntimeEventChannelEmitter> emitters,
+            ISet<int> seen)
+        {
+            if (emitter == null)
+            {
+                return;
+            }
+
+            int instanceId = emitter.GetInstanceID();
+            if (seen.Add(instanceId))
+            {
+                emitters.Add(emitter);
+            }
+        }
+
+        static void ValidateOptionalOverride(
+            SerializedObject serialized,
+            string enabledPropertyName,
+            string valuePropertyName,
+            string displayName,
+            LuxRuntimeEventChannelValidationResult result)
+        {
+            var enabledProperty = serialized.FindProperty(enabledPropertyName);
+            if (enabledProperty == null || !enabledProperty.boolValue)
+            {
+                return;
+            }
+
+            string value = ReadString(serialized, valuePropertyName);
+            if (string.IsNullOrWhiteSpace(value))
+            {
+                result.AddError(displayName + " is enabled but has no value.");
+            }
+        }
+
+        static void ValidateRetention(SerializedObject serialized, LuxRuntimeEventChannelValidationResult result)
+        {
+            var retention = serialized.FindProperty("retention");
+            if (retention == null)
+            {
+                result.AddError("retention settings are missing.");
+                return;
+            }
+
+            var enabled = retention.FindPropertyRelative("enabled");
+            var retentionDays = retention.FindPropertyRelative("retentionDays");
+            var maxEntries = retention.FindPropertyRelative("maxEntries");
+            if (enabled != null && !enabled.boolValue)
+            {
+                result.AddWarning("retention is disabled for this channel asset.");
+                return;
+            }
+
+            if (retentionDays == null || retentionDays.intValue < 1)
+            {
+                result.AddError("retentionDays must be at least 1 when retention is enabled.");
+            }
+
+            if (maxEntries == null || maxEntries.intValue < 1)
+            {
+                result.AddError("maxEntries must be at least 1 when retention is enabled.");
+            }
+        }
+
+        static string ReadString(SerializedObject serialized, string propertyName)
+        {
+            var property = serialized.FindProperty(propertyName);
+            return property == null ? string.Empty : property.stringValue;
+        }
+
+        static string NormalizeAssetDirectory(string path)
+        {
+            if (string.IsNullOrWhiteSpace(path))
+            {
+                return "Assets";
+            }
+
+            string normalized = path.Replace("\\", "/");
+            if (!AssetDatabase.IsValidFolder(normalized))
+            {
+                normalized = Path.GetDirectoryName(normalized);
+                normalized = string.IsNullOrWhiteSpace(normalized) ? "Assets" : normalized.Replace("\\", "/");
+            }
+
+            return AssetDatabase.IsValidFolder(normalized) ? normalized : "Assets";
+        }
+
+        static string NormalizeAssetName(string assetName)
+        {
+            string fileName = string.IsNullOrWhiteSpace(assetName) ? DefaultAssetName : assetName.Trim();
+            if (!string.Equals(Path.GetExtension(fileName), ".asset", StringComparison.OrdinalIgnoreCase))
+            {
+                fileName += ".asset";
+            }
+
+            return string.IsNullOrWhiteSpace(Path.GetFileNameWithoutExtension(fileName)) ? DefaultAssetName : fileName;
+        }
+
+        static string CombineAssetPath(string directory, string fileName)
+        {
+            return (directory.TrimEnd('/') + "/" + fileName).Replace("\\", "/");
+        }
+    }
+}
