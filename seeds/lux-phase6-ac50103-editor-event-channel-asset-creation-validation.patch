+using Linalab.Lux.Editor;
+using Linalab.Lux.Runtime;
+using NUnit.Framework;
+using UnityEditor;
+using UnityEngine;
+
+namespace Linalab.LuxEditor.Tests
+{
+    public sealed class LuxRuntimeEventChannelEditorAssetTests
+    {
+        const string TestAssetRoot = "Assets/LuxRuntimeEventChannelEditorAssetTests";
+
+        [SetUp]
+        public void SetUp()
+        {
+            DeleteTestAssetRoot();
+            AssetDatabase.CreateFolder("Assets", "LuxRuntimeEventChannelEditorAssetTests");
+        }
+
+        [TearDown]
+        public void TearDown()
+        {
+            DeleteTestAssetRoot();
+        }
+
+        [Test]
+        public void CreateRuntimeEventChannelAsset_CreatesSerializableAssetWithValidDefaults()
+        {
+            var channel = LuxRuntimeEventChannelAssetUtility.CreateRuntimeEventChannelAsset(
+                TestAssetRoot,
+                "Checkpoint Channel");
+
+            string path = AssetDatabase.GetAssetPath(channel);
+            string json = EditorJsonUtility.ToJson(channel);
+            var validation = LuxRuntimeEventChannelAssetUtility.ValidateChannel(channel);
+
+            Assert.That(channel, Is.Not.Null);
+            Assert.That(path, Does.StartWith(TestAssetRoot + "/Checkpoint Channel"));
+            Assert.That(path, Does.EndWith(".asset"));
+            Assert.That(json, Does.Contain("runtime.event"));
+            Assert.That(validation.IsValid, Is.True, string.Join("\n", validation.Errors));
+        }
+
+        [Test]
+        public void AssignChannelToEmitters_WritesSerializedChannelReference()
+        {
+            var channel = LuxRuntimeEventChannelAssetUtility.CreateRuntimeEventChannelAsset(
+                TestAssetRoot,
+                "Assigned Channel.asset");
+            var gameObject = new GameObject("Runtime Event Source");
+            var emitter = gameObject.AddComponent<LuxRuntimeEventChannelEmitter>();
+
+            int assigned = LuxRuntimeEventChannelAssetUtility.AssignChannelToEmitters(
+                channel,
+                new[] { emitter });
+            var serialized = new SerializedObject(emitter);
+            var validation = LuxRuntimeEventChannelAssetUtility.ValidateEmitter(emitter);
+
+            Assert.That(assigned, Is.EqualTo(1));
+            Assert.That(serialized.FindProperty("eventChannel").objectReferenceValue, Is.SameAs(channel));
+            Assert.That(emitter.EventChannel, Is.SameAs(channel));
+            Assert.That(validation.IsValid, Is.True, string.Join("\n", validation.Errors));
+            UnityEngine.Object.DestroyImmediate(gameObject);
+        }
+
+        [Test]
+        public void ValidateEmitter_ReportsMissingSerializedChannelReference()
+        {
+            var gameObject = new GameObject("Unassigned Runtime Event Source");
+            var emitter = gameObject.AddComponent<LuxRuntimeEventChannelEmitter>();
+
+            var validation = LuxRuntimeEventChannelAssetUtility.ValidateEmitter(emitter);
+
+            Assert.That(validation.IsValid, Is.False);
+            Assert.That(string.Join("\n", validation.Errors), Does.Contain("eventChannel"));
+            UnityEngine.Object.DestroyImmediate(gameObject);
+        }
+
+        [Test]
+        public void ValidateChannel_ReportsInvalidSerializedConfiguration()
+        {
+            var channel = LuxRuntimeEventChannelAssetUtility.CreateRuntimeEventChannelAsset(
+                TestAssetRoot,
+                "Invalid Channel.asset");
+            var serialized = new SerializedObject(channel);
+            serialized.FindProperty("eventType").stringValue = string.Empty;
+            serialized.FindProperty("useLogPathOverride").boolValue = true;
+            serialized.FindProperty("logPathOverride").stringValue = string.Empty;
+            var retention = serialized.FindProperty("retention");
+            retention.FindPropertyRelative("retentionDays").intValue = 0;
+            retention.FindPropertyRelative("maxEntries").intValue = 0;
+            serialized.ApplyModifiedPropertiesWithoutUndo();
+
+            var validation = LuxRuntimeEventChannelAssetUtility.ValidateChannel(channel);
+            string errors = string.Join("\n", validation.Errors);
+
+            Assert.That(validation.IsValid, Is.False);
+            Assert.That(errors, Does.Contain("eventType"));
+            Assert.That(errors, Does.Contain("logPathOverride"));
+            Assert.That(errors, Does.Contain("retentionDays"));
+            Assert.That(errors, Does.Contain("maxEntries"));
+        }
+
+        [Test]
+        public void CreateAndAssign_SupportsUnitySerializationWorkflow()
+        {
+            var channel = LuxRuntimeEventChannelAssetUtility.CreateRuntimeEventChannelAsset(
+                TestAssetRoot,
+                "Serialized Workflow Channel.asset");
+            var first = new GameObject("First Runtime Event Source");
+            var second = new GameObject("Second Runtime Event Source");
+            var firstEmitter = first.AddComponent<LuxRuntimeEventChannelEmitter>();
+            var secondEmitter = second.AddComponent<LuxRuntimeEventChannelEmitter>();
+
+            int assigned = LuxRuntimeEventChannelAssetUtility.AssignChannelToEmitters(
+                channel,
+                new[] { firstEmitter, secondEmitter });
+
+            var firstSerialized = new SerializedObject(firstEmitter);
+            var secondSerialized = new SerializedObject(secondEmitter);
+
+            Assert.That(assigned, Is.EqualTo(2));
+            Assert.That(firstSerialized.FindProperty("eventChannel").objectReferenceValue, Is.SameAs(channel));
+            Assert.That(secondSerialized.FindProperty("eventChannel").objectReferenceValue, Is.SameAs(channel));
+            Assert.That(firstEmitter.EventChannel, Is.SameAs(channel));
+            Assert.That(secondEmitter.EventChannel, Is.SameAs(channel));
+            UnityEngine.Object.DestroyImmediate(first);
+            UnityEngine.Object.DestroyImmediate(second);
+        }
+
+        static void DeleteTestAssetRoot()
+        {
+            if (AssetDatabase.IsValidFolder(TestAssetRoot))
+            {
+                AssetDatabase.DeleteAsset(TestAssetRoot);
+            }
+        }
+    }
+}
