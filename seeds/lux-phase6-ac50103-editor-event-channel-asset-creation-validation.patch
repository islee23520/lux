+using Linalab.Lux.Runtime;
+using UnityEditor;
+using UnityEngine;
+
+namespace Linalab.Lux.Editor
+{
+    [CustomEditor(typeof(LuxRuntimeEventChannel))]
+    public sealed class LuxRuntimeEventChannelEditor : UnityEditor.Editor
+    {
+        public override void OnInspectorGUI()
+        {
+            DrawDefaultInspector();
+            EditorGUILayout.Space();
+            EditorGUILayout.LabelField("LUX Validation", EditorStyles.boldLabel);
+            LuxRuntimeEventChannelAssetUtility.DrawValidationResult(
+                LuxRuntimeEventChannelAssetUtility.ValidateChannel((LuxRuntimeEventChannel)target));
+        }
+    }
+
+    [CustomEditor(typeof(LuxRuntimeEventChannelEmitter))]
+    public sealed class LuxRuntimeEventChannelEmitterEditor : UnityEditor.Editor
+    {
+        public override void OnInspectorGUI()
+        {
+            DrawDefaultInspector();
+            EditorGUILayout.Space();
+            EditorGUILayout.LabelField("LUX Validation", EditorStyles.boldLabel);
+
+            var emitter = (LuxRuntimeEventChannelEmitter)target;
+            LuxRuntimeEventChannelAssetUtility.DrawValidationResult(
+                LuxRuntimeEventChannelAssetUtility.ValidateEmitter(emitter));
+
+            using (new EditorGUILayout.HorizontalScope())
+            {
+                if (GUILayout.Button("Create Channel Asset"))
+                {
+                    CreateAndAssignChannel(emitter);
+                }
+
+                if (GUILayout.Button("Select Channel"))
+                {
+                    SelectAssignedChannel(emitter);
+                }
+            }
+        }
+
+        static void CreateAndAssignChannel(LuxRuntimeEventChannelEmitter emitter)
+        {
+            string name = emitter == null || emitter.gameObject == null
+                ? LuxRuntimeEventChannelAssetUtility.DefaultAssetName
+                : emitter.gameObject.name + " Event Channel.asset";
+            var channel = LuxRuntimeEventChannelAssetUtility.CreateRuntimeEventChannelAsset(
+                LuxRuntimeEventChannelAssetUtility.GetSelectedAssetDirectory(),
+                name);
+            LuxRuntimeEventChannelAssetUtility.AssignChannelToEmitters(channel, new[] { emitter });
+            Selection.activeObject = channel;
+            EditorGUIUtility.PingObject(channel);
+        }
+
+        static void SelectAssignedChannel(LuxRuntimeEventChannelEmitter emitter)
+        {
+            var channel = emitter == null ? null : emitter.EventChannel;
+            if (channel == null)
+            {
+                return;
+            }
+
+            Selection.activeObject = channel;
+            EditorGUIUtility.PingObject(channel);
+        }
+    }
+}
