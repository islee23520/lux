+        static void GuardEditorHook(string hookName, Action action)
+        {
+            try
+            {
+                action?.Invoke();
+            }
+            catch (Exception exception)
+            {
+                RecordInstrumentationFailure("hook", hookName, exception);
+            }
+        }
+
+        static void RecordInstrumentationFailure(string stage, string hookName, Exception exception)
+        {
+            lock (Sync)
+            {
+                switch (stage)
+                {
+                    case "log":
+                        logFailureCount++;
+                        break;
+                    case "broadcast":
+                        broadcastFailureCount++;
+                        break;
+                    case "flush":
+                        flushFailureCount++;
+                        break;
+                    case "time":
+                        timeProviderFailureCount++;
+                        break;
+                    default:
+                        hookFailureCount++;
+                        stage = "hook";
+                        break;
+                }
+
+                lastFailureStage = stage;
+                lastFailureHook = string.IsNullOrWhiteSpace(hookName) ? "unknown" : hookName;
+                lastFailureMessage = TruncateDiagnostic(exception == null ? string.Empty : exception.Message);
+            }
         }
 
+        static void ResetInstrumentationDiagnostics()
+        {
+            hookFailureCount = 0;
+            logFailureCount = 0;
+            broadcastFailureCount = 0;
+            flushFailureCount = 0;
+            timeProviderFailureCount = 0;
+            lastFailureStage = string.Empty;
+            lastFailureHook = string.Empty;
+            lastFailureMessage = string.Empty;
+        }
+
+        static string TruncateDiagnostic(string value)
+        {
+            if (string.IsNullOrEmpty(value) || value.Length <= MaxDiagnosticMessageLength)
+            {
+                return value ?? string.Empty;
+            }
+
+            return value.Substring(0, MaxDiagnosticMessageLength) + "[TRUNCATED]";
+        }
