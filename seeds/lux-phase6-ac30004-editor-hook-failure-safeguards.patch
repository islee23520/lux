+
+            var diagnostics = UnityEditor.LuxAiActionLogBroadcaster.InstrumentationDiagnostics();
+            Assert.That(diagnostics.HookFailureCount, Is.EqualTo(1));
+            Assert.That(diagnostics.TotalFailureCount, Is.EqualTo(1));
+            Assert.That(diagnostics.LastFailureStage, Is.EqualTo("hook"));
+            Assert.That(diagnostics.LastFailureHook, Is.EqualTo("failing.editorHook"));
+            Assert.That(diagnostics.LastFailureMessage, Does.Contain("simulated editor hook failure"));
