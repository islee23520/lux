+use std::{fs, path::Path};
+
+use serde_json::{json, Value};
+
+use crate::ai_log;
+
+pub fn collect_project_metadata_signals(project_root: &Path) -> Value {
+    let package_manifest = read_package_manifest_signals(project_root);
+    json!({
+        "schema": "lux.project_metadata_signals.v1",
+        "collection": {
+            "mode": "offline_file_scan",
+            "requires_unity_editor": false,
+        },
+        "unity": read_unity_project_version_signal(project_root),
+        "package_manifest": package_manifest,
+        "enabled_lux_features": detect_lux_feature_signals(project_root),
+        "render_pipeline": detect_render_pipeline_signals(project_root),
+        "platform_targets": detect_platform_target_signals(project_root),
+        "project_settings": read_relevant_project_settings_signals(project_root),
+    })
+}
+
+pub fn sanitize_project_signal_value(value: &Value) -> Value {
+    match value {
+        Value::String(text) => Value::String(redact_project_signal_text(text)),
+        Value::Array(items) => {
+            Value::Array(items.iter().map(sanitize_project_signal_value).collect())
+        }
+        Value::Object(map) => Value::Object(
+            map.iter()
+                .map(|(key, value)| {
+                    (
+                        if looks_sensitive_key(key) {
+                            "<sensitive-key>".to_string()
+                        } else {
+                            key.clone()
+                        },
+                        sanitize_project_signal_value_for_key(key, value),
+                    )
+                })
+                .collect::<serde_json::Map<String, Value>>(),
+        ),
+        other => other.clone(),
+    }
+}
+
+fn read_unity_project_version_signal(project_root: &Path) -> Value {
+    let version_path = project_root.join("ProjectSettings/ProjectVersion.txt");
+    match fs::read_to_string(&version_path) {
+        Ok(text) => {
+            let version = text
+                .lines()
+                .find_map(|line| line.strip_prefix("m_EditorVersion:"))
+                .map(str::trim)
+                .filter(|value| !value.is_empty());
+            let version_with_revision = text
+                .lines()
+                .find_map(|line| line.strip_prefix("m_EditorVersionWithRevision:"))
+                .map(str::trim)
+                .filter(|value| !value.is_empty());
+            json!({
+                "available": version.is_some(),
+                "source": "ProjectSettings/ProjectVersion.txt",
+                "version": version,
+                "version_with_revision": version_with_revision,
+            })
+        }
+        Err(error) => json!({
+            "available": false,
+            "source": "ProjectSettings/ProjectVersion.txt",
+            "version": Value::Null,
+            "version_with_revision": Value::Null,
+            "warning": format!("failed to read ProjectVersion.txt: {error}"),
+        }),
+    }
+}
+
+fn read_package_manifest_signals(project_root: &Path) -> Value {
+    let manifest_path = project_root.join("Packages/manifest.json");
+    match fs::read_to_string(&manifest_path) {
+        Ok(text) => match serde_json::from_str::<Value>(&text) {
+            Ok(manifest) => {
+                let dependencies = manifest
+                    .get("dependencies")
+                    .and_then(Value::as_object)
+                    .map(|map| {
+                        map.iter()
+                            .map(|(name, value)| {
+                                (
+                                    name.clone(),
+                                    sanitize_project_signal_value_for_key(name, value),
+                                )
+                            })
+                            .collect::<serde_json::Map<String, Value>>()
+                    })
+                    .unwrap_or_default();
+                let scoped_registries = manifest
+                    .get("scopedRegistries")
+                    .map(sanitize_project_signal_value)
+                    .unwrap_or_else(|| Value::Array(Vec::new()));
+                let lux_dependency = dependencies.get("com.linalab.lux").cloned();
+                json!({
+                    "available": true,
+                    "source": "Packages/manifest.json",
+                    "dependency_count": dependencies.len(),
+                    "dependencies": dependencies,
+                    "scoped_registries": scoped_registries,
+                    "lux_package": {
+                        "present": lux_dependency.is_some(),
+                        "version_or_source": lux_dependency,
+                    },
+                })
+            }
+            Err(error) => json!({
+                "available": false,
+                "source": "Packages/manifest.json",
+                "warning": format!("failed to parse Packages/manifest.json: {error}"),
+            }),
+        },
+        Err(error) => json!({
+            "available": false,
+            "source": "Packages/manifest.json",
+            "warning": format!("failed to read Packages/manifest.json: {error}"),
+        }),
+    }
+}
+
+fn detect_lux_feature_signals(project_root: &Path) -> Value {
+    json!({
+        "package_dependency": package_dependency_exists(project_root, "com.linalab.lux"),
+        "project_skills_directory": project_root.join(".lux/skills").is_dir(),
+        "ai_action_log": project_root.join("UserSettings/LuxAiActionLog.jsonl").is_file()
+            || project_root.join(".lux/ai-action-log.jsonl").is_file(),
+        "unity_ai_bridge_discovery": project_root.join("Library/UnityAiBridge/server.json").is_file(),
+        "project_lux_settings": project_root.join("ProjectSettings/LuxSettings.json").is_file(),
+    })
+}
+
+fn detect_render_pipeline_signals(project_root: &Path) -> Value {
+    let mut evidence = Vec::new();
+    let package_manifest = read_package_manifest_signals(project_root);
+    let dependencies = package_manifest
+        .get("dependencies")
+        .and_then(Value::as_object)
+        .cloned()
+        .unwrap_or_default();
+    let pipeline = if dependencies.contains_key("com.unity.render-pipelines.high-definition") {
+        evidence.push("Packages/manifest.json:com.unity.render-pipelines.high-definition");
+        "hdrp"
+    } else if dependencies.contains_key("com.unity.render-pipelines.universal") {
+        evidence.push("Packages/manifest.json:com.unity.render-pipelines.universal");
+        "urp"
+    } else if settings_file_contains(
+        project_root,
+        "ProjectSettings/GraphicsSettings.asset",
+        "HDRenderPipelineAsset",
+    ) {
+        evidence.push("ProjectSettings/GraphicsSettings.asset:HDRenderPipelineAsset");
+        "hdrp"
+    } else if settings_file_contains(
+        project_root,
+        "ProjectSettings/GraphicsSettings.asset",
+        "UniversalRenderPipelineAsset",
+    ) {
+        evidence.push("ProjectSettings/GraphicsSettings.asset:UniversalRenderPipelineAsset");
+        "urp"
+    } else {
+        "built-in-or-unknown"
+    };
+    json!({
+        "pipeline": pipeline,
+        "evidence": evidence,
+    })
+}
+
+fn detect_platform_target_signals(project_root: &Path) -> Value {
+    let settings_dir = project_root.join("ProjectSettings");
+    let probes = [
+        ("Standalone", "standalone"),
+        ("Android", "android"),
+        ("iPhone", "ios"),
+        ("iOS", "ios"),
+        ("WebGL", "webgl"),
+        ("tvOS", "tvos"),
+        ("VisionOS", "visionos"),
+    ];
+    let mut targets = Vec::new();
+
+    if let Ok(entries) = fs::read_dir(settings_dir) {
+        for entry in entries.flatten() {
+            let Ok(file_type) = entry.file_type() else {
+                continue;
+            };
+            if !file_type.is_file() {
+                continue;
+            }
+            let Ok(text) = fs::read_to_string(entry.path()) else {
+                continue;
+            };
+            for (needle, target) in &probes {
+                if text.contains(needle) && !targets.contains(target) {
+                    targets.push(*target);
+                }
+            }
+        }
+    }
+
+    targets.sort_unstable();
+    json!({
+        "declared_or_referenced": targets,
+        "source": "ProjectSettings/*",
+    })
+}
+
+fn read_relevant_project_settings_signals(project_root: &Path) -> Value {
+    let project_settings = read_yaml_like_settings_file(
+        &project_root.join("ProjectSettings/ProjectSettings.asset"),
+        "ProjectSettings/ProjectSettings.asset",
+        &[
+            "companyName",
+            "productName",
+            "bundleVersion",
+            "applicationIdentifier",
+            "scriptingBackend",
+            "apiCompatibilityLevelPerPlatform",
+            "activeColorSpace",
+            "defaultScreenOrientation",
+            "AndroidTargetArchitectures",
+        ],
+    );
+    let graphics_settings =
+        settings_file_signal(project_root, "ProjectSettings/GraphicsSettings.asset");
+    let quality_settings =
+        settings_file_signal(project_root, "ProjectSettings/QualitySettings.asset");
+    let editor_build_settings =
+        settings_file_signal(project_root, "ProjectSettings/EditorBuildSettings.asset");
+    json!({
+        "project_settings": project_settings,
+        "graphics_settings": graphics_settings,
+        "quality_settings": quality_settings,
+        "editor_build_settings": editor_build_settings,
+    })
+}
+
+fn read_yaml_like_settings_file(path: &Path, relative_path: &str, keys: &[&str]) -> Value {
+    match fs::read_to_string(path) {
+        Ok(text) => {
+            let mut values = serde_json::Map::new();
+            for line in text.lines() {
+                let Some((key, value)) = line.trim().split_once(':') else {
+                    continue;
+                };
+                let key = key.trim();
+                if keys.contains(&key) {
+                    values.insert(
+                        key.to_string(),
+                        sanitize_project_signal_value_for_key(
+                            key,
+                            &Value::String(value.trim().to_string()),
+                        ),
+                    );
+                }
+            }
+            json!({
+                "available": true,
+                "source": relative_path,
+                "signals": values,
+            })
+        }
+        Err(error) => json!({
+            "available": false,
+            "source": relative_path,
+            "warning": format!("failed to read settings file: {error}"),
+        }),
+    }
+}
+
+fn settings_file_signal(project_root: &Path, relative_path: &str) -> Value {
+    let path = project_root.join(relative_path);
+    match fs::metadata(&path) {
+        Ok(metadata) => json!({
+            "available": true,
+            "source": relative_path,
+            "byte_size": metadata.len(),
+        }),
+        Err(error) => json!({
+            "available": false,
+            "source": relative_path,
+            "warning": format!("failed to stat settings file: {error}"),
+        }),
+    }
+}
+
+fn package_dependency_exists(project_root: &Path, package_name: &str) -> bool {
+    let manifest_path = project_root.join("Packages/manifest.json");
+    let Ok(text) = fs::read_to_string(manifest_path) else {
+        return false;
+    };
+    let Ok(manifest) = serde_json::from_str::<Value>(&text) else {
+        return false;
+    };
+    manifest
+        .get("dependencies")
+        .and_then(Value::as_object)
+        .map(|dependencies| dependencies.contains_key(package_name))
+        .unwrap_or(false)
+}
+
+fn settings_file_contains(project_root: &Path, relative_path: &str, needle: &str) -> bool {
+    fs::read_to_string(project_root.join(relative_path))
+        .map(|text| text.contains(needle))
+        .unwrap_or(false)
+}
+
+fn sanitize_project_signal_value_for_key(key: &str, value: &Value) -> Value {
+    if looks_sensitive_key(key) {
+        return Value::String("[REDACTED]".to_string());
+    }
+    sanitize_project_signal_value(value)
+}
+
+fn redact_project_signal_text(text: &str) -> String {
+    ai_log::redact_secrets(text)
+}
+
+fn looks_sensitive_key(key: &str) -> bool {
+    let normalized = key.to_ascii_lowercase();
+    normalized.contains("token")
+        || normalized.contains("secret")
+        || normalized.contains("password")
+        || normalized.contains("api_key")
+        || normalized.contains("apikey")
+        || normalized.contains("accesskey")
+        || normalized.contains("privatekey")
+        || normalized.contains("credential")
+}
