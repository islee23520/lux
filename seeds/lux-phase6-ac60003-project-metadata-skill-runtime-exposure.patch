+fn build_skill_dispatch_params(
+    project_root: Option<&Path>,
+    skill_name: &str,
+    skill_params: Option<serde_json::Value>,
+) -> serde_json::Value {
+    let mut params = match skill_params {
+        Some(serde_json::Value::Object(map)) => map,
+        Some(value) => return value,
+        None => serde_json::Map::new(),
+    };
+
+    if params.contains_key("projectMetadata") || params.contains_key("luxAdaptation") {
+        return serde_json::Value::Object(params);
+    }
+
+    if let Some(adaptation) = read_project_skill_adaptation(project_root, skill_name) {
+        if let Some(project_metadata) = adaptation.get("project_metadata") {
+            params.insert(
+                "projectMetadata".to_string(),
+                project_metadata::sanitize_project_signal_value(project_metadata),
+            );
+        }
+        params.insert("luxAdaptation".to_string(), adaptation);
+    }
+
+    serde_json::Value::Object(params)
+}
+
+fn read_project_skill_adaptation(
+    project_root: Option<&Path>,
+    skill_name: &str,
+) -> Option<serde_json::Value> {
+    let project_root = project_root?;
+    if skill_name.is_empty()
+        || skill_name == "."
+        || skill_name == ".."
+        || skill_name.contains('/')
+        || skill_name.contains('\\')
+    {
+        return None;
+    }
+
+    let path = project_root
+        .join(".lux")
+        .join("skills")
+        .join(skill_name)
+        .join("lux-adaptation.json");
+    let content = fs::read_to_string(path).ok()?;
+    let parsed = serde_json::from_str::<serde_json::Value>(&content).ok()?;
+    Some(project_metadata::sanitize_project_signal_value(&parsed))
+}
