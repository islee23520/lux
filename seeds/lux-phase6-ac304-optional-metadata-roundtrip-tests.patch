+        [Test]
+        public void Record_PreservesOptionalMetadataAcrossSupportedEventPayloadTypes()
+        {
+            string path = GetTempLogPath();
+            using var log = new UnityEditor.LuxAiActionLog(logPath: path);
+
+            var editorEntry = log.Record(
+                "unity-editor",
+                "user",
+                "editor",
+                "selection.changed",
+                "Scene/Main Camera",
+                "Unity selection changed.",
+                metadata: new Dictionary<string, string>
+                {
+                    ["correlationId"] = "corr-editor-304",
+                    ["producer"] = "unity-editor",
+                    ["purpose"] = "editor-action-roundtrip"
+                },
+                payloadAttributes: new Dictionary<string, object>
+                {
+                    ["objectCount"] = 1,
+                    ["targetPath"] = "Scene/Main Camera"
+                });
+            var aiEntry = log.Record(
+                "ai-tool-dispatcher",
+                "codex",
+                "ai-tool",
+                "tool.apply_patch",
+                "apply_patch",
+                "AI tool step applied a source edit.",
+                metadata: new Dictionary<string, string>
+                {
+                    ["correlationId"] = "corr-ai-304",
+                    ["producer"] = "codex",
+                    ["purpose"] = "ai-work-step-roundtrip"
+                },
+                payloadAttributes: new Dictionary<string, object>
+                {
+                    ["executionId"] = "exec-304",
+                    ["stepName"] = "apply_patch",
+                    ["tool"] = "codex"
+                });
+            var runtimeEntry = log.Record(
+                "unity-runtime",
+                "gameplay",
+                "runtime",
+                "enemy_death",
+                "Enemies/Enemy-7",
+                "Gameplay runtime enemy death logged.",
+                metadata: new Dictionary<string, string>
+                {
+                    ["correlationId"] = "corr-runtime-304",
+                    ["producer"] = "gameplay",
+                    ["purpose"] = "runtime-gameplay-roundtrip"
+                },
+                payloadAttributes: new Dictionary<string, object>
+                {
+                    ["entityId"] = "enemy-7",
+                    ["scoreValue"] = 150
+                });
+            log.Flush();
+
+            string[] lines = File.ReadAllLines(path);
+
+            Assert.That(lines, Has.Length.EqualTo(3));
+            AssertMetadataRoundTrip(lines[0], editorEntry, "editor-action", "selection.changed", "corr-editor-304", "unity-editor", "editor-action-roundtrip");
+            AssertMetadataRoundTrip(lines[1], aiEntry, "ai-work-step", "tool.apply_patch", "corr-ai-304", "codex", "ai-work-step-roundtrip");
+            AssertMetadataRoundTrip(lines[2], runtimeEntry, "runtime-gameplay-event", "enemy_death", "corr-runtime-304", "gameplay", "runtime-gameplay-roundtrip");
+        }
+
+        static void AssertMetadataRoundTrip(
+            string line,
+            UnityEditor.LuxAiActionLogEntry entry,
+            string expectedPayloadKind,
+            string expectedEventType,
+            string expectedCorrelationId,
+            string expectedProducer,
+            string expectedPurpose)
+        {
+            var decoded = JsonUtility.FromJson<MetadataRoundTripLogRecordForTests>(line);
+
+            Assert.That(entry.metadata["correlationId"], Is.EqualTo(expectedCorrelationId));
+            Assert.That(entry.metadata["producer"], Is.EqualTo(expectedProducer));
+            Assert.That(entry.metadata["purpose"], Is.EqualTo(expectedPurpose));
+            Assert.That(entry.payload.kind, Is.EqualTo(expectedPayloadKind));
+            Assert.That(entry.payload.eventType, Is.EqualTo(expectedEventType));
+            Assert.That(line, Does.Contain("\"metadata\":{\"correlationId\":\"" + expectedCorrelationId + "\""));
+            Assert.That(decoded.metadata.correlationId, Is.EqualTo(expectedCorrelationId));
+            Assert.That(decoded.metadata.producer, Is.EqualTo(expectedProducer));
+            Assert.That(decoded.metadata.purpose, Is.EqualTo(expectedPurpose));
+            Assert.That(decoded.payload.kind, Is.EqualTo(expectedPayloadKind));
+            Assert.That(decoded.payload.eventType, Is.EqualTo(expectedEventType));
+        }
