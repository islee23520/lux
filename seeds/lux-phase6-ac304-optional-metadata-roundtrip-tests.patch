+    #[test]
+    fn event_envelopes_preserve_optional_metadata_for_supported_payload_types() {
+        let cases = vec![
+            (
+                EventPayloadKind::EditorAction,
+                editor_action_payload_example(),
+                "corr-editor-304",
+                "editor-action-roundtrip",
+            ),
+            (
+                EventPayloadKind::AiWorkStep,
+                ai_work_step_payload_example(),
+                "corr-ai-304",
+                "ai-work-step-roundtrip",
+            ),
+            (
+                EventPayloadKind::RuntimeGameplayEvent,
+                runtime_gameplay_payload_example(),
+                "corr-runtime-304",
+                "runtime-gameplay-roundtrip",
+            ),
+        ];
+
+        for (expected_kind, payload, correlation_id, purpose) in cases {
+            let event = EventEnvelope {
+                schema_version: PROTOCOL_VERSION,
+                event_id: format!("{correlation_id}-event"),
+                category: EventCategory::AiActionLog,
+                source: "phase6-tests".to_string(),
+                session_id: "session-304".to_string(),
+                captured_at_utc: "2026-05-04T00:00:00.0000000Z".to_string(),
+                metadata: Some(json!({
+                    "correlationId": correlation_id,
+                    "producer": "phase6-tests",
+                    "purpose": purpose,
+                    "optional": true
+                })),
+                payload: serde_json::to_value(payload).unwrap(),
+            };
+
+            let value = serde_json::to_value(&event).unwrap();
+
+            assert_eq!(value["metadata"]["correlationId"], correlation_id);
+            assert_eq!(value["metadata"]["purpose"], purpose);
+            assert_eq!(value["metadata"]["optional"], json!(true));
+
+            let roundtrip = EventEnvelope::from_json_value(value).unwrap();
+            let roundtrip_metadata = roundtrip
+                .metadata
+                .as_ref()
+                .expect("metadata survives event envelope roundtrip");
+            let roundtrip_payload =
+                EventPayloadConvention::from_json_value(roundtrip.payload).unwrap();
+
+            assert_eq!(roundtrip_metadata["correlationId"], correlation_id);
+            assert_eq!(roundtrip_metadata["purpose"], purpose);
+            assert_eq!(roundtrip_metadata["optional"], json!(true));
+            assert_eq!(roundtrip_payload.kind, expected_kind);
+            match expected_kind {
+                EventPayloadKind::EditorAction => {
+                    assert_eq!(roundtrip_payload.event_type, "selection.changed");
+                    assert_eq!(roundtrip_payload.attributes["objectCount"], json!(1));
+                }
+                EventPayloadKind::AiWorkStep => {
+                    assert_eq!(roundtrip_payload.event_type, "tool.apply_patch");
+                    assert_eq!(roundtrip_payload.attributes["stepName"], json!("apply_patch"));
+                }
+                EventPayloadKind::RuntimeGameplayEvent => {
+                    assert_eq!(roundtrip_payload.event_type, "enemy_death");
+                    assert_eq!(roundtrip_payload.attributes["entityId"], json!("enemy-7"));
+                }
+                EventPayloadKind::ToolCommand | EventPayloadKind::GatewaySignal => {
+                    panic!("AC304 only covers currently supported event log payload types");
+                }
+            }
+        }
+    }
