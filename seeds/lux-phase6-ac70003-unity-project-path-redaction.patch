+        static string ReplaceKnownPath(string value, string rawPath, string placeholder)
+        {
+            if (string.IsNullOrEmpty(value) || string.IsNullOrWhiteSpace(rawPath))
+            {
+                return value ?? string.Empty;
+            }
+
+            string result = value;
+            foreach (string variant in KnownPathVariants(rawPath))
+            {
+                result = ReplaceKnownPathVariant(result, variant, placeholder);
+            }
+
+            return result;
+        }
+
+        static IEnumerable<string> KnownPathVariants(string rawPath)
+        {
+            string normalized = NormalizePathForRedaction(rawPath);
+            if (string.IsNullOrEmpty(normalized))
+            {
+                yield break;
+            }
+
+            yield return normalized;
+            string backslash = normalized.Replace('/', '\\');
+            if (!string.Equals(backslash, normalized, StringComparison.Ordinal))
+            {
+                yield return backslash;
+            }
+        }
+
+        static string ReplaceKnownPathVariant(string value, string prefix, string placeholder)
+        {
+            if (string.IsNullOrEmpty(value) || string.IsNullOrEmpty(prefix))
+            {
+                return value ?? string.Empty;
+            }
+
+            var builder = new StringBuilder(value.Length);
+            int cursor = 0;
+            while (cursor < value.Length)
+            {
+                int index = value.IndexOf(prefix, cursor, StringComparison.OrdinalIgnoreCase);
+                if (index < 0)
+                {
+                    break;
+                }
+
+                int end = index + prefix.Length;
+                if (!IsPathBoundaryAfter(value, end))
+                {
+                    builder.Append(value, cursor, end - cursor);
+                    cursor = end;
+                    continue;
+                }
+
+                builder.Append(value, cursor, index - cursor);
+                builder.Append(placeholder);
+                cursor = end;
+            }
+
+            builder.Append(value, cursor, value.Length - cursor);
+            return builder.ToString();
+        }
+
+        static bool IsPathBoundaryAfter(string value, int index)
+        {
+            if (index >= value.Length)
+            {
+                return true;
+            }
+
+            char next = value[index];
+            return next == '/'
+                || next == '\\'
+                || char.IsWhiteSpace(next)
+                || next == '"'
+                || next == '\''
+                || next == ','
+                || next == ';'
+                || next == ':'
+                || next == ')'
+                || next == ']'
+                || next == '}';
+        }
+
+        static string NormalizeProjectScopedPlaceholders(string value)
+        {
+            string result = value ?? string.Empty;
+            foreach (string directory in new[] { "Assets", "Library", "Packages" })
+            {
+                result = NormalizeProjectDirectoryPlaceholder(result, directory);
+            }
+
+            return result;
+        }
+
+        static string NormalizeProjectDirectoryPlaceholder(string value, string directory)
+        {
+            string slashPrefix = ProjectPathPlaceholder + "/" + directory;
+            string backslashPrefix = ProjectPathPlaceholder + "\\" + directory;
+            return ReplaceProjectDirectoryPrefix(
+                ReplaceProjectDirectoryPrefix(value, slashPrefix, directory),
+                backslashPrefix,
+                directory);
+        }
+
+        static string ReplaceProjectDirectoryPrefix(string value, string prefix, string directory)
+        {
+            var builder = new StringBuilder(value.Length);
+            int cursor = 0;
+            while (cursor < value.Length)
+            {
+                int index = value.IndexOf(prefix, cursor, StringComparison.Ordinal);
+                if (index < 0)
+                {
+                    break;
+                }
+
+                int afterPrefix = index + prefix.Length;
+                bool exactDirectory = afterPrefix >= value.Length || IsPathBoundaryAfter(value, afterPrefix);
+                bool nestedDirectory = afterPrefix < value.Length && (value[afterPrefix] == '/' || value[afterPrefix] == '\\');
+                if (!exactDirectory && !nestedDirectory)
+                {
+                    builder.Append(value, cursor, afterPrefix - cursor);
+                    cursor = afterPrefix;
+                    continue;
+                }
+
+                builder.Append(value, cursor, index - cursor);
+                builder.Append(directory);
+                if (nestedDirectory)
+                {
+                    builder.Append('/');
+                    cursor = afterPrefix + 1;
+                }
+                else
+                {
+                    cursor = afterPrefix;
+                }
+            }
+
+            builder.Append(value, cursor, value.Length - cursor);
+            return builder.ToString();
+        }
+
+        static string NormalizeRedactedSeparators(string value)
+        {
+            string result = value ?? string.Empty;
+            foreach (string prefix in new[] { "Assets", "Library", "Packages", ProjectPathPlaceholder, HomePathPlaceholder })
+            {
+                result = result.Replace(prefix + "\\", prefix + "/");
+            }
+
+            return result;
+        }
+
+        static string SafeFullPath(string path)
+        {
+            if (string.IsNullOrWhiteSpace(path))
+            {
+                return string.Empty;
+            }
+
+            try
+            {
+                return Path.GetFullPath(path);
+            }
+            catch (ArgumentException)
+            {
+                return path;
+            }
+            catch (NotSupportedException)
+            {
+                return path;
+            }
+            catch (PathTooLongException)
+            {
+                return path;
+            }
+        }
+
+        static string NormalizePathForRedaction(string path)
+        {
+            return (path ?? string.Empty).Trim().Replace('\\', '/').TrimEnd('/');
+        }
