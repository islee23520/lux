+fn redact_unity_paths(text: &str, project_root: Option<&Path>) -> String {
+    let mut redacted = text.to_string();
+    if let Some(project_root) = project_root {
+        redacted = replace_known_path(&redacted, project_root, "<PROJECT>");
+        redacted = normalize_project_scoped_placeholders(&redacted);
+    }
