+fn replace_known_path(text: &str, path: &Path, placeholder: &str) -> String {
+    let mut output = text.to_string();
+    for variant in known_path_variants(path) {
+        output = replace_known_path_variant(&output, &variant, placeholder);
+    }
+    output
+}
+
+fn known_path_variants(path: &Path) -> Vec<String> {
+    let mut variants = Vec::new();
+    push_unique_string(
+        &mut variants,
+        normalize_path_for_redaction(&path.to_string_lossy()),
+    );
+    if let Ok(canonical) = path.canonicalize() {
+        push_unique_string(
+            &mut variants,
+            normalize_path_for_redaction(&canonical.to_string_lossy()),
+        );
+    }
+
+    let slash_variants = variants.clone();
+    for variant in slash_variants {
+        push_unique_string(&mut variants, variant.replace('/', "\\"));
+    }
+
+    variants
+        .into_iter()
+        .filter(|variant| !variant.is_empty())
+        .collect()
+}
+
+fn replace_known_path_variant(text: &str, prefix: &str, placeholder: &str) -> String {
+    if prefix.is_empty() {
+        return text.to_string();
+    }
+
+    let mut output = String::with_capacity(text.len());
+    let mut cursor = 0usize;
+    while cursor < text.len() {
+        let Some(relative) = find_ascii_case_insensitive(&text[cursor..], prefix) else {
+            break;
+        };
+        let start = cursor + relative;
+        let end = start + prefix.len();
+        if !is_path_boundary_after(text, end) {
+            output.push_str(&text[cursor..end]);
+            cursor = end;
+            continue;
+        }
+
+        output.push_str(&text[cursor..start]);
+        output.push_str(placeholder);
+        cursor = end;
+    }
+
+    output.push_str(&text[cursor..]);
+    output
+}
+
+fn is_path_boundary_after(text: &str, index: usize) -> bool {
+    text[index..].chars().next().map_or(true, |character| {
+        character == '/'
+            || character == '\\'
+            || character.is_whitespace()
+            || matches!(character, '"' | '\'' | ',' | ';' | ':' | ')' | ']' | '}')
+    })
+}
+
+fn normalize_project_scoped_placeholders(text: &str) -> String {
+    ["Assets", "Library", "Packages"]
+        .iter()
+        .fold(text.to_string(), |value, directory| {
+            normalize_project_directory_placeholder(&value, directory)
+        })
+}
+
+fn normalize_project_directory_placeholder(text: &str, directory: &str) -> String {
+    let slash_prefix = format!("<PROJECT>/{directory}");
+    let backslash_prefix = format!("<PROJECT>\\{directory}");
+    let text = replace_project_directory_prefix(text, &slash_prefix, directory);
+    replace_project_directory_prefix(&text, &backslash_prefix, directory)
+}
+
+fn replace_project_directory_prefix(text: &str, prefix: &str, directory: &str) -> String {
+    let mut output = String::with_capacity(text.len());
+    let mut cursor = 0usize;
+    while cursor < text.len() {
+        let Some(relative) = text[cursor..].find(prefix) else {
+            break;
+        };
+        let start = cursor + relative;
+        let after_prefix = start + prefix.len();
+        let nested_directory = text[after_prefix..]
+            .chars()
+            .next()
+            .is_some_and(|character| character == '/' || character == '\\');
+        let exact_directory = !nested_directory && is_path_boundary_after(text, after_prefix);
+        if !nested_directory && !exact_directory {
+            output.push_str(&text[cursor..after_prefix]);
+            cursor = after_prefix;
+            continue;
+        }
+
+        output.push_str(&text[cursor..start]);
+        output.push_str(directory);
+        if nested_directory {
+            output.push('/');
+            cursor = after_prefix + 1;
+        } else {
+            cursor = after_prefix;
+        }
+    }
+
+    output.push_str(&text[cursor..]);
+    output
+}
+
+fn normalize_redacted_separators(text: &str) -> String {
+    ["Assets", "Library", "Packages", "<PROJECT>", "<HOME>"]
+        .iter()
+        .fold(text.to_string(), |value, prefix| {
+            value.replace(&format!("{prefix}\\"), &format!("{prefix}/"))
+        })
+}
+
+fn normalize_path_for_redaction(path: &str) -> String {
+    path.trim().replace('\\', "/").trim_end_matches('/').to_string()
+}
+
+fn home_dir() -> Option<PathBuf> {
+    std::env::var_os("HOME")
+        .filter(|value| !value.is_empty())
+        .map(PathBuf::from)
+}
+
+fn find_ascii_case_insensitive(haystack: &str, needle: &str) -> Option<usize> {
+    haystack
+        .to_ascii_lowercase()
+        .find(&needle.to_ascii_lowercase())
+}
+
+fn push_unique_string(values: &mut Vec<String>, value: String) {
+    if !values.contains(&value) {
+        values.push(value);
+    }
 }
 
