+async fn install_project_skill(
+    State(state): State<GatewayState>,
+    headers: HeaderMap,
+    Json(request): Json<InstallSkillRequest>,
+) -> Result<(StatusCode, Json<serde_json::Value>), Response> {
+    require_token(&state, &headers)?;
+    let Some(project_root) = state.config.project_root.as_deref() else {
+        return Err(project_path_required());
+    };
+
+    crate::install_skill_for_project(
+        &request.name,
+        &request.source,
+        true,
+        request.adapt,
+        Some(project_root),
+    )
+    .map(|result| (StatusCode::CREATED, Json(result)))
+    .map_err(bad_request)
+}
+
+async fn get_project_skill_info(
+    State(state): State<GatewayState>,
+    headers: HeaderMap,
+    AxumPath(skill_name): AxumPath<String>,
+) -> Result<Json<serde_json::Value>, Response> {
+    require_token(&state, &headers)?;
+    let Some(project_root) = state.config.project_root.as_deref() else {
+        return Err(project_path_required());
+    };
+
+    let Some(info) =
+        crate::skill_info_for_project(&skill_name, Some(project_root)).map_err(internal_error)?
+    else {
+        return Err(not_found());
+    };
+
+    serde_json::to_value(info)
+        .map(Json)
+        .map_err(|error| internal_error(error.into()))
+}
