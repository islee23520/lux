+    #[test]
+    fn ai_work_step_concurrent_appends_preserve_complete_records() {
+        const WRITER_COUNT: usize = 6;
+        const EVENTS_PER_WRITER: usize = 16;
+        let project_root = temp_project_root("ai-work-step-append-concurrent");
+        let path = Arc::new(project_root.join("UserSettings").join("LuxAiActionLog.jsonl"));
+
+        let handles: Vec<_> = (0..WRITER_COUNT)
+            .map(|writer| {
+                let path = Arc::clone(&path);
+                thread::spawn(move || {
+                    for index in 0..EVENTS_PER_WRITER {
+                        let sequence = (writer * EVENTS_PER_WRITER + index) as u64;
+                        let record = test_ai_work_step_record(
+                            &format!("ai-step-writer-{writer}-event-{index}"),
+                            sequence,
+                        );
+                        append_ai_work_step_record(&*path, &record).unwrap();
+                    }
+                })
+            })
+            .collect();
+
+        for handle in handles {
+            handle.join().unwrap();
+        }
+
+        let contents = fs::read_to_string(&*path).unwrap();
+        let records = parse_ai_work_step_records(Cursor::new(contents));
+        let mut ids = BTreeSet::new();
+        assert_eq!(records.len(), WRITER_COUNT * EVENTS_PER_WRITER);
+        for record in records {
+            assert_eq!(record.value["payload"]["kind"], AI_WORK_STEP_RECORD_KIND);
+            assert!(ids.insert(record.value["id"].as_str().unwrap().to_string()));
+        }
+        assert_eq!(ids.len(), WRITER_COUNT * EVENTS_PER_WRITER);
+
+        fs::remove_dir_all(project_root).unwrap();
+    }
 
