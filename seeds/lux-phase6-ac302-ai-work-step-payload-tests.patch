+    #[test]
+    fn ai_work_step_payload_roundtrips_tool_metadata_through_serde() {
+        let payload = EventPayloadConvention::new(
+            EventPayloadKind::AiWorkStep,
+            "tool.apply_patch",
+            "AI tool step applied a source edit.",
+        )
+        .with_status("completed")
+        .with_attribute("action", json!("apply_patch"))
+        .with_attribute(
+            "changedFiles",
+            json!(["LuxEditorTests/Editor/LuxAiActionLogTests.cs"]),
+        )
+        .with_attribute("diagnosticCount", json!(0))
+        .with_attribute("executionId", json!("exec-302"))
+        .with_attribute("stepName", json!("apply_patch"))
+        .with_attribute("tool", json!("codex"));
+        let value = serde_json::to_value(payload).unwrap();
+
+        assert_eq!(value["kind"], "ai-work-step");
+        assert_eq!(value["eventType"], "tool.apply_patch");
+        assert_eq!(value["summary"], "AI tool step applied a source edit.");
+        assert_eq!(value["status"], "completed");
+        assert_eq!(value["attributes"]["action"], json!("apply_patch"));
+        assert_eq!(
+            value["attributes"]["changedFiles"][0],
+            json!("LuxEditorTests/Editor/LuxAiActionLogTests.cs")
+        );
+        assert_eq!(value["attributes"]["diagnosticCount"], json!(0));
+        assert_eq!(value["attributes"]["executionId"], json!("exec-302"));
+        assert_eq!(value["attributes"]["stepName"], json!("apply_patch"));
+        assert_eq!(value["attributes"]["tool"], json!("codex"));
+
+        let roundtrip = EventPayloadConvention::from_json_value(value).unwrap();
+
+        assert_eq!(roundtrip.kind, EventPayloadKind::AiWorkStep);
+        assert_eq!(roundtrip.event_type, "tool.apply_patch");
+        assert_eq!(roundtrip.summary, "AI tool step applied a source edit.");
+        assert_eq!(roundtrip.status.as_deref(), Some("completed"));
+        assert_eq!(roundtrip.attributes["stepName"], json!("apply_patch"));
+        assert_eq!(roundtrip.attributes["tool"], json!("codex"));
+    }
