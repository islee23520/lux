+        [Test]
+        public void Broadcaster_EditorHookEventLoggingSmokePersistsReadableJsonl()
+        {
+            string path = Path.Combine(_tempDirectory, "UserSettings", "LuxAiActionLog.jsonl");
+            using var log = new UnityEditor.LuxAiActionLog(logPath: path);
+            var broadcasts = new List<Tuple<string, UnityEditor.LuxAiActionLogEntry>>();
+            UnityEditor.LuxAiActionLogBroadcaster.ConfigureForTests(
+                log,
+                (eventType, payload) => broadcasts.Add(Tuple.Create(eventType, (UnityEditor.LuxAiActionLogEntry)payload)),
+                () => 0.0);
+
+            InvokeBroadcasterHook("OnProjectChanged");
+            UnityEditor.LuxAiActionLogBroadcaster.Flush();
+
+            Assert.That(File.Exists(path), Is.True);
+            string[] lines = File.ReadAllLines(path);
+            Assert.That(lines, Has.Length.EqualTo(1));
+
+            var parsed = UnityEngine.JsonUtility.FromJson<EditorHookSmokeRecordForTests>(lines[0]);
+            Assert.That(parsed.schemaVersion, Is.EqualTo(UnityEditor.LuxAiActionLog.SchemaVersion));
+            Assert.That(parsed.protocol, Is.EqualTo(UnityEditor.LuxAiActionLog.Protocol));
+            Assert.That(parsed.source, Is.EqualTo("unity-editor"));
+            Assert.That(parsed.actor, Is.EqualTo("user"));
+            Assert.That(parsed.category, Is.EqualTo("project"));
+            Assert.That(parsed.action, Is.EqualTo("changed"));
+            Assert.That(parsed.target, Is.EqualTo("Project"));
+            Assert.That(parsed.message, Is.EqualTo("Unity project assets changed."));
+            Assert.That(parsed.success, Is.True);
+
+            var recent = log.Recent();
+            Assert.That(recent, Has.Count.EqualTo(1));
+            Assert.That(recent[0].source, Is.EqualTo("unity-editor"));
+            Assert.That(recent[0].actor, Is.EqualTo("user"));
+            Assert.That(recent[0].category, Is.EqualTo("project"));
+            Assert.That(recent[0].action, Is.EqualTo("changed"));
+
+            Assert.That(broadcasts, Has.Count.EqualTo(1));
+            Assert.That(broadcasts[0].Item1, Is.EqualTo("ai_action_log"));
+            Assert.That(broadcasts[0].Item2.source, Is.EqualTo("unity-editor"));
+            Assert.That(broadcasts[0].Item2.category, Is.EqualTo("project"));
+        }
+
