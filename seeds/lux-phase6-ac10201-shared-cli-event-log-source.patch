+fn resolve_ai_log_source(args: &AiLogProjectArgs) -> anyhow::Result<AiLogSource> {
+    let project_path = normalize_cli_project_path(&args.project_path)?;
+    let path_resolution = ai_log::ensure_log_path_resolution(&project_path)?;
+    let log_path = path_resolution.path.clone();
