+        project_path,
+        log_path,
+        path_resolution,
+    })
+}
+
+fn normalize_cli_project_path(path: &Path) -> anyhow::Result<PathBuf> {
+    let absolute = if path.is_absolute() {
+        path.to_path_buf()
+    } else {
+        std::env::current_dir()
+            .context("failed to determine current directory")?
+            .join(path)
+    };
+
+    Ok(absolute.canonicalize().unwrap_or(absolute))
+}
