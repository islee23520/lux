+#[test]
+fn ai_log_recent_json_read_response_has_project_scoped_contract_fields() {
+    let project_root = create_ai_log_fixture_project("lux-ai-log-recent-contract");
+    let output = Command::new(env!("CARGO_BIN_EXE_lux"))
+        .args([
+            "ai-log",
+            "recent",
+            "--project-path",
+            project_root.to_str().expect("project path UTF-8"),
+            "--limit",
+            "3",
+            "--json",
+        ])
+        .output()
+        .expect("run lux ai-log recent contract read");
+
+    assert_command_success(&output, "lux ai-log recent contract read");
+    let parsed: Value = serde_json::from_slice(&output.stdout).expect("recent contract JSON");
+    assert_eq!(parsed["projectPath"], project_root.display().to_string());
+    assert_eq!(
+        parsed["path"],
+        project_root
+            .join(".lux/ai-action-log.jsonl")
+            .display()
+            .to_string()
+    );
+    assert_eq!(parsed["count"], 3);
+    let entries = parsed["entries"].as_array().expect("entries array");
+    assert_eq!(entries.len(), 3);
+    assert_eq!(entries[0]["line_number"], 3);
+    assert_eq!(entries[0]["timestamp"], "2026-05-04T00:00:02Z");
+    assert_eq!(entries[0]["value"]["summary"], "second codex edit");
+    assert_eq!(entries[2]["value"]["summary"], "opencode review");
+}
+
+#[test]
+fn ai_log_recent_json_filters_only_the_requested_project_log() {
+    let requested_project = create_ai_log_project_with_log(
+        "lux-ai-log-requested-project",
+        concat!(
+            "{\"timestampUtc\":\"2026-05-04T00:00:01Z\",\"actor\":\"codex\",\"category\":\"ai-action-log\",\"source\":\"cli\",\"action\":\"edit\",\"eventType\":\"append\",\"summary\":\"requested project edit\"}\n",
+            "{\"timestampUtc\":\"2026-05-04T00:00:02Z\",\"actor\":\"opencode\",\"category\":\"review\",\"source\":\"cli\",\"action\":\"qa\",\"eventType\":\"complete\",\"summary\":\"requested project review\"}\n",
+        ),
+    );
+    let other_project = create_ai_log_project_with_log(
+        "lux-ai-log-other-project",
+        "{\"timestampUtc\":\"2026-05-04T00:00:01Z\",\"actor\":\"codex\",\"category\":\"ai-action-log\",\"source\":\"cli\",\"action\":\"edit\",\"eventType\":\"append\",\"summary\":\"other project edit\"}\n",
+    );
+
+    let output = Command::new(env!("CARGO_BIN_EXE_lux"))
+        .args([
+            "ai-log",
+            "recent",
+            "--project-path",
+            requested_project.to_str().expect("project path UTF-8"),
+            "--limit",
+            "10",
+            "--json",
+            "--actor",
+            "codex",
+            "--category",
+            "ai-action-log",
+            "--source",
+            "cli",
+            "--action",
+            "edit",
+            "--event-type",
+            "append",
+        ])
+        .output()
+        .expect("run lux ai-log recent project-scoped read");
+
+    assert_command_success(&output, "lux ai-log recent project-scoped read");
+    let parsed: Value = serde_json::from_slice(&output.stdout).expect("project-scoped JSON");
+    assert_eq!(
+        parsed["projectPath"],
+        requested_project.display().to_string()
+    );
+    assert_eq!(
+        parsed["path"],
+        requested_project
+            .join(".lux/ai-action-log.jsonl")
+            .display()
+            .to_string()
+    );
+    assert_eq!(parsed["count"], 1);
+    let entries = parsed["entries"].as_array().expect("entries array");
+    assert_eq!(entries[0]["value"]["summary"], "requested project edit");
+    assert_ne!(entries[0]["value"]["summary"], "other project edit");
+    assert!(other_project.join(".lux/ai-action-log.jsonl").is_file());
+}
