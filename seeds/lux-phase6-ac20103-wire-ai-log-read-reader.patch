+
+fn build_ai_log_read_response(
+    project_root: &Path,
+    path: &Path,
+    entries: &[AiLogEntry],
+    filter: &AiLogFilter,
+) -> AiLogReadResponse {
+    let limit = filter.limit.unwrap_or(AI_LOG_DEFAULT_LIMIT);
+    let mut ordered = entries.to_vec();
+    ordered.sort_by(|left, right| {
+        left.timestamp
+            .cmp(&right.timestamp)
+            .then(left.line_number.cmp(&right.line_number))
+    });
+    if ordered.len() > limit {
+        ordered = ordered.split_off(ordered.len() - limit);
+    }
+    let entries: Vec<_> = ordered.iter().map(ai_log_read_entry).collect();
+
+    AiLogReadResponse {
+        schema_version: 1,
+        protocol: "lux.ai_log.read.v1",
+        project_path: project_root.display().to_string(),
+        path: path.display().to_string(),
+        limit,
+        filters: AiLogReadFilters {
+            actor: filter.actor.clone(),
+            category: filter.category.clone(),
+            source: filter.source.clone(),
+            action: filter.action.clone(),
+            event_type: filter.event_type.clone(),
+        },
+        count: entries.len(),
+        entries,
+    }
+}
+
+fn ai_log_read_entry(entry: &AiLogEntry) -> AiLogReadEntry {
+    let event_type = ai_log_event_type(&entry.value);
+    AiLogReadEntry {
+        line_number: entry.line_number,
+        timestamp_utc: redact_api_text(&entry.timestamp),
+        id: ai_log_string_field_deep(&entry.value, "id")
+            .or_else(|| ai_log_string_field_deep(&entry.value, "event_id"))
+            .map(|text| redact_api_text(&text)),
+        actor: redacted_ai_log_string_field(&entry.value, "actor"),
+        category: redacted_ai_log_string_field(&entry.value, "category"),
+        source: redacted_ai_log_string_field(&entry.value, "source"),
+        type_name: event_type.clone(),
+        action: redacted_ai_log_string_field(&entry.value, "action"),
+        target: redacted_ai_log_string_field(&entry.value, "target"),
+        status: redacted_ai_log_string_field(&entry.value, "status"),
+        tool: redacted_ai_log_string_field(&entry.value, "tool"),
+        event_type,
+        summary: ai_log_compact_summary(&entry.value),
+        message: ai_log_compact_message(&entry.value),
+        redaction_metadata: redacted_ai_log_value_field(&entry.value, "redactionMetadata")
+            .or_else(|| redacted_ai_log_value_field(&entry.value, "redaction_metadata")),
+        retention_metadata: redacted_ai_log_value_field(&entry.value, "retentionMetadata")
+            .or_else(|| redacted_ai_log_value_field(&entry.value, "retention_metadata")),
+    }
+}
+
+fn ai_log_event_type(value: &serde_json::Value) -> Option<String> {
+    ai_log_string_field_deep(value, "type")
+        .or_else(|| ai_log_string_field_deep(value, "eventType"))
+        .or_else(|| ai_log_string_field_deep(value, "event_type"))
+        .or_else(|| ai_log_string_field_deep(value, "kind"))
+        .or_else(|| ai_log_string_field_deep(value, "stepName"))
+        .or_else(|| ai_log_string_field_deep(value, "action"))
+        .map(|text| redact_api_text(&text))
+}
+
+fn ai_log_compact_summary(value: &serde_json::Value) -> Option<String> {
+    [
+        "summary",
+        "message",
+        "description",
+        "resultSummary",
+        "stepName",
+    ]
+    .iter()
+    .find_map(|field| ai_log_string_field_deep(value, field))
+    .map(|text| redact_api_text(&text))
+}
+
+fn ai_log_compact_message(value: &serde_json::Value) -> Option<String> {
+    ["message", "summary", "description", "resultSummary"]
+        .iter()
+        .find_map(|field| ai_log_string_field_deep(value, field))
+        .map(|text| redact_api_text(&text))
+}
+
+fn redacted_ai_log_string_field(value: &serde_json::Value, field: &str) -> Option<String> {
+    ai_log_string_field_deep(value, field).map(|text| redact_api_text(&text))
+}
+
+fn ai_log_string_field_deep(value: &serde_json::Value, field: &str) -> Option<String> {
+    value
+        .get(field)
+        .and_then(serde_json::Value::as_str)
+        .or_else(|| value.get("payload")?.get(field)?.as_str())
+        .map(ToOwned::to_owned)
+}
+
+fn redacted_ai_log_value_field(
+    value: &serde_json::Value,
+    field: &str,
+) -> Option<serde_json::Value> {
+    value
+        .get(field)
+        .map(redact_api_value)
+        .or_else(|| value.get("payload")?.get(field).map(redact_api_value))
+}
+
+fn redact_api_value(value: &serde_json::Value) -> serde_json::Value {
+    match value {
+        serde_json::Value::String(text) => serde_json::Value::String(redact_api_text(text)),
+        serde_json::Value::Array(items) => {
+            serde_json::Value::Array(items.iter().map(redact_api_value).collect())
+        }
+        serde_json::Value::Object(object) => serde_json::Value::Object(
+            object
+                .iter()
+                .map(|(key, value)| (redact_api_text(key), redact_api_value(value)))
+                .collect(),
+        ),
+        other => other.clone(),
+    }
 }
 
+fn redact_api_text(text: &str) -> String {
+    let mut redact_next = false;
+    text.split_whitespace()
+        .map(|part| {
+            if redact_next {
+                redact_next = false;
+                "[REDACTED]".to_string()
+            } else if part.eq_ignore_ascii_case("bearer") {
+                redact_next = true;
+                "[REDACTED]".to_string()
+            } else {
+                ai_log::redact_secrets(part)
+            }
+        })
+        .collect::<Vec<_>>()
+        .join(" ")
+}
