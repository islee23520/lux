+fn record_context_slimming_result_event(adaptation: &Value) -> anyhow::Result<()> {
+    let Some(context_slimming) = adaptation.get("context_slimming") else {
+        return Ok(());
+    };
+    let project_root = adaptation
+        .get("project_root")
+        .and_then(Value::as_str)
+        .map(PathBuf::from)
+        .context("context slimming adaptation metadata is missing project_root")?;
+    let log_path = ai_log::ensure_log_path(&project_root)?;
+    let timestamp_utc = lux_cli_event_timestamp();
+    let event = build_context_slimming_result_event(adaptation, context_slimming, &timestamp_utc);
+
+    ai_log::append_ai_work_step_record(&log_path, &event).with_context(|| {
+        format!(
+            "failed to persist context slimming result event to {}",
+            log_path.display()
+        )
+    })
+}
+
+fn build_context_slimming_result_event(
+    adaptation: &Value,
+    context_slimming: &Value,
+    timestamp_utc: &str,
+) -> Value {
+    let skill_name = context_slimming
+        .get("skill_name")
+        .and_then(Value::as_str)
+        .or_else(|| adaptation.get("skill_name").and_then(Value::as_str))
+        .unwrap_or("unknown-skill");
+    let event_type = "skill.context_slimming.completed";
+    let summary = format!("Context slimming completed for adapted skill '{skill_name}'.");
+    let context_slimming_status = context_slimming_event_status(context_slimming);
+    let adaptation_status = context_slimming_adaptation_status(adaptation);
+
+    json!({
+        "schemaVersion": 1,
+        "protocol": "lux.ai.action_log.v1",
+        "id": format!(
+            "skill-context-slimming-{}-{}",
+            event_id_component(skill_name),
+            event_id_component(timestamp_utc)
+        ),
+        "timestampUtc": timestamp_utc,
+        "projectPath": adaptation.get("project_root").cloned().unwrap_or(Value::Null),
+        "source": "lux-cli",
+        "actor": "lux-skill",
+        "category": "ai-action-log",
+        "type": event_type,
+        "summary": summary,
+        "status": context_slimming_status,
+        "tool": "lux skill install --adapt",
+        "payload": {
+            "kind": ai_log::AI_WORK_STEP_RECORD_KIND,
+            "eventType": event_type,
+            "stepName": "context-slimming",
+            "status": context_slimming_status,
+            "summary": summary,
+            "ordering": {
+                "sequence": 0,
+                "groupId": format!("skill-adaptation-{skill_name}"),
+            },
+            "timestamps": {
+                "recordedAtUtc": timestamp_utc,
+            },
+            "tool": {
+                "name": "lux skill install",
+                "action": "adapt",
+            },
+            "action": {
+                "name": "persist-context-slimming-result",
+                "target": skill_name,
+                "result": context_slimming_status,
+            },
+            "content": {
+                "summary": summary,
+            },
+            "attributes": {
+                "adaptation": {
+                    "protocol": adaptation.get("protocol").cloned().unwrap_or(Value::Null),
+                    "status": adaptation_status,
+                    "checkCount": adaptation
+                        .get("checks")
+                        .and_then(Value::as_array)
+                        .map(Vec::len)
+                        .unwrap_or_default(),
+                    "warningCount": adaptation
+                        .get("warnings")
+                        .and_then(Value::as_array)
+                        .map(Vec::len)
+                        .unwrap_or_default(),
+                },
+                "contextSlimming": {
+                    "schema": context_slimming.get("schema").cloned().unwrap_or(Value::Null),
+                    "skillName": skill_name,
+                    "status": context_slimming_status,
+                    "mode": context_slimming.get("mode").cloned().unwrap_or(Value::Null),
+                    "artifacts": context_slimming.get("artifacts").cloned().unwrap_or(Value::Null),
+                    "metrics": context_slimming.get("metrics").cloned().unwrap_or(Value::Null),
+                },
+            },
+        },
+    })
+}
+
+fn context_slimming_event_status(context_slimming: &Value) -> &'static str {
+    let has_json_artifact = context_slimming
+        .pointer("/artifacts/json")
+        .and_then(Value::as_str)
+        .is_some_and(|path| !path.trim().is_empty());
+    let has_markdown_artifact = context_slimming
+        .pointer("/artifacts/markdown")
+        .and_then(Value::as_str)
+        .is_some_and(|path| !path.trim().is_empty());
+
+    if has_json_artifact && has_markdown_artifact {
+        "completed"
+    } else {
+        "incomplete"
+    }
+}
+
+fn context_slimming_adaptation_status(adaptation: &Value) -> &'static str {
+    if adaptation
+        .get("protocol")
+        .and_then(Value::as_str)
+        .is_some_and(|protocol| protocol == "lux.skill.adaptation.v1")
+    {
+        "adapted"
+    } else {
+        "unknown"
+    }
+}
+
+fn lux_cli_event_timestamp() -> String {
+    use std::time::{SystemTime, UNIX_EPOCH};
+
+    let seconds = SystemTime::now()
+        .duration_since(UNIX_EPOCH)
+        .map(|duration| duration.as_secs())
+        .unwrap_or_default();
+    format!("unix:{seconds}")
+}
+
+fn event_id_component(value: &str) -> String {
+    let sanitized: String = value
+        .chars()
+        .map(|character| {
+            if character.is_ascii_alphanumeric() || matches!(character, '-' | '_') {
+                character
+            } else {
+                '-'
+            }
+        })
+        .collect();
+
+    if sanitized.trim_matches('-').is_empty() {
+        "unknown".to_string()
+    } else {
+        sanitized.trim_matches('-').to_string()
+    }
+}
