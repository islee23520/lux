+fn combine_ai_log_file_diagnostics(files: &[AiLogFileInfo]) -> ai_log::AiLogReadDiagnostics {
+    let skipped_lines = files
+        .iter()
+        .flat_map(|file| file.diagnostics.skipped_lines.iter().cloned())
+        .collect::<Vec<_>>();
+    ai_log::AiLogReadDiagnostics {
+        skipped_line_count: skipped_lines.len(),
+        skipped_lines,
+    }
+}
+
+fn sanitize_ai_log_diagnostics(
+    diagnostics: ai_log::AiLogReadDiagnostics,
+) -> ai_log::AiLogReadDiagnostics {
+    let skipped_lines = diagnostics
+        .skipped_lines
+        .into_iter()
+        .map(|line| ai_log::AiLogSkippedLine {
+            line_number: line.line_number,
+            reason: redact_api_warning_text(&line.reason),
+            message: redact_api_warning_text(&line.message),
+        })
+        .collect::<Vec<_>>();
+    ai_log::AiLogReadDiagnostics {
+        skipped_line_count: skipped_lines.len(),
+        skipped_lines,
+    }
+}
+
+fn redact_api_warning_text(text: &str) -> String {
+    let mut redact_next = false;
+    text.split_whitespace()
+        .map(|part| {
+            if redact_next {
+                redact_next = false;
+                "[REDACTED]".to_string()
+            } else if part.eq_ignore_ascii_case("bearer") {
+                redact_next = true;
+                "[REDACTED]".to_string()
+            } else {
+                ai_log::redact_secrets(part)
+            }
+        })
+        .collect::<Vec<_>>()
+        .join(" ")
+}
 
