+
+        static int DrainEditorEvents(int maxEvents)
+        {
+            int recorded = 0;
+            int limit = maxEvents <= 0 ? EditorEventBatchSize : maxEvents;
+            while (recorded < limit)
+            {
+                LuxPendingEditorEvent pending;
+                lock (Sync)
+                {
+                    if (PendingEditorEvents.Count == 0)
+                    {
+                        return recorded;
+                    }
+
+                    pending = PendingEditorEvents.Dequeue();
+                }
+
+                RecordEditorHookEvent(pending);
+                recorded++;
+            }
+
+            return recorded;
+        }
