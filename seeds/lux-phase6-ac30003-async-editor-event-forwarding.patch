+        static void EnqueueEditorHookEvent(
+            string hookName,
+            string eventType,
+            string target,
+            string message,
+            string status,
+            IReadOnlyDictionary<string, string> metadata = null,
+            string severity = "info",
+            bool success = true)
+        {
+            var pending = CreatePendingEditorEvent(hookName, eventType, target, message, status, metadata, severity, success);
+            lock (Sync)
+            {
+                while (PendingEditorEvents.Count >= MaxQueuedEditorEvents)
+                {
+                    PendingEditorEvents.Dequeue();
+                }
+
+                PendingEditorEvents.Enqueue(pending);
