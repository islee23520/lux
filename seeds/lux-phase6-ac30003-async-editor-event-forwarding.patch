+        [Test]
+        public void Broadcaster_QueuesEditorHookEventsUntilExplicitPump()
+        {
+            string path = GetTempLogPath();
+            using var log = new UnityEditor.LuxAiActionLog(logPath: path);
+            var broadcasts = new List<Tuple<string, UnityEditor.LuxAiActionLogEntry>>();
+            UnityEditor.LuxAiActionLogBroadcaster.ConfigureForTests(
+                log,
+                (eventType, payload) => broadcasts.Add(Tuple.Create(eventType, (UnityEditor.LuxAiActionLogEntry)payload)),
+                () => 0.0);
+
+            UnityEditor.LuxAiActionLogBroadcaster.QueueEditorHookEventForTests(
+                "Selection.selectionChanged",
+                " Selection.Changed ",
+                "Main Camera",
+                "Unity selection changed.",
+                "completed",
+                new Dictionary<string, string>
+                {
+                    ["objectCount"] = "1",
+                    ["apiKey"] = "secret-token"
+                });
+
+            Assert.That(UnityEditor.LuxAiActionLogBroadcaster.PendingEditorEventCountForTests(), Is.EqualTo(1));
+            Assert.That(log.Recent(), Is.Empty);
+            Assert.That(File.Exists(path), Is.False);
+            Assert.That(broadcasts, Is.Empty);
+
+            int recorded = UnityEditor.LuxAiActionLogBroadcaster.PumpEditorEventsForTests();
+            log.Flush();
+
+            var recent = log.Recent();
+            string jsonl = File.ReadAllText(path);
+            Assert.That(recorded, Is.EqualTo(1));
+            Assert.That(UnityEditor.LuxAiActionLogBroadcaster.PendingEditorEventCountForTests(), Is.EqualTo(0));
+            Assert.That(recent, Has.Count.EqualTo(1));
+            Assert.That(recent[0].source, Is.EqualTo("unity-editor"));
+            Assert.That(recent[0].category, Is.EqualTo("editor"));
+            Assert.That(recent[0].action, Is.EqualTo("selection.changed"));
+            Assert.That(recent[0].metadata["hookName"], Is.EqualTo("Selection.selectionChanged"));
+            Assert.That(recent[0].metadata["objectCount"], Is.EqualTo("1"));
+            Assert.That(recent[0].metadata["apiKey"], Is.EqualTo("[REDACTED]"));
+            Assert.That(jsonl, Does.Contain("\"action\":\"selection.changed\""));
+            Assert.That(jsonl, Does.Not.Contain("secret-token"));
+            Assert.That(broadcasts, Is.Empty);
+
+            Assert.That(UnityEditor.LuxAiActionLogBroadcaster.PumpForTests(), Is.EqualTo(1));
+            Assert.That(broadcasts, Has.Count.EqualTo(1));
+            Assert.That(broadcasts[0].Item1, Is.EqualTo("ai_action_log"));
+            Assert.That(broadcasts[0].Item2.metadata["apiKey"], Is.EqualTo("[REDACTED]"));
+        }
+
