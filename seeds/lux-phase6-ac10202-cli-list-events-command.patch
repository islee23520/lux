+#[test]
+fn ai_log_list_json_filters_only_requested_project_events() {
+    let requested_project = create_ai_log_project_with_log(
+        "lux-ai-log-list-requested-project",
+        concat!(
+            "{\"timestampUtc\":\"2026-05-04T00:00:01Z\",\"actor\":\"codex\",\"category\":\"ai-action-log\",\"source\":\"cli\",\"action\":\"edit\",\"eventType\":\"append\",\"summary\":\"requested project edit\"}\n",
+            "{\"timestampUtc\":\"2026-05-04T00:00:02Z\",\"actor\":\"opencode\",\"category\":\"review\",\"source\":\"cli\",\"action\":\"qa\",\"eventType\":\"complete\",\"summary\":\"requested project review\"}\n",
+        ),
+    );
+    let other_project = create_ai_log_project_with_log(
+        "lux-ai-log-list-other-project",
+        "{\"timestampUtc\":\"2026-05-04T00:00:01Z\",\"actor\":\"codex\",\"category\":\"ai-action-log\",\"source\":\"cli\",\"action\":\"edit\",\"eventType\":\"append\",\"summary\":\"other project edit\"}\n",
+    );
+
+    let output = Command::new(env!("CARGO_BIN_EXE_lux"))
+        .args([
+            "ai-log",
+            "list",
+            "--project-path",
+            requested_project.to_str().expect("project path UTF-8"),
+            "--json",
+            "--actor",
+            "codex",
+            "--category",
+            "ai-action-log",
+            "--source",
+            "cli",
+            "--action",
+            "edit",
+            "--event-type",
+            "append",
+        ])
+        .env_remove("LUX_AI_ACTION_LOG_PATH")
+        .output()
+        .expect("run lux ai-log list project scoped");
+
+    assert_command_success(&output, "lux ai-log list project scoped");
+    let parsed: Value = serde_json::from_slice(&output.stdout).expect("project-scoped list JSON");
+    assert_eq!(parsed["count"], 1);
+    assert_eq!(parsed["entries"][0]["value"]["summary"], "requested project edit");
+    assert_ne!(parsed["entries"][0]["value"]["summary"], "other project edit");
+    assert!(other_project
+        .join("UserSettings/LuxAiActionLog.jsonl")
+        .is_file());
+}
