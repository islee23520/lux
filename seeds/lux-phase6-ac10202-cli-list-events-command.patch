+#[test]
+fn ai_log_list_json_lists_persisted_events_for_project_path() {
+    let project_root = create_ai_log_fixture_project("lux-ai-log-list");
+    let output = Command::new(env!("CARGO_BIN_EXE_lux"))
+        .args([
+            "ai-log",
+            "list",
+            "--project-path",
+            project_root.to_str().expect("project path UTF-8"),
+            "--json",
+        ])
+        .env_remove("LUX_AI_ACTION_LOG_PATH")
+        .output()
+        .expect("run lux ai-log list");
+
+    assert_command_success(&output, "lux ai-log list");
+    let parsed: Value = serde_json::from_slice(&output.stdout).expect("list JSON");
+    assert_eq!(
+        parsed["projectPath"],
+        project_root
+            .canonicalize()
+            .expect("canonical project path")
+            .to_string_lossy()
+            .as_ref()
+    );
+    assert_eq!(
+        parsed["path"],
+        project_root
+            .canonicalize()
+            .expect("canonical project path")
+            .join("UserSettings/LuxAiActionLog.jsonl")
+            .to_string_lossy()
+            .as_ref()
+    );
+    assert_eq!(parsed["pathResolution"]["source"], "default_project_path");
+    assert_eq!(parsed["count"], 4);
+    let entries = parsed["entries"].as_array().expect("entries array");
+    assert_eq!(entries[0]["line_number"], 1);
+    assert_eq!(entries[0]["value"]["summary"], "first codex edit");
+    assert_eq!(entries[1]["line_number"], 3);
+    assert_eq!(entries[1]["value"]["summary"], "second codex edit");
+    assert_eq!(entries[3]["value"]["summary"], "opencode review");
+}
