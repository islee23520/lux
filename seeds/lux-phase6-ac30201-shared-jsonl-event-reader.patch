+pub fn read_project_event_log(
+    project_root: impl AsRef<Path>,
+    filter: &AiLogFilter,
+) -> Result<ProjectEventLogReadResult> {
+    let project_root = project_root.as_ref();
+    let path = resolve_log_path(project_root);
+    let entries = read_jsonl_event_entries(&path, filter)?;
+
+    Ok(ProjectEventLogReadResult {
+        project_path: project_root.to_path_buf(),
+        path,
+        entries,
+    })
+}
+
+pub fn read_jsonl_event_entries(
+    path: impl AsRef<Path>,
+    filter: &AiLogFilter,
+) -> Result<Vec<AiLogEntry>> {
+    let path = path.as_ref();
+    if !path.exists() {
+        return Ok(Vec::new());
+    }
+
+    let file = File::open(path)
+        .with_context(|| format!("failed to open project event log {}", path.display()))?;
+    Ok(filter_ordered_entries(
+        parse_entries(BufReader::new(file)),
+        filter,
+    ))
+}
