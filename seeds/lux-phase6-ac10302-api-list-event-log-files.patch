+fn parse_ai_log_project_request(
+    state: &GatewayState,
+    requested_project_path: Option<PathBuf>,
+) -> Result<AiLogProjectRequest, Response> {
+    let project_root = match requested_project_path {
+        Some(path) => canonicalize_unity_project_path(&path)?,
+        None => {
+            let Some(configured_project_root) = state.config.project_root.as_ref() else {
+                return Err((
+                    StatusCode::SERVICE_UNAVAILABLE,
+                    "project path is not configured",
+                )
+                    .into_response());
+            };
+            canonicalize_unity_project_path(configured_project_root)?
+        }
+    };
+
+    if let Some(configured_project_root) = state.config.project_root.as_ref() {
+        let configured_project_root = canonicalize_unity_project_path(configured_project_root)?;
+        if configured_project_root != project_root {
+            return Err((
+                StatusCode::FORBIDDEN,
+                "requested project path is outside the configured project scope",
+            )
+                .into_response());
+        }
+    }
+
+    let log_path = ai_log::ensure_log_path(&project_root).map_err(internal_error)?;
+    Ok(AiLogProjectRequest {
+        project_root,
+        log_path,
+    })
+}
+
+fn canonicalize_unity_project_path(path: &Path) -> Result<PathBuf, Response> {
+    if path.as_os_str().is_empty() {
+        return Err((StatusCode::BAD_REQUEST, "project path is required").into_response());
+    }
+
+    let project_root = path.canonicalize().map_err(|_| {
+        (
+            StatusCode::BAD_REQUEST,
+            "project path must be an accessible Unity project directory",
+        )
+            .into_response()
+    })?;
+
+    if !project_root.is_dir()
+        || !project_root.join("Assets").is_dir()
+        || !project_root.join("ProjectSettings").is_dir()
+    {
+        return Err((
+            StatusCode::BAD_REQUEST,
+            "project path must contain Assets and ProjectSettings directories",
+        )
+            .into_response());
+    }
+
+    Ok(project_root)
+}
+
+fn discover_ai_log_files(
+    project_root: &Path,
+    log_path: &Path,
+) -> anyhow::Result<Vec<AiLogFileInfo>> {
+    let mut paths = discover_ai_log_file_paths(log_path)?;
+    paths.sort();
+    paths
+        .iter()
+        .map(|path| inspect_ai_log_file(project_root, path))
+        .collect()
+}
+
+fn discover_ai_log_file_paths(log_path: &Path) -> anyhow::Result<Vec<PathBuf>> {
+    let Some(parent) = log_path.parent() else {
+        return Ok(Vec::new());
+    };
+    if !parent.is_dir() {
+        return Ok(Vec::new());
+    }
+
+    let expected_name = log_path.file_name();
+    let expected_stem = log_path
+        .file_stem()
+        .and_then(|stem| stem.to_str())
+        .unwrap_or_default();
+
+    let mut paths = Vec::new();
+    for entry in fs::read_dir(parent)? {
+        let path = entry?.path();
+        if !path.is_file() || path.extension().and_then(|ext| ext.to_str()) != Some("jsonl") {
+            continue;
+        }
+
+        let file_name_matches = expected_name.map_or(false, |name| path.file_name() == Some(name));
+        let stem_matches = path
+            .file_stem()
+            .and_then(|stem| stem.to_str())
+            .map_or(false, |stem| {
+                stem == expected_stem
+                    || (!expected_stem.is_empty() && stem.starts_with(&format!("{expected_stem}.")))
+            });
+
+        if file_name_matches || stem_matches {
+            paths.push(path);
+        }
+    }
+
+    Ok(paths)
+}
+
+fn inspect_ai_log_file(project_root: &Path, path: &Path) -> anyhow::Result<AiLogFileInfo> {
+    let metadata = fs::metadata(path)?;
+    let entries = ai_log::read_log_entries(path, &AiLogFilter::default())?;
+    let first_timestamp_utc = entries.first().map(|entry| entry.timestamp.clone());
+    let last_timestamp_utc = entries.last().map(|entry| entry.timestamp.clone());
+
+    Ok(AiLogFileInfo {
+        path: path.display().to_string(),
+        relative_path: path
+            .strip_prefix(project_root)
+            .ok()
+            .map(|relative| relative.display().to_string()),
+        byte_size: metadata.len(),
+        modified_unix_seconds: metadata
+            .modified()
+            .ok()
+            .and_then(|modified| modified.duration_since(UNIX_EPOCH).ok())
+            .map(|duration| duration.as_secs()),
+        line_count: count_lines(path)?,
+        valid_event_count: entries.len(),
+        first_timestamp_utc,
+        last_timestamp_utc,
+    })
+}
+
+fn count_lines(path: &Path) -> anyhow::Result<usize> {
+    let file = File::open(path)?;
+    let mut count = 0usize;
+    for line in BufReader::new(file).lines() {
+        line?;
+        count += 1;
+    }
+    Ok(count)
+}
