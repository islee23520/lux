+#[test]
+fn ai_log_recent_json_returns_ordered_editor_originated_events() {
+    let requested_project = create_temp_dir("lux-ai-log-ordered-editor-origin").join("Project");
+    let requested_log_directory = requested_project.join(".lux");
+    fs::create_dir_all(&requested_log_directory).expect("create requested .lux");
+    fs::write(
+        requested_log_directory.join("ai-action-log.jsonl"),
+        concat!(
+            "{\"timestampUtc\":\"2026-05-04T00:00:03Z\",\"id\":\"editor-3\",\"actor\":\"user\",\"category\":\"editor\",\"source\":\"unity-editor\",\"action\":\"playmode.state_changed\",\"eventType\":\"playmode.state_changed\",\"summary\":\"entered play mode\",\"payload\":{\"kind\":\"editor-action\",\"eventType\":\"playmode.state_changed\",\"status\":\"completed\",\"target\":\"EditorApplication.playModeStateChanged\",\"attributes\":{\"hookName\":\"EditorApplication.playModeStateChanged\",\"eventSource\":\"unity-editor\",\"eventCategory\":\"editor\"}}}\n",
+            "not-json\n",
+            "{\"timestampUtc\":\"2026-05-04T00:00:01Z\",\"id\":\"editor-1\",\"actor\":\"user\",\"category\":\"editor\",\"source\":\"unity-editor\",\"action\":\"selection.changed\",\"eventType\":\"selection.changed\",\"summary\":\"selected main camera\",\"payload\":{\"kind\":\"editor-action\",\"eventType\":\"selection.changed\",\"status\":\"completed\",\"target\":\"Scene/Main Camera\",\"attributes\":{\"hookName\":\"Selection.selectionChanged\",\"eventSource\":\"unity-editor\",\"eventCategory\":\"editor\",\"objectCount\":1}}}\n",
+            "{\"captured_at_utc\":\"2026-05-04T00:00:02Z\",\"id\":\"editor-2\",\"actor\":\"user\",\"category\":\"editor\",\"source\":\"unity-editor\",\"action\":\"asset.saved\",\"event_type\":\"asset.saved\",\"summary\":\"saved scene asset\",\"payload\":{\"kind\":\"editor-action\",\"eventType\":\"asset.saved\",\"status\":\"completed\",\"target\":\"Assets/Scenes/Game.unity\",\"attributes\":{\"hookName\":\"AssetDatabase.assetSaved\",\"eventSource\":\"unity-editor\",\"eventCategory\":\"editor\"}}}\n",
+            "{\"timestampUtc\":\"2026-05-04T00:00:00Z\",\"id\":\"ai-ignored\",\"actor\":\"codex\",\"category\":\"ai-tool\",\"source\":\"ai-tool-dispatcher\",\"eventType\":\"tool.step\",\"summary\":\"not an editor event\"}\n",
+        ),
+    )
+    .expect("write requested AI log fixture");
+
+    let other_project = create_temp_dir("lux-ai-log-ordered-editor-origin-other").join("Project");
+    let other_log_directory = other_project.join(".lux");
+    fs::create_dir_all(&other_log_directory).expect("create other .lux");
+    fs::write(
+        other_log_directory.join("ai-action-log.jsonl"),
+        "{\"timestampUtc\":\"2026-05-04T00:00:00Z\",\"id\":\"other-editor\",\"actor\":\"user\",\"category\":\"editor\",\"source\":\"unity-editor\",\"summary\":\"other project editor step\"}\n",
+    )
+    .expect("write other AI log fixture");
+
+    let output = Command::new(env!("CARGO_BIN_EXE_lux"))
+        .args([
+            "ai-log",
+            "recent",
+            "--project-path",
+            requested_project.to_str().expect("project path UTF-8"),
+            "--limit",
+            "10",
+            "--json",
+            "--category",
+            "editor",
+            "--source",
+            "unity-editor",
+        ])
+        .output()
+        .expect("run lux ai-log recent ordered editor read");
+
+    assert_command_success(&output, "lux ai-log recent ordered editor read");
+    let parsed: Value = serde_json::from_slice(&output.stdout).expect("ordered editor read JSON");
+    assert_eq!(
+        parsed["projectPath"],
+        requested_project.display().to_string()
+    );
+    assert_eq!(
+        parsed["path"],
+        requested_project
+            .join(".lux/ai-action-log.jsonl")
+            .display()
+            .to_string()
+    );
+    assert_eq!(parsed["count"], 3);
+
+    let entries = parsed["entries"].as_array().expect("entries array");
+    assert_eq!(entries[0]["line_number"], 3);
+    assert_eq!(entries[0]["value"]["id"], "editor-1");
+    assert_eq!(entries[0]["timestamp"], "2026-05-04T00:00:01Z");
+    assert_eq!(entries[0]["value"]["source"], "unity-editor");
+    assert_eq!(entries[0]["value"]["category"], "editor");
+    assert_eq!(entries[0]["value"]["payload"]["kind"], "editor-action");
+    assert_eq!(entries[0]["value"]["payload"]["target"], "Scene/Main Camera");
+    assert_eq!(entries[1]["line_number"], 4);
+    assert_eq!(entries[1]["value"]["id"], "editor-2");
+    assert_eq!(entries[1]["timestamp"], "2026-05-04T00:00:02Z");
+    assert_eq!(entries[1]["value"]["payload"]["target"], "Assets/Scenes/Game.unity");
+    assert_eq!(entries[2]["line_number"], 1);
+    assert_eq!(entries[2]["value"]["id"], "editor-3");
+    assert_eq!(entries[2]["timestamp"], "2026-05-04T00:00:03Z");
+    assert_eq!(entries[2]["value"]["payload"]["eventType"], "playmode.state_changed");
+
+    let serialized = serde_json::to_string(&parsed).unwrap();
+    assert!(!serialized.contains("ai-ignored"));
+    assert!(!serialized.contains("other-editor"));
+    assert!(!serialized.contains("other project editor step"));
+    assert!(other_project.join(".lux/ai-action-log.jsonl").is_file());
+}
